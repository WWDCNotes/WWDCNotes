{"sections":[],"abstract":[{"text":"Leveraging the industry-leading support for accessibility in OS X can let you reach new markets. Hear about exciting new products, new API additions and improved security for both accessibility hosts and clients; all designed to help applications reach wider audiences and provide unparalleled access for users with disabilities. Learn techniques to make even the most custom UI accessible.","type":"text"}],"sampleCodeDownload":{"action":{"isActive":true,"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2013\/200\/"},"kind":"sampleDownload"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC13-200-Accessibility-in-OS-X"},"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc13-200-accessibility-in-os-x"]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC13"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","metadata":{"modules":[{"name":"WWDC Notes"}],"title":"Accessibility in OS X","roleHeading":"WWDC13","role":"sampleCode"},"references":{"WWDC13.jpeg":{"alt":null,"identifier":"WWDC13.jpeg","type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC13.jpeg","traits":["1x","light"]}]},"https://nonstrict.eu/wwdcindex/wwdc2013/200/":{"type":"download","identifie