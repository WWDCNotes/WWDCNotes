{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Read Transcript","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/418\/","isActive":true}},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-418-Source-Control-Workflows-in-Xcode"},"abstract":[{"type":"text","text":"Xcode integrates with GitHub, Bitbucket, and GitLab to help you manage your source code, back up your files, and collaborate with others. Find out how to easily see the changes in your project right in the source editor, and learn how to use Xcode for common source control workflows with Git. See how conflicts occur, how to resolve them, and how to avoid them before they even happen."}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference","isActive":true}]},{"type":"heading","level":2,"anchor":"Related-Sessions","text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-404-Getting-Started-with-Xcode","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-413-Create-Your-Own-Swift-Playgrounds-Subscription","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-405-GitHub-and-the-New-Source-Control-Workflows-in-Xcode-9"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc18-418-source-control-workflows-in-xcode"]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/