{"sections":[],"kind":"article","variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc25-266-explore-concurrency-in-swiftui"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-266-Explore-concurrency-in-SwiftUI","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"]]},"metadata":{"modules":[{"name":"WWDC Notes"}],"title":"Explore concurrency in SwiftUI","roleHeading":"WWDC25","role":"sampleCode"},"abstract":[{"text":"Discover how SwiftUI leverages Swift concurrency to build safe and responsive apps. Explore how SwiftUI uses the main actor by default and offloads work to other actors. Learn how to interpret concurrency annotations and manage async tasks with SwiftUI’s event loop for smooth animations and UI updates. You’ll leave knowing how to avoid data races and write code fearlessly.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"type":"heading","text":"Related Sessions","level":2,"anchor":"Related-Sessions"},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-270-Codealong-Elevate-an-app-with-Swift-concurrency","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-268-Embracing-Swift-concurrency","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10156-Explore-SwiftUI-animation"],"style":"list"}],"kind":"content"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/266","isActive":true,"overridingTitle":"Watch Video (24 min)","type":"reference"}},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC25":{"url":"\/documentation\/wwdcnotes\/wwdc25","abstract":[{"text":"Xcode 26, Swift 6.2, iOS\/macOS\/tvOS\/visionOS 26.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AlarmKit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"PermissionKit","type":"codeVoice"},{"text":", and more.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25","type":"topic","kind":"article","images":[{"identifier":"WWDC25-Icon.png","type":"icon"},{"identifier":"WWDC25.jpg","type":"card"}],"role":"collectionGroup","title":"WWDC25"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-270-Codealong-Elevate-an-app-with-Swift-concurrency":{"title":"Code-along: Elevate an app with Swift concurrency","url":"\/documentation\/wwdcnotes\/wwdc25-270-codealong-elevate-an-app-with-swift-concurrency","abstract":[{"text":"Learn how to optimize your app’s user experience with Swift concurrency as we update an existing sample app. We’ll start with a main-actor app, then gradually introduce asynchronous code as we need to. We’ll use tasks to optimize code running on the main actor, and discover how to parallelize code by offloading work to the background. We’ll explore what data-race safety provides, and work through interpreting and fixing data-race safety errors. Finally, we’ll show how you can make the most out of structured concurrency in the context of an app.","type":"text"}],"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-270-Codealong-Elevate-an-app-with-Swift-concurrency","kind":"article","type":"topic"},"WWDC25.jpg":{"type":"image","identifier":"WWDC25.jpg","variants":[{"url":"\/images\/WWDCNotes\/WWDC25.jpg","traits":["1x","light"]}],"alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-268-Embracing-Swift-concurrency":{"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-268-Embracing-Swift-concurrency","kind":"article","title":"Embracing Swift concurrency","url":"\/documentation\/wwdcnotes\/wwdc25-268-embracing-swift-concurrency","abstract":[{"type":"text","text":"Join us to learn the core Swift concurrency concepts. Concurrency helps you improve app responsiveness and performance, and Swift is designed to make asynchronous and concurrent code easier to write correctly. We’ll cover the steps you need to take an app through from single-threaded to concurrent. We’ll also help you determine how and when to make the best use of Swift concurrency features – whether it’s making your code more asynchronous, moving it to the background, or sharing data across concurrent tasks."}],"type":"topic"},"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"WWDCNotes.png"},"WWDC25-Icon.png":{"type":"image","identifier":"WWDC25-Icon.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-Icon.png"}]},"https://developer.apple.com/videos/play/wwdc2025/266":{"type":"download","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/266","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/266"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10156-Explore-SwiftUI-animation":{"role":"sampleCode","title":"Explore SwiftUI animation","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10156-Explore-SwiftUI-animation","kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc23-10156-explore-swiftui-animation","abstract":[{"type":"text","text":"Explore SwiftUI’s powerful animation capabilities and find out how these features work together to produce impressive visual effects. Learn how SwiftUI refreshes the rendering of a view, determines what to animate, interpolates values over time, and propagates context for the current transaction."}]}}}