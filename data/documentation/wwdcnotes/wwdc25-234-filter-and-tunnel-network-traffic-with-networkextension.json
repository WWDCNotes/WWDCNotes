ntributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-714-Network-Extensions-for-the-Modern-Mac":{"url":"\/documentation\/wwdcnotes\/wwdc19-714-network-extensions-for-the-modern-mac","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-714-Network-Extensions-for-the-Modern-Mac","kind":"article","abstract":[{"type":"text","text":"Learn about powerful new APIs in macOS that you can use to create apps that extend and customize the networking capabilities of macOS without using kernel extensions."}],"role":"sampleCode","title":"Network Extensions for the Modern Mac"},"https://developer.apple.com/videos/play/wwdc2025/234":{"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/234","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/234","checksum":null},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-246-Integrate-privacy-into-your-development-process":{"url":"\/documentation\/wwdcnotes\/wwdc25-246-integrate-privacy-into-your-development-process","kind":"article","abstract":[{"type":"text","text":"Learn how to build privacy into your apps from the planning stages through deployment. We’ll cover practical ways to integrate privacy at each step of the development lifecycle, focusing on data minimization, on-device processing, and transparency and control. You’ll discover how to use Apple’s tools and frameworks to protect user data and create a privacy-respecting app experience."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-246-Integrate-privacy-into-your-development-process","type":"topic","role":"sampleCode","title":"Integrate privacy into your development proces