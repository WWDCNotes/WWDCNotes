{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10041-Explore-advances-in-declarative-device-management-"},"sections":[],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10039-Meet-device-management-for-Apple-Watch","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10040-Whats-new-in-managing-Apple-devices","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10263-Deploy-passkeys-at-work","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10046-Adopt-declarative-device-management","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10131-Meet-declarative-device-management"],"style":"list","type":"links"}],"kind":"content"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Watch Video (36 min)","isActive":true,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2023\/10041","type":"reference"}},"abstract":[{"type":"text","text":"Learn how you can help IT administrators get the tools they need to manage their organization’s devices. Discover the latest changes to declarative device management, including software update management, additional asset types, status reporting for FileVault, and more."}],"metadata":{"roleHeading":"WWDC23","modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"Explore advances in declarative device management"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23"]]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc23-10041-explore-advances-in-declarative-device-management-"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"url":"\/documentation\/wwdcnotes","title":"WWDC Notes","kind":"symbol","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","role":"collection","type":"topic","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"images":[{"identifier":"WWDCNotes.png","type":"icon"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10039-Meet-device-management-for-Apple-Watch":{"role":"sampleCode","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc23-10039-meet-device-management-for-apple-watch","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10039-Meet-device-management-for-Apple-Watch","kind":"article","abstract":[{"type":"text","text":"Organizations can now deploy and configure Apple Watch in addition to other Apple devices. Learn how to implement device management for watchOS to help organizations improve productivity, support wellness, and provide additional support for their employees."}],"title":"Meet device management for Apple Watch"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23":{"title":"WWDC23","url":"\/documentation\/wwdcnotes\/wwdc23","type":"topic","role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC23-Icon.png"},{"type":"card","identifier":"WWDC23.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23","abstract":[{"text":"Xcode 15, Swift 5.9, iOS 17, macOS 14 (Sonoma), tvOS 17, visionOS 1, watchOS 10.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"SwiftData","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Observation","type":"codeVoice"},{"text":", ","type":"text"},{"code":"StoreKit","type":"codeVoice"},{"text":" views, and more.","type":"text"}],"kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10040-Whats-new-in-managing-Apple-devices":{"type":"topic","title":"What’s new in managing Apple devices","url":"\/documentation\/wwdcnotes\/wwdc23-10040-whats-new-in-managing-apple-devices","kind":"article","role":"sampleCode","abstract":[{"text":"Learn about the latest management capabilities for iOS, iPadOS, and macOS. Discover how you can streamline the setup experience with enhancements to automated device enrollment and a new return-to-service option for iOS and iPadOS devices. We’ll share how to use your identity provider in even more places on macOS and show you how Apple Configurator can help automate tasks.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10040-Whats-new-in-managing-Apple-devices"},"WWDC23.jpeg":{"alt":null,"type":"image","identifier":"WWDC23.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC23.jpeg","traits":["1x","light"]}]},"https://developer.apple.com/videos/play/wwdc2023/10041":{"type":"download","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2023\/10041","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2023\/10041"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10263-Deploy-passkeys-at-work":{"type":"topic","role":"sampleCode","abstract":[{"text":"Discover how you can take advantage of passkeys in managed environments at work. We’ll explore how passkeys can work well in enterprise environments through Managed Apple ID support for iCloud Keychain. We’ll also share how administrators can manage passkeys for specific devices using Access Management controls in Apple Business Manager and Apple School Manager.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc23-10263-deploy-passkeys-at-work","title":"Deploy passkeys at work","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10263-Deploy-passkeys-at-work"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10131-Meet-declarative-device-management":{"role":"sampleCode","type":"topic","abstract":[{"text":"The future of device management is here: Learn how you can support mobile device management while allowing individual devices to be autonomous and proactive, bringing both increased performance and scalability. We’ll show you how you can incorporate this declarative model in your MDM solution.","type":"text"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc21-10131-meet-declarative-device-management","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10131-Meet-declarative-device-management","title":"Meet declarative device management"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10046-Adopt-declarative-device-management":{"url":"\/documentation\/wwdcnotes\/wwdc22-10046-adopt-declarative-device-management","kind":"article","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10046-Adopt-declarative-device-management","abstract":[{"type":"text","text":"Discover how you can simplify development of your device management solution with the declarative approach. We’ll take you through the latest updates to platform support and explore protocol enhancements for status and predicates."}],"type":"topic","title":"Adopt declarative device management"},"WWDC23-Icon.png":{"identifier":"WWDC23-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC23-Icon.png","traits":["1x","light"]}],"alt":null,"type":"image"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"WWDCNotes.png":{"alt":null,"type":"image","identifier":"WWDCNotes.png","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]}}}