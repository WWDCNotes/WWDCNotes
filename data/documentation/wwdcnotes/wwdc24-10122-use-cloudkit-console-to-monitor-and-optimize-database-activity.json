nsole-to-monitor-and-optimize-database-activity"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"https://developer.apple.com/videos/play/wwdc2024/10122":{"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2024\/10122","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2024\/10122","checksum":null},"WWDCNotes.png":{"type":"image","identifier":"WWDCNotes.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"WWDC24-Icon.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC24-Icon.png","traits":["1x","light"]}],"type":"image","identifier":"WWDC24-Icon.png","alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC24":{"title":"WWDC24","abstract":[{"type":"text","text":"Xcode 16, Swift 6, iOS 18, macOS 15 (Sequoia), tvOS 18, visionOS 2, watchOS 11."},{"type":"text","text":" "},{"type":"text","text":"New APIs: Swift Testing, "},{"type":"codeVoice","code":"FinanceKit"},{"type":"text","text":", "},{"type":"codeVoice","code":"TabletopKit"},{"type":"text","text":", and more."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC24","images":[{"type":"icon","identifier":"WWDC24-Icon.png"},{"type":"card","identifier":"WWDC24.jpeg"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc24","role":"collectionGroup"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10650-Sync-a-Core-Data-store-with-the-CloudKit-public-database":{"type":"topic","title":"Sync a Core Data store with the CloudKit public database","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc20-10650-sync-a-core-data-store-with-the-cloudkit-public-database","abstract":[{"type":"text","text":"Discover how Core Data can help you adopt the CloudKit public database in your app with as little as one line of code. Learn how to easily manage the flow of data through your app and in and out of CloudKit. We’ll show you how to combine the complementary power of Core Data and the CloudKit public database to allow people to access — and contribute to — data, such as high scores or application templates."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10650-Sync-a-Core-Data-store-with-the-CloudKit-public-database","role":"sampleCode"},"WWDC24.jpeg":{"type":"image","identifier":"WWDC24.jpeg","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC24.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10115-Whats-new-in-CloudKit-Console":{"kind":"article","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10115-Whats-new-in-CloudKit-Console","title":"What’s new in CloudKit Console","abstract":[{"text":"We’ll take you through the latest updates to CloudKit Console and discover how you can explore and debug your containers on the web like never before. Learn more about Act as iCloud, which helps you query records and view data from the perspective of another account. Discover how to share zones of records, and provide better collaboration between participants. And find out how to hide inactive containers. We’ll also share a few tips on getting the most out of CloudKit Console.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc22-10115-whats-new-in-cloudkit-console"}}}