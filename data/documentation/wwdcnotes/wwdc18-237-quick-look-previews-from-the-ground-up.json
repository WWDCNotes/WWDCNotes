{"abstract":[{"type":"text","text":"Quicklook Previews are an easy way preview documents in your app. Hear about the basics as well as some advanced implementations. Learn to present a variety of types of documents from within your app without reinventing the wheel, and make sure your custom file format works great with the built-in support offered by iOS."}],"metadata":{"title":"Quick Look Previews from the Ground Up","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC18","role":"sampleCode"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc18-237-quick-look-previews-from-the-ground-up"]}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"level":2,"type":"heading","text":"Related Sessions","anchor":"Related-Sessions"},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-719-Whats-New-in-File-Management-and-Quick-Look"],"style":"list"}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"]]},"sections":[],"sampleCodeDownload":{"action":{"type":"reference","isActive":true,"overridingTitle":"Read Transcript","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/237\/"},"kind":"sampleDownload"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-237-Quick-Look-Previews-from-the-Ground-Up"},"references":{"WWDC18-Icon.png":{"alt":null,"identifier":"WWDC18-I