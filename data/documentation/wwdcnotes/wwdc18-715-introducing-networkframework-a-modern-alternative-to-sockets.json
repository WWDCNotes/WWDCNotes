{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-715-Introducing-Networkframework-A-modern-alternative-to-Sockets","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"]]},"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/715","type":"reference","overridingTitle":"Watch Video (61 min)"}},"abstract":[{"text":"The new Network.framework API gives you direct access to the same high-performance user-space networking stack used by URLSession. If you’re considering using Berkeley Sockets in your app or library, learn what better options are available to you.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc18-715-introducing-networkframework-a-modern-alternative-to-sockets"]}],"metadata":{"role":"sampleCode","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC18","title":"Introducing Network.framework: A modern alternative to Sockets"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10239-Reduce-network-delays-for-your-app","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10111-Boost-performance-and-security-with-modern-networking","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-714-Optimizing-Your-App-for-Todays-Internet"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","references":{"WWDCNotes.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","type":"image","alt":null},"WWDC18.jpeg":{"identifier":"WWDC18.jpeg","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC18.jpeg"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10239-Reduce-network-delays-for-your-app":{"abstract":[{"type":"text","text":"CPU performance and network throughput rates keep improving, but the speed of light is one limit that isn’t going any higher. Learn the APIs and best practices to maximize your app’s responsiveness and efficiency by keeping network round-trip times low and minimizing the number of round trips when performing network operations."}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10239-Reduce-network-delays-for-your-app","url":"\/documentation\/wwdcnotes\/wwdc21-10239-reduce-network-delays-for-your-app","kind":"article","role":"sampleCode","title":"Reduce network delays for your app"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"https://developer.apple.com/videos/play/wwdc2018/715":{"checksum":null,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/715","type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/715"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10111-Boost-performance-and-security-with-modern-networking":{"kind":"article","abstract":[{"type":"text","text":"Speed up your app and make it more nimble, private and secure with modern networking APIs. Learn about networking protocols like IPv6, HTTP\/2, TLS 1.3 and Encrypted DNS, and how incorporating these within your app and server can provide faster performance and reduce both your power consumption and thermal impact. In addition, discover how adopting the latest security protocols can help you better protect privacy within your app."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10111-Boost-performance-and-security-with-modern-networking","title":"Boost performance and security with modern networking","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc20-10111-boost-performance-and-security-with-modern-networking","type":"topic"},"WWDC18-Icon.png":{"identifier":"WWDC18-Icon.png","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC18-Icon.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-714-Optimizing-Your-App-for-Todays-Internet":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-714-Optimizing-Your-App-for-Todays-Internet","url":"\/documentation\/wwdcnotes\/wwdc18-714-optimizing-your-app-for-todays-internet","title":"Optimizing Your App for Today’s Internet","abstract":[{"text":"Learn what Apple has been doing to help your app get the most out of the network with the least effort. Let Apple’s networking APIs do the heavy lifting for you. Learn best practices for getting top networking performance from your app using the URLSession APIs.","type":"text"}],"type":"topic","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"url":"\/documentation\/wwdcnotes\/wwdc18","abstract