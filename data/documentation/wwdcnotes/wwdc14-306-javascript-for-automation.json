{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC14"]]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc14-306-javascript-for-automation"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC14","title":"JavaScript for Automation","role":"sampleCode"},"sections":[],"sampleCodeDownload":{"action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2014\/306\/","isActive":true,"type":"reference","overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"primaryContentSections":[{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}]}],"kind":"content"}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC14-306-JavaScript-for-Automation"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Automation in OS X has always been about power and choice. Scriptable applications, including Pages, Keynote, Numbers, and the Finder, can already be automated using a variety of languages, including AppleScript, Objective-C, Perl, Python, and Ruby. With OS X Yosemite, application scripting support has been added to another popular language, JavaScript. JavaScript for Automation (JXA) extends the standard JavaScript environment provided by the JavaScriptCore framework with support for querying and controlling all of the scriptable applications running in OS X.  JXA scripts are supported at all layers of the system and can be invoked from the command-line, from the system-wide Script Menu, and can even be distributed as code-signed applications.","type":"text"}],"references":{"WWDC14.jpeg":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC14.jpeg"}],"alt":null,"identifier":"WWDC14.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"https://nonstrict.eu/wwdcindex/wwdc2014/306/":{"type":"download","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2014\/306\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2014\/306\/","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC14":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC14-Icon.png"},{"type":"card","identifier":"WWDC14.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC14","url":"\/documentation\/wwdcnotes\/wwdc14","abstract":[{"text":"Xcode 6, Swift 1.0, iOS 8, macOS 10.10 (Yosemite).","type":"text"}],"type":"topic","title":"WWDC14","kind":"article"},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"identifier":"WWDCNotes.png"},"WWDC14-Icon.png":{"alt":null,"type":"image","identifier":"WWDC14-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC14-Icon.png"}]}}}