{"sections":[],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc26-209-whats-new-in-wallet"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"What’s new in Wallet","modules":[{"name":"WWDC Notes"}],"role":"sampleCode","roleHeading":"WWDC26"},"sampleCodeDownload":{"action":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/209","overridingTitle":"Watch Video (15 min)","type":"reference","isActive":true},"kind":"sampleDownload"},"abstract":[{"type":"text","text":"Explore the newest design updates and developer tools for Apple Wallet passes. Refresh your passes with beautiful new styles for rich, vibrant designs. Discover new barcode formats and a flexible pass actions API. Meet Pass Designer and Pass Builder, powerful tools that simplify designing, personalizing, and distributing your passes at scale."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Summary","type":"heading","text":"Summary"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"New ","type":"text"},{"inlineContent":[{"text":"Poster Generic","type":"text"}],"type":"strong"},{"text":" style enhances pass design with bold, colorful artwork.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Four new barcode types expand flexibility; ensure backward compatibility.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Featured actions API enables custom actions across all pass stylaes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Pass Designer"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"text":"Pass Builder","type":"text"}],"type":"strong"},{"text":" streamline pass creation and distribution.","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Presenters","type":"heading","text":"Presenters"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Shaun Merchant, Wallet Engineer"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"New-Features-in-iOS-27-Wallet","type":"heading","text":"New Features in iOS 27 Wallet"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Poster Generic Style","type":"text"}],"type":"strong"},{"text":": Ideal for membership cards and loyalty programs. Includes background image, primary logo, and header fields. Requires iOS 27+.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-poster-generic.jpeg","type":"image"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"New Barcode Types"}]},{"text":": Supports EM13, Code 39, Codabar, and ITF. Prioritize multiple formats for compatibility with older iOS versions.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-qr-fallback.jpeg","type":"image"}]},{"syntax":"json","code":["\/\/ pass.json","{","  \/\/ Adopting Poster Generic","  \"posterGeneric\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Supporting Generic on iOS 26 and earlier","  \"generic\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Adopting new barcode types and supporting iOS 26 and earlier.","  \"barcodes\": [","    {","      \"format\": \"PKBarcodeFormatCodabar\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    },","    {","      \"format\": \"PKBarcodeFormatQR\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    }","  ],","  \/\/ Featured actions","  \"featuredActions\": [","    {","      \"identifier\": \"my-offer-id\",","      \"type\": \"membershipBenefits\",","      \"url\": \"www.example.com\/offers\"","    }","  ]","}"],"type":"codeListing"},{"level":2,"anchor":"Developer-Tools","type":"heading","text":"Developer Tools"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Pass Designer","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This WYSIWYG editor allows developers to create pass templates with a live preview, making design intuitive and straightforward.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Users can configure pass identity, style, images, barcodes, fields, and semantics directly within the tool."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Pass Builder"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Facilitates the personalization and distribution of passes at scale, supporting automated workflows."}]}]},{"content":[{"inlineContent":[{"text":"Can be integrated with other programming languages through Java bindings via the Swift Java project.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"numberOfColumns":2,"type":"row","columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"WWDC26-209-pass-builder-and-designer.jpeg","type":"image"}],"type":"paragraph"}]},{"size":1,"content":[{"inlineContent":[{"identifier":"WWDC26-209-pass-builder.jpeg","type":"image"}],"type":"paragraph"}]}]},{"syntax":"swift","code":["import PassBuilder","  ","func createPass(for doggo: MemeberModel) async throws -> URL {","  var passPackage = PassPackage(url: \"template.pkpasstemplate\")","  ","  passPackage.pass.fields.setValue(doggo.name, forKey: \"DOG_NAME\")","  passPackage.pass.fields.setValue(doggo.favoriteToy, forKey: \"LOVES\")","  passPackage.pass.fields.setValue(doggo.id, forKey: \"MEMBER_ID\")","  ","  passPackage.background = PassImage(url: doggo.photoURL)","  ","  passPackage.pass.barcodes = [","    Pass.Barcode(message: doggo.id, format: .pdf417)","  ]","","  passPackage.featuredActions = [","    Pass.Action(id: \"action-1\", type: \"viewMembership\", url: doggo.membershipURL) ","  ]","","  let passCertificate = try PassCertificate(url: \"pass.p12\", password: \"s3cr3t\")","  let wwdrCertificate = try PassCertificate(url: \"wwdr.cer\")","","  let signer = PassSigner(","    passCertificate: passCertificate,","    wwdrCertifiate: wwdrCertificate","  )","","  let destinationURL = URL(string: \"\/www\/passes\/\" + doggo.id)","  try signer.signPass(passPackage, writingTo: destinationURL)","","  return destinationURL","}"],"type":"codeListing"},{"level":2,"anchor":"Implementation-Tips","type":"heading","text":"Implementation Tips"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Include both new and existing style keys in your pass JSON to ensure older iOS versions can still render the pass.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Prepare for manual entry scenarios by making credential IDs easily accessible and training staff accordingly.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Featured-Actions","type":"heading","text":"Featured Actions"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Provide semantic URLs for additional user actions beneath the pass."}]}]},{"content":[{"inlineContent":[{"text":"Define actions in pass JSON with a unique ID, action type, and URL.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Limit to two meaningful actions per pass.","type":"text"}]}]}],"type":"unorderedList"},{"numberOfColumns":2,"type":"row","columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-209-featured-actions.jpeg"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-more-featured-actions.jpeg","type":"image"}]}]}]},{"level":2,"anchor":"Recommendations","type":"heading","text":"Recommendations"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Experiment with Poster Generic style using Pass Designer."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Plan for barcode format fallbacks."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identify and implement featured actions that are most relevant to users."}]}]}],"type":"unorderedList"}]}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-209-Whats-new-in-Wallet"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"references":{"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png","alt":null,"type":"image"},"WWDC26-209-featured-actions.jpeg":{"type":"image","alt":"Featured actions","variants":[{"url":"\/images\/WWDCNotes\/WWDC26-209-featured-actions.jpeg","traits":["1x","light"]}],"identifier":"WWDC26-209-featured-actions.jpeg"},"WWDC26-209-pass-builder-and-designer.jpeg":{"identifier":"WWDC26-209-pass-builder-and-designer.jpeg","alt":"New pass builder and pass designer","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC26-209-pass-builder-and-designer.jpeg"}],"type":"image"},"WWDC26.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC26.jpeg","traits":["1x","light"]}],"identifier":"WW