{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-209-Whats-new-in-Wallet"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"sections":[],"metadata":{"roleHeading":"WWDC26","title":"What’s new in Wallet","role":"sampleCode","modules":[{"name":"WWDC Notes"}]},"primaryContentSections":[{"content":[{"anchor":"Summary","text":"Summary","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New "},{"inlineContent":[{"type":"text","text":"Poster Generic"}],"type":"strong"},{"type":"text","text":" style enhances pass design with bold, colorful artwork."}]}]},{"content":[{"inlineContent":[{"text":"Four new barcode types expand flexibility; ensure backward compatibility.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Featured actions API enables custom actions across all pass stylaes.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Pass Designer","type":"text"}],"type":"strong"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"Pass Builder"}],"type":"strong"},{"type":"text","text":" streamline pass creation and distribution."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Presenters","text":"Presenters","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Shaun Merchant, Wallet Engineer"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"New-Features-in-iOS-27-Wallet","text":"New Features in iOS 27 Wallet","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Poster Generic Style","type":"text"}]},{"type":"text","text":": Ideal for membership cards and loyalty programs. Includes background image, primary logo, and header fields. Requires iOS 27+."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"WWDC26-209-poster-generic.jpeg","type":"image"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"New Barcode Types"}],"type":"strong"},{"text":": Supports EM13, Code 39, Codabar, and ITF. Prioritize multiple formats for compatibility with older iOS versions.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"WWDC26-209-qr-fallback.jpeg","type":"image"}],"type":"paragraph"},{"syntax":"json","code":["\/\/ pass.json","{","  \/\/ Adopting Poster Generic","  \"posterGeneric\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Supporting Generic on iOS 26 and earlier","  \"generic\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Adopting new barcode types and supporting iOS 26 and earlier.","  \"barcodes\": [","    {","      \"format\": \"PKBarcodeFormatCodabar\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    },","    {","      \"format\": \"PKBarcodeFormatQR\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    }","  ],","  \/\/ Featured actions","  \"featuredActions\": [","    {","      \"identifier\": \"my-offer-id\",","      \"type\": \"membershipBenefits\",","      \"url\": \"www.example.com\/offers\"","    }","  ]","}"],"type":"codeListing"},{"anchor":"Developer-Tools","text":"Developer Tools","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Pass Designer","type":"text"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This WYSIWYG editor allows developers to create pass templates with a live preview, making design intuitive and straightforward."}]}]},{"content":[{"inlineContent":[{"text":"Users can configure pass identity, style, images, barcodes, fields, and semantics directly within the tool.","type":"text"}],"type":"paragraph"}]}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Pass Builder"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Facilitates the personalization and distribution of passes at scale, supporting automated workflows.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Can be integrated with other programming languages through Java bindings via the Swift Java project."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"columns":[{"size":1,"content":[{"inlineContent":[{"type":"image","identifier":"WWDC26-209-pass-builder-and-designer.jpeg"}],"type":"paragraph"}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-pass-builder.jpeg","type":"image"}]}]}],"numberOfColumns":2,"type":"row"},{"syntax":"swift","code":["import PassBuilder","  ","func createPass(for doggo: MemeberModel) async throws -> URL {","  var passPackage = PassPackage(url: \"template.pkpasstemplate\")","  ","  passPackage.pass.fields.setValue(doggo.name, forKey: \"DOG_NAME\")","  passPackage.pass.fields.setValue(doggo.favoriteToy, forKey: \"LOVES\")","  passPackage.pass.fields.setValue(doggo.id, forKey: \"MEMBER_ID\")","  ","  passPackage.background = PassImage(url: doggo.photoURL)","  ","  passPackage.pass.barcodes = [","    Pass.Barcode(message: doggo.id, format: .pdf417)","  ]","","  passPackage.featuredActions = [","    Pass.Action(id: \"action-1\", type: \"viewMembership\", url: doggo.membershipURL) ","  ]","","  let passCertificate = try PassCertificate(url: \"pass.p12\", password: \"s3cr3t\")","  let wwdrCertificate = try PassCertificate(url: \"wwdr.cer\")","","  let signer = PassSigner(","    passCertificate: passCertificate,","    wwdrCertifiate: wwdrCertificate","  )","","  let destinationURL = URL(string: \"\/www\/passes\/\" + doggo.id)","  try signer.signPass(passPackage, writingTo: destinationURL)","","  return destinationURL","}"],"type":"codeListing"},{"anchor":"Implementation-Tips","text":"Implementation Tips","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Include both new and existing style keys in your pass JSON to ensure older iOS versions can still render the pass.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Prepare for manual entry scenarios by making credential IDs easily accessible and training staff accordingly."}]}]}],"type":"unorderedList"},{"anchor":"Featured-Actions","text":"Featured Actions","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Provide semantic URLs for additional user actions beneath the pass."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Define actions in pass JSON with a unique ID, action type, and URL.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Limit to two meaningful actions per pass."}]}]}],"type":"unorderedList"},{"columns":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-featured-actions.jpeg","type":"image"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-more-featured-actions.jpeg","type":"image"}]}],"size":1}],"numberOfColumns":2,"type":"row"},{"anchor":"Recommendations","text":"Recommendations","level":2,"type":"heading"},{"items":[{"con