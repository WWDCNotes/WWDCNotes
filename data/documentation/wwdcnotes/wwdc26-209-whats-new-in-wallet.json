{"sections":[],"sampleCodeDownload":{"action":{"overridingTitle":"Watch Video (15 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/209","type":"reference","isActive":true},"kind":"sampleDownload"},"abstract":[{"type":"text","text":"Explore the newest design updates and developer tools for Apple Wallet passes. Refresh your passes with beautiful new styles for rich, vibrant designs. Discover new barcode formats and a flexible pass actions API. Meet Pass Designer and Pass Builder, powerful tools that simplify designing, personalizing, and distributing your passes at scale."}],"metadata":{"roleHeading":"WWDC26","role":"sampleCode","title":"What’s new in Wallet","modules":[{"name":"WWDC Notes"}]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc26-209-whats-new-in-wallet"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-209-Whats-new-in-Wallet","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Summary","text":"Summary"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"New ","type":"text"},{"inlineContent":[{"text":"Poster Generic","type":"text"}],"type":"strong"},{"text":" style enhances pass design with bold, colorful artwork.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Four new barcode types expand flexibility; ensure backward compatibility."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Featured actions API enables custom actions across all pass stylaes.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Pass Designer"}],"type":"strong"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"Pass Builder"}],"type":"strong"},{"text":" streamline pass creation and distribution.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Presenters","text":"Presenters"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Shaun Merchant, Wallet Engineer","type":"text"}]}]}]},{"type":"heading","level":2,"anchor":"New-Features-in-iOS-27-Wallet","text":"New Features in iOS 27 Wallet"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Poster Generic Style","type":"text"}]},{"type":"text","text":": Ideal for membership cards and loyalty programs. Includes background image, primary logo, and header fields. Requires iOS 27+."}]}]}]},{"inlineContent":[{"type":"image","identifier":"WWDC26-209-poster-generic.jpeg"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"New Barcode Types"}]},{"type":"text","text":": Supports EM13, Code 39, Codabar, and ITF. Prioritize multiple formats for compatibility with older iOS versions."}]}]}]},{"inlineContent":[{"identifier":"WWDC26-209-qr-fallback.jpeg","type":"image"}],"type":"paragraph"},{"type":"codeListing","syntax":"json","code":["\/\/ pass.json","{","  \/\/ Adopting Poster Generic","  \"posterGeneric\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Supporting Generic on iOS 26 and earlier","  \"generic\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Adopting new barcode types and supporting iOS 26 and earlier.","  \"barcodes\": [","    {","      \"format\": \"PKBarcodeFormatCodabar\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    },","    {","      \"format\": \"PKBarcodeFormatQR\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    }","  ],","  \/\/ Featured actions","  \"featuredActions\": [","    {","      \"identifier\": \"my-offer-id\",","      \"type\": \"membershipBenefits\",","      \"url\": \"www.example.com\/offers\"","    }","  ]","}"]},{"type":"heading","level":2,"anchor":"Developer-Tools","text":"Developer Tools"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Pass Designer"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"This WYSIWYG editor allows developers to create pass templates with a live preview, making design intuitive and straightforward.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Users can configure pass identity, style, images, barcodes, fields, and semantics directly within the tool."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Pass Builder","type":"text"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Facilitates the personalization and distribution of passes at scale, supporting automated workflows."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Can be integrated with other programming languages through Java bindings via the Swift Java project.","type":"text"}]}]}],"type":"unorderedList"}]}]},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-pass-builder-and-designer.jpeg","type":"image"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-pass-builder.jpeg","type":"image"}]}],"size":1}]},{"type":"codeListing","syntax":"swift","code":["import PassBuilder","  ","func createPass(for doggo: MemeberModel) async throws -> URL {","  var passPackage = PassPackage(url: \"template.pkpasstemplate\")","  ","  passPackage.pass.fields.setValue(doggo.name, forKey: \"DOG_NAME\")","  passPackage.pass.fields.setValue(doggo.favoriteToy, forKey: \"LOVES\")","  passPackage.pass.fields.setValue(doggo.id, forKey: \"MEMBER_ID\")","  ","  passPackage.background = PassImage(url: doggo.photoURL)","  ","  passPackage.pass.barcodes = [","    Pass.Barcode(message: doggo.id, format: .pdf417)","  ]","","  passPackage.featuredActions = [","    Pass.Action(id: \"action-1\", type: \"viewMembership\", url: doggo.membershipURL) ","  ]","","  let passCertificate = try PassCertificate(url: \"pass.p12\", password: \"s3cr3t\")","  let wwdrCertificate = try PassCertificate(url: \"wwdr.cer\")","","  let signer = PassSigner(","    passCertificate: passCertificate,","    wwdrCertifiate: wwdrCertificate","  )","","  let destinationURL = URL(string: \"\/www\/passes\/\" + doggo.id)","  try signer.signPass(passPackage, writingTo: destinationURL)","","  return destinationURL","}"]},{"type":"heading","level":2,"anchor":"Implementation-Tips","text":"Implementation Tips"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Include both new and existing style keys in your pass JSON to ensure older iOS versions can still render the pass."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Prepare for manual entry scenarios by making credential IDs easily accessible and training staff accordingly.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Featured-Actions","text":"Featured Actions"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Provide semantic URLs for additional user actions beneath the pass.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Define actions in pass JSON with a unique ID, action type, and URL.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Limit to two meaningful actions per pass."}],"type":"paragraph"}]}]},{"type":"row","numberOfColumns":2,"columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"WWDC26-209-featured-actions.jpeg","type":"image"}],"type":"paragraph"}]},{"size":1,"content":[{"inlineContent":[{"identifier":"WWDC26-209-more-featured-actions.jpeg","type":"image"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"anchor":"Recommendations","text":"Recommendations"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Experiment with Poster Generic style using Pass Designer.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Plan for barcode format fallbacks.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Identify and implement featured actions that are most relevant to users.","type":"text"}],"type":"paragraph"}]}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"kind":"article","references":{"WWDC26-209-pass-builder-and-designer.jpeg":{"type":"image","alt":"New pass builder and pass designer","identifier":"WWDC26-209-pass-builder-and-designer.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC26-209-pass-builder-and-designer.jpeg"}]},"WWDC26-209-pass-builder.jpeg":{"identifier":"WWDC26-209-pass-builder.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC26-209-pass-builder.jpeg"}],"alt":"Pass builder app","type":"image"},"WWDC26-Icon.png":{"alt":null,"identifier":"WWDC26-Icon.png","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC26-Icon.png"}]},"WWDCNotes.png":{"type":"image","alt":null,"identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\