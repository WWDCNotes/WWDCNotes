{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Summary","anchor":"Summary","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"New ","type":"text"},{"inlineContent":[{"type":"text","text":"Poster Generic"}],"type":"strong"},{"text":" style enhances pass design with bold, colorful artwork.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Four new barcode types expand flexibility; ensure backward compatibility.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Featured actions API enables custom actions across all pass stylaes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Pass Designer"}],"type":"strong"},{"type":"text","text":" and "},{"inlineContent":[{"type":"text","text":"Pass Builder"}],"type":"strong"},{"type":"text","text":" streamline pass creation and distribution."}]}]}]},{"type":"heading","text":"Presenters","anchor":"Presenters","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Shaun Merchant, Wallet Engineer"}],"type":"paragraph"}]}]},{"type":"heading","text":"New Features in iOS 27 Wallet","anchor":"New-Features-in-iOS-27-Wallet","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Poster Generic Style"}],"type":"strong"},{"type":"text","text":": Ideal for membership cards and loyalty programs. Includes background image, primary logo, and header fields. Requires iOS 27+."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"image","identifier":"WWDC26-209-poster-generic.jpeg"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"New Barcode Types"}],"type":"strong"},{"type":"text","text":": Supports EM13, Code 39, Codabar, and ITF. Prioritize multiple formats for compatibility with older iOS versions."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"image","identifier":"WWDC26-209-qr-fallback.jpeg"}],"type":"paragraph"},{"type":"codeListing","syntax":"json","code":["\/\/ pass.json","{","  \/\/ Adopting Poster Generic","  \"posterGeneric\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Supporting Generic on iOS 26 and earlier","  \"generic\": {","    \"headerFields\": [","      {","        \"key\": \"memberID\",","        \"label\": \"Guest No.\",","        \"value\": \"102035\"","      }","    ],","    \"footerFields\": [","      {","        \"key\": \"membershipType\",","        \"value\": \"Family Pass\"","      }","    ]","  },","  \/\/ Adopting new barcode types and supporting iOS 26 and earlier.","  \"barcodes\": [","    {","      \"format\": \"PKBarcodeFormatCodabar\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    },","    {","      \"format\": \"PKBarcodeFormatQR\",","      \"message\": \"123456789\",","      \"messageEncoding\": \"iso-8859-1\"","    }","  ],","  \/\/ Featured actions","  \"featuredActions\": [","    {","      \"identifier\": \"my-offer-id\",","      \"type\": \"membershipBenefits\",","      \"url\": \"www.example.com\/offers\"","    }","  ]","}"]},{"type":"heading","text":"Developer Tools","anchor":"Developer-Tools","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Pass Designer"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This WYSIWYG editor allows developers to create pass templates with a live preview, making design intuitive and straightforward."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Users can configure pass identity, style, images, barcodes, fields, and semantics directly within the tool.","type":"text"}]}]}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Pass Builder"}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Facilitates the personalization and distribution of passes at scale, supporting automated workflows."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Can be integrated with other programming languages through Java bindings via the Swift Java project."}],"type":"paragraph"}]}],"type":"unorderedList"}]}]},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-209-pass-builder-and-designer.jpeg","type":"image"}]}],"size":1},{"content":[{"inlineContent":[{"identifier":"WWDC26-209-pass-builder.jpeg","type":"image"}],"type":"paragraph"}],"size":1}]},{"type":"codeListing","syntax":"swift","code":["import PassBuilder","  ","func createPass(for doggo: MemeberModel) async throws -> URL {","  var passPackage = PassPackage(url: \"template.pkpasstemplate\")","  ","  passPackage.pass.fields.setValue(doggo.name, forKey: \"DOG_NAME\")","  passPackage.pass.fields.setValue(doggo.favoriteToy, forKey: \"LOVES\")","  passPackage.pass.fields.setValue(doggo.id, forKey: \"MEMBER_ID\")","  ","  passPackage.background = PassImage(url: doggo.photoURL)","  ","  passPackage.pass.barcodes = [","    Pass.Barcode(message: doggo.id, format: .pdf417)","  ]","","  passPackage.featuredActions = [","    Pass.Action(id: \"action-1\", type: \"viewMembership\", url: doggo.membershipURL) ","  ]","","  let passCertificate = try PassCertificate(url: \"pass.p12\", password: \"s3cr3t\")","  let wwdrCertificate = try PassCertificate(url: \"wwdr.cer\")","","  let signer = PassSigner(","    passCertificate: passCertificate,","    wwdrCertifiate: wwdrCertificate","  )","","  let destinationURL = URL(string: \"\/www\/passes\/\" + doggo.id)","  try signer.signPass(passPackage, writingTo: destinationURL)","","  return destinationURL","}"]},{"type":"heading","text":"Implementation Tips","anchor":"Implementation-Tips","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Include both new and existing style keys in your pass JSON to ensure older iOS versions can still render the pass."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Prepare for manual entry scenarios by making credential IDs easily accessible and training staff accordingly.","type":"text"}]}]}]},{"type":"heading","text":"Featured Actions","anchor":"Featured-Actions","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Provide semantic URLs for additional user actions beneath the pass."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Define actions in pass JSON with a unique ID, action type, and URL."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Limit to two meaningful actions per pass."}]}]}]},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"inlineContent":[{"identifier":"WWDC26-209-featured-actions.jpeg","type":"image"}],"type":"paragraph"}],"size":1},{"content":[{"inlineContent":[{"identifier":"WWDC26-209-more-featured-actions.jpeg","type":"image"}],"type":"paragraph"}],"size":1}]},{"type":"heading","text":"Recommendations","anchor":"Recommendations","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Experiment with Poster Generic style using Pass Designer.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Plan for barcode format fallbacks."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identify and implement featured 