9-430-introducing-the-create-ml-app","role":"sampleCode","title":"Introducing the Create ML App","kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-430-Introducing-the-Create-ML-App"},"https://developers.google.com/machine-learning/crash-course/descending-into-ml/training-and-loss":{"title":"the lower the better","identifier":"https:\/\/developers.google.com\/machine-learning\/crash-course\/descending-into-ml\/training-and-loss","type":"link","titleInlineContent":[{"text":"the lower the better","type":"text"}],"url":"https:\/\/developers.google.com\/machine-learning\/crash-course\/descending-into-ml\/training-and-loss"},"WWDC19-424-accuracy":{"identifier":"WWDC19-424-accuracy","alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC19-424-accuracy.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-406-Create-ML-for-Object-Detection-and-Sound-Classification":{"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-406-Create-ML-for-Object-Detection-and-Sound-Classification","url":"\/documentation\/wwdcnotes\/wwdc19-406-create-ml-for-object-detection-and-sound-classification","abstract":[{"type":"text","text":"Create ML enables you to create, evaluate, and test powerful, production-class Core ML models. See how easy it is to create your own Object Detection and Sound Classification models for use in your apps. Learn strategies for balancing your training data to achieve great model accuracy."}],"title":"Create ML for Object Detection and Sound Classification","type":"topic","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/zntfdr":{"url":"\/documentation\/wwdcnotes\/zntfdr","type":"topic","kind":"article","role":"sampleCode","images":[{"identifier":"zntfdr.jpeg","type":"card"},{"identifier":"zntfdr.jpeg","type":"icon"}],"abstract":[{"type":"text","text":"No Bio on GitHub"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/zntfdr",