{"abstract":[{"text":"CloudKit.js is the new library that provides web access to your app data stored in iCloud. Explore the new web service APIs and learn how to extend your iOS or OS X apps to the web using CloudKit.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}]},{"level":2,"type":"heading","text":"Related Sessions","anchor":"Related-Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-226-Build-Better-Apps-with-CloudKit-Dashboard"],"type":"links","style":"list"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/710\/","overridingTitle":"Open on WWDCIndex","type":"reference"}},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc15-710-cloudkit-js-and-web-services"]}],"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-710-CloudKit-JS-and-Web-Services","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"metadata":{"title":"CloudKit JS and Web Services","role":"sampleCode","roleHeading":"WWDC15","modules":[{"name":"WWDC Notes"}]},"references":{"https://nonstrict.eu/wwdcindex/wwdc2015/710/":{"type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/710\/","identifier":"https:\/\/nonstric