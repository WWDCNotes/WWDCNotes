{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-509-Introducing-AirPlay-2"},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/509\/","isActive":true,"type":"reference"}},"abstract":[{"type":"text","text":"AirPlay allows you to wirelessly stream content from your iOS device or Mac. Now with AirPlay 2, you can fill the home with multi-room audio. Learn how AirPlay 2 synchronizes playback and provides an even more reliable audio experience, and how to incorporate support for AirPlay 2 into your app."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-509-introducing-airplay-2"]}],"metadata":{"roleHeading":"WWDC17","modules":[{"name":"WWDC Notes"}],"title":"Introducing AirPlay 2","role":"sampleCode"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"type":"heading","level":2,"anchor":"Related-Sessions","text":"Related Sessions"},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-501-Whats-New-in-Audio","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-502-Introducing-MusicKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-504-Advances-in-HTTP-Live-Streaming"],"style":"list"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","references":{"WWDCNotes.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"abstract":[{"text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"type":"codeVoice","code":"Core NFC"},{"text":" and more.","type":"text"}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17","kind":"article","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"role":"collectionGroup","title":"WWDC17"},"WWDC17-Icon.png":{"identifier":"WWDC17-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17-Icon.png","traits":["1x","light"]}],"type":"image"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-502-Introducing-MusicKit":{"title":"Introducing MusicKit","abstract":[{"type":"text","text":"Get introduced to the new API for the Apple Music subscription service.  Learn how to add Apple Music playback in your own app, and discover how to search the catalogue, manage playback queues, and engage with playlists and recommendations."}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-502-Introducing-MusicKit","url":"\/documentation\/wwdcnotes\/wwdc17-502-introducing-musickit","kind":"article","role":"sampleCode"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","title":"Learn More…"},"WWDC17.jpeg":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17.jpeg","traits":["1x","light"]}],"identifier":"WWDC17.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-501-Whats-New-in-Audio":{"url":"\/documentation\/wwdcnotes\/wwdc17-501-whats-new-in-audio","title":"What’s New in Audio","role":"sampleCode","abstract":[{"text":"Apple platforms provide a comprehensive set of audio frameworks that are essential to creating powerful audio solutions and rich app experiences. Come learn about enhancements to AVAudioEngine, support for high-order ambisonics, and new capabilities for background audio recording on watchOS. See how to take advantage of these new audio technologies and APIs in this session.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-501-Whats-New-in-Audio","type":"topic","kind":"article"},"https://nonstrict.eu/wwdcindex/wwdc2017/509/":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/509\/","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/509\/","type":"download"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-504-Advances-in-HTTP-Live-Streaming":{"url":"\/documentation\/wwdcnotes\/wwdc17-504-advances-in-http-live-streaming","title":"Advances in HTTP Live Streaming","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-504-Advances-in-HTTP-Live-Streaming","abstract":[{"type":"text","text":"HTTP Live Streaming allows you to stream live and on-demand content to global audiences. Learn about great new features and enhancements to HTTP Live Streaming. Highlights include support for HEVC, playlist metavariables, IMSC1 subtitles, and synchronized playback of multiple streams. Discover how to simplify your FairPlay key handling with the new AVContentKeySession API, and take advantage of enhancements to offline HLS playback."}],"type":"topic","kind":"article"}}}