{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Key-Takeaways","text":"Key Takeaways","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"🔄 Server model is a one-line swap on "},{"code":"LanguageModelSession","type":"codeVoice"},{"type":"text","text":" — tools and "},{"code":"@Generable","type":"codeVoice"},{"type":"text","text":" stay the same"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"🧠 PCC for reasoning and 32K context; on-device when you need offline with no daily cap"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"💰 Free PCC usage for apps under 2M downloads, no API keys","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"📋 Quota is per-user via iCloud — gate on ","type":"text"},{"code":"isAvailable","type":"codeVoice"},{"text":", surface ","type":"text"},{"code":"quotaUsage","type":"codeVoice"},{"text":" in UI","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Introduction","text":"Introduction","level":2,"type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Private Cloud Compute (PCC) exposes a server LLM through Foundation Models"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Apple’s Server Model and On-device model are accessed through the same APIs","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"PCC is for workloads that need more context, reasoning, or heavy tool loops"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"What-is-Private-Cloud-Compute","text":"What is Private Cloud Compute","level":2,"type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Server model; request data isn’t stored or retained after the response","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Wired into OS\/iCloud — no auth setup, no API keys, no per-tok