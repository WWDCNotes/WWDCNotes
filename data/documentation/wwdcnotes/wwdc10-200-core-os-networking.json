{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc10-200-core-os-networking"]}],"metadata":{"roleHeading":"WWDC10","modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"Core OS Networking"},"abstract":[{"type":"text","text":"iPhone OS and Mac OS X offer a rich set of networking APIs that provide advanced features while maintaining compatibility with open standards. You can use Apple’s networking APIs to develop software that perform a wide range of networking tasks, from providing access to web services within your application to writing a device driver for a network hardware device. Hear about new technologies, the latest developments in the networking frameworks and best practices."}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2010\/200\/","isActive":true,"type":"reference","overridingTitle":"Open on WWDCIndex"}},"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC10-200-Core-OS-Networking","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC10"]]},"references":{"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifi