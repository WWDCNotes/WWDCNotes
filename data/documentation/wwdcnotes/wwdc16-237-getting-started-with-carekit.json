{"sampleCodeDownload":{"action":{"type":"reference","isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/237\/","overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-237-getting-started-with-carekit"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-237-Getting-Started-with-CareKit"},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"metadata":{"title":"Getting Started with CareKit","role":"sampleCode","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC16"},"sections":[],"abstract":[{"text":"CareKit is a new open source framework designed to help you create personal care apps that can monitor, present and share personal health information. Learn how to create and extend Care Cards and an Insight Dashboard, and to package information for sharing with families or professional caregivers.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"anchor":"Related-Sessions","level":2,"type":"heading","text":"Related Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-209-Getting-the-Most-Out-of-HealthKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-234-Whats-New-in-ResearchKit"],"type":"links","style":"list"}],"kind":"content"}],"referenc