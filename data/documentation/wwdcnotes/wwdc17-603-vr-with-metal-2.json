{"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc17-603-vr-with-metal-2"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-603-VR-with-Metal-2"},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"metadata":{"modules":[{"name":"WWDC Notes"}],"title":"VR with Metal 2","roleHeading":"WWDC17","role":"sampleCode"},"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/603\/","type":"reference"}},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}]},{"type":"heading","level":2,"anchor":"Related-Sessions","text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-611-Metal-for-VR","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-601-Introducing-Metal-2"]}],"kind":"content"}],"kind":"article","abstract":[{"text":"Metal 2 provides powerful and specialized support for Virtual Reality (VR) rendering and external GPUs. Get details about adopting these emerging technologies within your Metal 2-based apps and games on macOS High Sierra. Walk through integrating Metal 2 with the SteamVR SDK and learn about efficiently rendering to a VR headset. Understand how external GPUs take macOS graphics to a whole new level and see how to prepare your apps to take advantage of their full potential.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-611-Metal-for-VR":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-611-Metal-for-VR","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-611-metal-for-vr","type":"topic","title":"Metal for VR","abstract":[{"type":"text","text":"On macOS, Metal 2 adds specialized support for virtual reality (VR) rendering and external GPUs. Learn about new features and optimizations to take advantage of these technologies within your Metal 2-based apps and games. Understand best practices for scheduling workloads across multiple GPUs and techniques for frame pacing while multi-threading."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-601-Introducing-Metal-2":{"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-601-Introducing-Metal-2","title":"Introducing Metal 2","url":"\/documentation\/wwdcnotes\/wwdc17-601-introducing-metal-2","abstract":[{"text":"Metal 2 provides near-direct access to the graphics processor (GPU), enabling your apps and games to realize their full graphics and compute potential. Dive into the breakthrough features of Metal 2 that empower the GPU to take control over key aspects of the rendering pipeline. Check out how Metal 2 enables essential tasks to be specified on-the-fly by the GPU, opening up new efficiencies for advanced rendering.","type":"text"}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"title":"WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17","images":[{"identifier":"WWDC17-Icon.png","type":"icon"},{"identifier":"WWDC17.jpeg","type":"card"}],"role":"collectionGroup","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","abstract":[{"text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"Core NFC","type":"codeVoice"},{"text":" and more.","type":"text"}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"titleInlineContent":[{"text":"Learn More…","type":"text"}],"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"WWDC17-Icon.png":{"type":"image","identifier":"WWDC17-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17-Icon.png","traits":["1x","light"]}]},"WWDC17.jpeg":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17.jpeg"}],"type":"image","alt":null,"identifier":"WWDC17.jpeg"},"WWDCNotes.png":{"alt":null,"type":"image","identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"https://nonstrict.eu/wwdcindex/wwdc2017/603/":{"checksum":null,"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/603\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/603\/"}}}