{"kind":"article","sections":[],"metadata":{"title":"What’s new in App Clips","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC21","role":"sampleCode"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Discover how App Clips can elevate quick and focused experiences for specific tasks, the moment your customer needs them. We’ll take you through some of the latest improvements to App Clips, including launching an experience directly from an app, testing your App Clip locally, and creating App Clip Codes to make it easy to access your experience in the real world. We’ll also share some great examples of App Clips from our developer community that provide innovative ways to interact with people and beautiful designs."}],"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"new in iOS 15: Businesses app clips will show up in Spotlight"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"App-Clip-card-in-Safari","text":"App Clip card in Safari","type":"heading"},{"inlineContent":[{"type":"image","identifier":"WWDC21-10012-appClipSafari"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"in iOS 14, we could use the ","type":"text"},{"code":"apple-itunes-app","type":"codeVoice"},{"text":" meta tag to display the smart app banner in Safari or Safari View Controller","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"new in iOS 15 we can configure the meta tag to show a full-sized App Clip Card"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"if the user chooses "},{"code":"View in Safari","type":"codeVoice"},{"type":"text","text":", Safari will remember the choice and not show the card next time the page is loaded again"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"add "},{"type":"codeVoice","code":"app-clip-display=card"},{"type":"text","text":" in your meta tag:"}]}]}],"type":"unorderedList"},{"syntax":"html","type":"codeListing","code":["<head>","<meta name=\"apple-itunes-app\"","      content=\"app-clip-bundle-id-com.example.fruta.Clip, app-id-123456789, app-clip-display=card\"> ","<\/head> "]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"works from another app’s Safari View Controller too"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Test-with-local-experiences","text":"Test with local experiences","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"you can test the whole app clip experience"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"you can launch it with most of regular App Clip invocation methods."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"to create one local experience, go to "},{"type":"codeVoice","code":"Developer Settings > Local Experiences"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Local experiences support QR, NFC, App Clip Code, Safari, and Messages","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"They don’t show up in Maps, location suggestions, and Spotlight search"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"you can only specify local experiences for Xcode-installed App Clips or App Clips in Beta testing","type":"text"}]}]}]}]}],"type":"unorderedList"},{"level":2,"anchor":"App-Clip-Code","text":"App Clip Code","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"Apple-designed visual code","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"available from iOS 14.3"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"an App Clip code always leads to an App Clip","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"each code encodes an unique URL","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"two types: NFC-integrated or Scan-only"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"can be used as an AR anchor"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"you can create a code via App Store Connect or via the ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/app-clips\/resources\/"},{"text":" cli tool","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"See all available templates at ","type":"text"},{"type":"codeVoice","code":"\/Library\/Developer\/AppClipCodeGenerator\/SampleTemplates"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"generator command example:"}]}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"syntax":"shell","type":"codeListing","code":["$ AppClipCodeGenerator generate --type nfc --url https:\/\/fruta.example --index 4 --output fruta.svg`"]},{"level":3,"anchor":"Best-practices","text":"Best practices","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"keep the code on a flat surface"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"the code should be placed at upright position (no sideways etc)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"make the code at least one-inch wide","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"ensure good visibility: the code shouldn’t be blocked, damaged, or placed too close to other codes","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Written-By","text":"Written By","type":"heading"},{"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"zntfdr"}]}]},{"size":4,"content":[{"level":3,"type":"heading","text":"zntfdr","anchor":"zntfdr"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/zntfdr","isActive":true,"overridingTitle":"Contributed Notes","overridingTitleInlineContent":[{"text":"Contributed Notes","type":"text"}],"type":"reference"},{"text":" ","type":"text"},{"text":"|","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/github.com\/zntfdr","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"|","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/","isActive":true,"type":"reference"}]}]}],"numberOfColumns":5,"type":"row"},{"type":"thematicBreak"},{"inlineContent":[{"type":"text","text":"Missing anything? Corrections? "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"level":2,"anchor":"Related-Sessions","text":"Related Sessions","type":"heading"},{"style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10097-Whats-new-in-App-Clips","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10013-Build-light-and-fast-App-Clips","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10073-Explore-ARKit-5","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10146-Configure-and-link-your-App-Clips","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10651-Whats-new-in-App-Store-Connect"],"type":"links"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Legal Notice","type":"text"}]}],"type":"small"},{"inlineContent":[{"text":"All content copyright © 2012 – 2025 Apple Inc. All rights reserved.","type":"text"},{"text":" ","type":"text"},{"text":"Swift, the Swift logo, Swift Playgrounds, Xcode, Instruments, Cocoa Touch, Touch ID, FaceID, iPhone, iPad, Safari, Apple Vision, Apple Watch, App Store, iPadOS, watchOS, visionOS, tvOS, Mac, and macOS are trademarks of Apple Inc., registered in the U.S. and other countries.","type":"text"},{"text":" ","type":"text"},{"text":"This website is not made by, affiliated with, nor endorsed by Apple.","type":"text"}],"type":"small"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21"]]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc21-10012-whats-new-in-app-clips"],"traits":[{"interfaceLanguage":"swift"}]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","identifier":"https:\/\/developer.apple.com\/wwdc21\/10012","isActive":true,"overridingTitle":"Watch Video (15 min)"}},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10012-Whats-new-in-App-Clips","interfaceLanguage":"swift"},"references":{"WWDC21-Icon.png":{"identifier":"WWDC21-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC21-Icon.png"}],"type":"image","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10013-Build-light-and-fast-App-Clips":{"url":"\/documentation\/wwdcnotes\/wwdc21-10013-build-light-and-fast-app-clips","abstract":[{"text":"App Clips give people the power to discover and download a small part of your app at a moment’s notice to complete tasks and transactions. Explore tips and best practices to help you create compact App Clips that emphasize modern features and elegant design. Learn how you can build reliable and secure App Clips to ensure that people can always access your experience when scanning a physical App Clip Code or viewing it through your website. And we’ll take you through specific strategies for testing an App Clip before releasing it to the world.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10013-Build-light-and-fast-App-Clips","type":"topic","title":"Build light and fast App Clips","kind":"article","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes":{"type":"topic","role":"collection","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes","images":[{"identifier":"WWDCNotes.png","type":"icon"}],"kind":"symbol","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10146-Configure-and-link-your-App-Clips":{"abstract":[{"type":"text","text":"App Clips are small parts of an app that offer a streamlined, direct experience and help people get what they need at the right time. Learn how you can invoke an App Clip through real-world experiences like App Clip Codes, NFC, and QR codes, or have them appear digitally through apps like Maps or Safari. We’ll show you how to handle links in your App Clip and demonstrate how to set up your associated domains. And discover how you can configure App Clip experiences in App Store Connect, add App Clip banners to your website, and thoroughly test your App Clips through TestFlight."}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10146-Configure-and-link-your-App-Clips","kind":"article","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc20-10146-configure-and-link-your-app-clips","title":"Configure and link your App Clips"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10651-Whats-new-in-App-Store-Connect":{"kind":"article","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10651-Whats-new-in-App-Store-Connect","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc20-10651-whats-new-in-app-store-connect","title":"What’s new in App Store Connect","abstract":[{"type":"text","text":"Discover the latest improvements to App Store Connect, your suite of tools to upload, submit, and manage apps on the App Store. Learn about enhancements to the App Store Connect API, in-app purchase and subscriptions, Game Center, and more."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21":{"url":"\/documentation\/wwdcnotes\/wwdc21","role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC21-Icon.png"},{"type":"card","identifier":"WWDC21.jpeg"}],"title":"WWDC21","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21","abstract":[{"text":"Xcode 13, Swift 5.5, iOS 15, macOS 12 (Monterey), tvOS 15, watchOS 8.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"MusicKit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"DocC","type":"codeVoice"},{"text":", ","type":"text"},{"code":"StoreKit 2","type":"codeVoice"},{"text":", and more.","type":"text"}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10097-Whats-new-in-App-Clips":{"abstract":[{"type":"text","text":"Explore the latest updates to App Clips! Discover how we’ve made your App Clip even easier to build with improvements to the size limit as well as CloudKit and keychain usage. We’ll also show you how to use our validation tool to verify your App Clip and automate workflows for your advanced App Clip experiences using App Store Connect."}],"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10097-Whats-new-in-App-Clips","url":"\/documentation\/wwdcnotes\/wwdc22-10097-whats-new-in-app-clips","type":"topic","kind":"article","title":"What’s new in App Clips"},"doc://WWDCNotes/documentation/WWDCNotes/zntfdr":{"kind":"article","url":"\/documentation\/wwdcnotes\/zntfdr","abstract":[{"text":"No Bio on GitHub","type":"text"}],"role":"sampleCode","type":"topic","images":[{"identifier":"zntfdr.jpeg","type":"card"},{"identifier":"zntfdr.jpeg","type":"icon"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/zntfdr","title":"zntfdr (332 notes)"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10073-Explore-ARKit-5":{"role":"sampleCode","abstract":[{"text":"Build the next generation of augmented reality apps with ARKit 5. Explore how you can use Location Anchors in additional regions and more easily onboard people into your location-based AR experience. Learn more about Face Tracking and Motion Capture. And discover best practices for placing your AR content in the real world. We’ll also show you how you can integrate App Clip Codes into your AR app for easy discovery and precise positioning of your virtual content.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc21-10073-explore-arkit-5","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10073-Explore-ARKit-5","type":"topic","kind":"article","title":"Explore ARKit 5"},"WWDC21.jpeg":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC21.jpeg"}],"identifier":"WWDC21.jpeg","alt":null},"WWDC21-10012-appClipSafari":{"alt":null,"type":"image","identifier":"WWDC21-10012-appClipSafari","variants":[{"url":"\/images\/WWDCNotes\/WWDC21-10012-appClipSafari.png","traits":["1x","light"]}]},"zntfdr.jpeg":{"identifier":"zntfdr.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/zntfdr.jpeg"}],"type":"image","alt":null},"WWDCNotes.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Contributions are welcome!","titleInlineContent":[{"text":"Contributions are welcome!","type":"text"}]},"https://":{"identifier":"https:\/\/","title":"Blog","url":"https:\/\/","type":"link","titleInlineContent":[{"text":"Blog","type":"text"}]},"https://developer.apple.com/app-clips/resources/":{"type":"link","identifier":"https:\/\/developer.apple.com\/app-clips\/resources\/","titleInlineContent":[{"type":"text","text":"App Clip Code Generator"}],"url":"https:\/\/developer.apple.com\/app-clips\/resources\/","title":"App Clip Code Generator"},"https://developer.apple.com/wwdc21/10012":{"type":"download","identifier":"https:\/\/developer.apple.com\/wwdc21\/10012","url":"https:\/\/developer.apple.com\/wwdc21\/10012","checksum":null},"https://github.com/zntfdr":{"identifier":"https:\/\/github.com\/zntfdr","title":"GitHub","url":"https:\/\/github.com\/zntfdr","type":"link","titleInlineContent":[{"type":"text","text":"GitHub"}]},"zntfdr":{"alt":"Profile image of zntfdr","type":"image","identifier":"zntfdr","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/zntfdr.jpeg"}]}}}