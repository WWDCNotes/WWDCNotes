dcnotes\/wwdc20","type":"topic","abstract":[{"type":"text","text":"Xcode 12, Swift 5.3, iOS 14, macOS 11 (Big Sur), tvOS 14, watchOS 7."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"WidgetKit"},{"type":"text","text":", "},{"type":"codeVoice","code":"StoreKit Testing"},{"type":"text","text":", and more."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20","kind":"article","images":[{"type":"icon","identifier":"WWDC20-Icon.png"},{"type":"card","identifier":"WWDC20.jpeg"}],"role":"collectionGroup","title":"WWDC20"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-104-Apple-Design-Awards":{"url":"\/documentation\/wwdcnotes\/wwdc19-104-apple-design-awards","title":"Apple Design Awards","role":"sampleCode","abstract":[{"text":"Join us for an unforgettable award ceremony celebrating developers and their outstanding work. The 2019 Apple Design Awards recognize state of the art iOS, macOS, watchOS, and tvOS apps that reflect excellence in design and innovation.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-104-Apple-Design-Awards","type":"topic","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-103-Apple-Design-Awards":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-103-apple-design-awards","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-103-Apple-Design-Awards","type":"topic","title":"Apple Design Awards","abstract":[{"type":"text","text":"Join us for an unforgettable award ceremony celebrating developers and their outstanding work. The 2018 Apple Design Awards recognize state of the art iOS, macOS, watchOS, and tvOS apps that reflect excellence in design and innovation."}],"role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10690-2020-Apple-Design-Awards":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc20-10690-2020-apple-design-awards","type":"topic","role":"sampleCode","abstract":[{"text":"The Apple De