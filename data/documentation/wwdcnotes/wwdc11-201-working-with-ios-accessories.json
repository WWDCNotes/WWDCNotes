{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11"]]},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc11-201-working-with-ios-accessories"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"iOS provides several services in which apps can interact with external accessories and devices. Starting with iOS 4.3, you can stream content from your app using AirPlay. In this session we will review the AirPlay feature set and describe how apps and websites can work with AirPlay devices. We will also review the latest hardware guidelines for developers of Bluetooth accessories and cover new features for Bluetooth, the External Accessory framework, and accessibility devices.","type":"text"}],"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11-201-Working-with-iOS-Accessories","interfaceLanguage":"swift"},"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","isActive":true,"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/201\/"}},"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC11","role":"sampleCode","title":"Working with iOS Accessories"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}],"type":"paragraph"}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC11":{"role":"collectionGroup","images":[{"type":"icon","identifier":