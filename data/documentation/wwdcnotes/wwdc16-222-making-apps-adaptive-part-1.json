{"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"metadata":{"roleHeading":"WWDC16","role":"sampleCode","title":"Making Apps Adaptive, Part 1","modules":[{"name":"WWDC Notes"}]},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-222-Making-Apps-Adaptive-Part-1","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"anchor":"Related-Sessions","text":"Related Sessions","type":"heading","level":2},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10105-Build-for-iPad","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-233-Making-Apps-Adaptive-Part-2","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-236-Whats-New-in-Auto-Layout","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts"],"style":"list"}],"kind":"content"}],"abstract":[{"text":"In this first part of a two part series, explore the motivation and concepts necessary to take advantage of trait collections. Walk through building an interface in Xcode and learn from the experts how to take advantage of new features to more easily create your app for different device sizes and configurations.","type":"text"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/222\/","isActive":true}},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc16-222-making-apps-adaptive-part-1"]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-236-Whats-New-in-Auto-Layout":{"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-236-whats-new-in-auto-layout","abstract":[{"text":"Get details about new features of Auto Layout in Xcode, Cocoa and Cocoa Touch. Explore the new NSGridView, allowing your Cocoa app to easily build grid interfaces. Dive deeper into new tools that enable you to quickly diagnose layout issues in your interface. Learn about the new features in Xcode to quickly build adaptive interfaces.","type":"text"}],"title":"What’s New in Auto Layout","kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-236-Whats-New-in-Auto-Layout"},"https://nonstrict.eu/wwdcindex/wwdc2016/222/":{"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/222\/","checksum":null,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/222\/","type":"download"},"WWDC16.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC16.jpeg","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"WWDC16.jpeg"},"WWDCNotes.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","type":"image"},"WWDC16-Icon.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC16-Icon.png","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"WWDC16-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"titleInlineContent":[{"text":"Learn More…","type":"text"}],"title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc16","title":"WWDC16","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-803-Typography-and-Fonts":{"title":"Typography and Fonts","url":"\/documentation\/wwdcnotes\/wwdc16-803-typography-and-fonts","role":"sampleCode","abstract":[{"text":"Typography is essential to an app’s form and function. Learn principles of good typography and techniques to apply them to your work. Make the most of the advanced features in our system fonts, and learn best practices for using custom fonts.","type":"text"}],"kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-233-Making-Apps-Adaptive-Part-2":{"abstract":[{"text":"In this second part of a two part series, go beyond the basics in understanding how to make your apps adaptive. Learn through practical examples how to extend your application interfaces using UIKit. Get introduced to best practices for structuring your app for flexible interface designs. Learn from the experts what to keep in mind as you build apps for the future, today.","type":"text"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-233-making-apps-adaptive-part-2","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-233-Making-Apps-Adaptive-Part-2","kind":"article","title":"Making Apps Adaptive, Part 2"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10105-Build-for-iPad":{"abstract":[{"type":"text","text":"Learn how to improve iPad apps to leverage the increased screen size and additional features of iPadOS, and help people accomplish more with their devices. Discover how you can build detailed multi-column layouts and integrate lists into your app with little adjustment to your existing code. We’ll also explore reducing modality within your views to make it easier to navigate your interface with fewer taps and touches."}],"url":"\/documentation\/wwdcnotes\/wwdc20-10105-build-for-ipad","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10105-Build-for-iPad","title":"Build for iPad","kind":"article","role":"sampleCode"}}}