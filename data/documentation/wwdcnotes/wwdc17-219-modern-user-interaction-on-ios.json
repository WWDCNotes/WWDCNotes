{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-219-Modern-User-Interaction-on-iOS","interfaceLanguage":"swift"},"sections":[],"sampleCodeDownload":{"action":{"type":"reference","isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/219\/","overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"abstract":[{"text":"Touch user interactions are fundamental to the user experience on iOS. Learn how to master the power of UIKit’s gesture recognizer system in your application. Find out how to integrate with the new Drag and Drop features and the system gestures. Get some great tips for debugging your custom built interactions.","type":"text"}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc17-219-modern-user-interaction-on-ios"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"WWDC17","title":"Modern User Interaction on iOS","modules":[{"name":"WWDC Notes"}],"role":"sampleCode"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"text":"Related Sessions","level":2,"type":"heading","anchor":"Related-Sessions"},{"style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-221-Introducing-PencilKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-804-Designing-Across-Platforms"],"type":"links"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","references":{"WWDCNotes.png":{"alt":null,"type":"image","identifier":"WWDCNotes.png","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-221-Introducing-PencilKit":{"type":"topic","title":"Introducing PencilKit","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-221-Introducing-PencilKit","abstract":[{"type":"text","text":"Meet PencilKit, Apple’s feature-rich drawing and annotation framework. With just a few lines of code, you can add a full drawing experience to your app — with access to a canvas, responsive inks, rich tool palette and drawing model. Hear the technical details that make a great Apple Pencil experience. Learn about the new screenshot editor and how you can adopt just a few small APIs to enable your full content to be captured beyond the size of the screen, with or without your app’s user interface."}],"kind":"article","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc19-221-introducing-pencilkit"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"abstract":[{"text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"type":"codeVoice","code":"Core NFC"},{"text":" and more.","type":"text"