able(anyAppleOS 27, *)","   @available(tvOS, unavailable)","   func launch() { ... }","","   #if os(anyAppleOS)","   func makeLiveActivityWidget() -> some Widget { ... }","   #endif","}"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Deprecated APIs:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"@diagnose"},{"type":"text","text":" attribute can manage warnings for deprecated APIs."}],"type":"paragraph"},{"syntax":"swift","code":[" @diagnose(DeprecatedDeclaration, as: ignored, reason: \"Flying with surplus hardware\")"," func makeApolloSoyuzMission() -> Mission {","    CrewedMission(","       rocket: makeSaturnIRocket(),","       payload: makeApolloCSM(),","       crew: [.daniellePoole, .nathanMorrison]","    )"," }",""," @diagnose(StrictMemorySafety, as: warning)"," func uplinkCommand(from receiver: inout Receiver, to computer: inout Computer) {","    let commandSize = receiver.receiveInt()","    receiver.withReceivedData(byteCount: commandSize) {","       computer.receiveUplinkedCommand($0)","    }"," }",""," @diagnose(ErrorInFutureSwiftVersion, as: error)"," func fetchPosition() -> (x: Double, y: Double, z: Double) {","    return self.rotation"," }"],"type":"codeListing"}]}]},{"anchor":"Library-Updates","type":"heading","text":"Library Updates","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Standard Library:","type":"text"}],"type":"strong"},{"type":"text","text":" New tools for task cancellation, dictionary transformations, and file paths."}],"type":"paragraph"},{"code":[" \/\/ Radio for help",""," extension Radio {","    func send(_ data: [UInt8]) {","       if Task.isCancelled { return }","       \/\/ ...","    }"," }",""," extension EmergencyTransponder {","    func sendSOS() {","       withTaskCancellationShield {","          radio.send(makeSOSPacket())","       }","    }"," }"],"type":"codeListing","syntax":"swift"},{"code":[" \/\/ FilePath handling