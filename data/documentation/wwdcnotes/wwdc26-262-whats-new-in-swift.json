":["extension Mission {","   @available(anyAppleOS 27, *)","   func showStatus() { ... }","","   @available(anyAppleOS 27, *)","   @available(tvOS, unavailable)","   func launch() { ... }","","   #if os(anyAppleOS)","   func makeLiveActivityWidget() -> some Widget { ... }","   #endif","}"],"syntax":"swift"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Deprecated APIs:"}],"type":"strong"},{"text":" ","type":"text"},{"code":"@diagnose","type":"codeVoice"},{"text":" attribute can manage warnings for deprecated APIs.","type":"text"}],"type":"paragraph"},{"code":[" @diagnose(DeprecatedDeclaration, as: ignored, reason: \"Flying with surplus hardware\")"," func makeApolloSoyuzMission() -> Mission {","    CrewedMission(","       rocket: makeSaturnIRocket(),","       payload: makeApolloCSM(),","       crew: [.daniellePoole, .nathanMorrison]","    )"," }",""," @diagnose(StrictMemorySafety, as: warning)"," func uplinkCommand(from receiver: inout Receiver, to computer: inout Computer) {","    let commandSize = receiver.receiveInt()","    receiver.withReceivedData(byteCount: commandSize) {","       computer.receiveUplinkedCommand($0)","    }"," }",""," @diagnose(ErrorInFutureSwiftVersion, as: error)"," func fetchPosition() -> (x: Double, y: Double, z: Double) {","    return self.rotation"," }"],"type":"codeListing","syntax":"swift"}]}]},{"type":"heading","text":"Library Updates","anchor":"Library-Updates","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Standard Library:","type":"text"}],"type":"strong"},{"text":" New tools for task cancellation, dictionary transformations, and file paths.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[" \/\/ Radio for help",""," extension Radio {","    func send(_ data: [UInt8]) {","       if Task.isCancelled { return }","       \/\/ ...","    }"," }",""," extension EmergencyTransponder {","    func sendSOS() {","       withTaskC