{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"primaryContentSections":[{"content":[{"anchor":"Summary","type":"heading","level":2,"text":"Summary"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Swift 6.3 and 6.4 bring significant language and library improvements, enhancing developer efficiency and code safety.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New tools for task cancellation, file path manipulation, and API deprecation handling improve code management."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Performance tuning features in Swift simplify optimizing code without sacrificing safety."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Enhanced interoperability and new SDKs expand Swift’s usability across platforms like Android and web apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Swift’s ownership system and new APIs make high-performance programming safer and more accessible.","type":"text"}]}]}]},{"anchor":"Presenters","type":"heading","level":2,"text":"Presenters"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Becca, Swift Team","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Evan, Swift Team","type":"text"}]}]}]},{"anchor":"Language-Improvements","type":"heading","level":2,"text":"Language Improvements"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Optional Handling:"}]},{"type":"text","text":" Swift 6.4 removes the need for parentheses with "},{"type":"codeVoice","code":"some"},{"type":"text","text":" or "},{"type":"codeVoice","code":"any"},{"type":"text","text":" and optional types."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Error Handling:","type":"text"}]},{"type":"text","text":" Warnings for unhandled errors in concurrency tasks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Async Functions:","type":"text"}]},{"text":" Now callable from a ","type":"text"},{"code":"defer","type":"codeVoice"},{"text":" block.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Sendable Checking:","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"weak let"},{"type":"text","text":" supports immutability, and "},{"type":"codeVoice","code":"~Sendable"},{"type":"text","text":" syntax for non-sendable types (doesn’t stop subclasses from being "},{"type":"codeVoice","code":"Sendable"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Initializer Enhancements:","type":"text"}],"type":"strong"},{"text":" Structs with mixed visibility properties get a second member-wise initializer.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[" struct Briefing {","    internal var topic: String","    internal var scheduledAt: Date","    private  var attendees: [Person] = []"," }",""," \/\/ Generated memberwise initializers:"," \/\/ extension Briefing {"," \/\/     private init(topic: String, scheduledAt: Date, attendees: [Person] = []) { "," \/\/          self.topic = topic"," \/\/          self.scheduledAt = scheduledAt"," \/\/          self.attendees = attendees"," \/\/     }"," \/\/ "," \/\/     internal init(topic: String, scheduledAt: Date) {"," \/\/          self.topic = topic"," \/\/          self.scheduledAt = scheduledAt"," \/\/          self.attendees = []"," \/\/     }"," \/\/ }"]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cross-Platform Availability:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"anyAppleOS"},{"type":"text","text":" condenses platform names for OS availability attributes (only supported for OSes 26 and newer)."}]},{"type":"codeListing","syntax":"swift","code":["extension Mission {","   @available(anyAppleOS 27, *)","   func showStatus() { ... }","","   @available(anyAppleOS 27, *)","   @available(tvOS, unavailable)","   func launch() { ... }","","   #if os(anyAppleOS)","   func makeLiveActivityWidget() -> some Widget { ... }","   #endif","}"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Deprecated APIs:"}]},{"type":"text","text":" "},{"code":"@diagnose","type":"codeVoice"},{"type":"text","text":" attribute can manage warnings for deprecated APIs."}],"type":"paragraph"},{"code":[" @diagnose(DeprecatedDeclaration, as: ignored, reason: \"Flying with surplus hardware\")"," func makeApolloSoyuzMission() -> Mission {","    CrewedMission(","       rocket: makeSaturnIRocket(),","       payload: makeApolloCSM(),","       crew: [.daniellePoole, .nathanMorrison]","    )"," }",""," @diagnose(StrictMemorySafety, as: warning)"," func uplinkCommand(from receiver: inout Receiver, to computer: inout Computer) {","    let commandSize = receiver.receiveInt()","    receiver.withReceivedData(byteCount: commandSize) {","       computer.receiveUplinkedCommand($0)","    }"," }",""," @diagnose(ErrorInFutureSwiftVersion, as: error)"," func fetchPosition() -> (x: Double, y: Double, z: Double) {","    return self.rotation"," }"],"syntax":"swift","type":"codeListing"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Module Selectors:"}],"type":"strong"},{"type":"text","text":" New "},{"code":"::","type":"codeVoice"},{"type":"text","text":" syntax disambiguates which module a declaration comes from."}],"type":"paragraph"},{"code":[" import Rocket"," import GiftShopToys",""," let rocket1 = SaturnV()            \/\/ could mean `Rocket::SaturnV` or `GiftShopToys::SaturnV`"," let rocket2 = Rocket.SaturnV()     \/\/ prefers `Rocket::Rocket.SaturnV`"," let rocket3 = Rocket::SaturnV()    \/\/ correctly finds `Rocket::SaturnV`"],"syntax":"swift","type":"codeListing"}]}]},{"anchor":"Library-Updates","type":"heading","level":2,"text":"Library Updates"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Standard Library:"}]},{"type":"text","text":" New tools for task cancellation, dictionary transformations, and file paths."}]},{"type":"codeListing","code":[" \/\/ Radio for help",""," extension Radio {","    func send(_ data: [UInt8]) {","       if Task.isCancelled { return }","       \/\/ ...","    }"," }",""," extension EmergencyTransponder {","    func sendSOS() {","       withTaskCancellationShield {","          radio.send(makeSOSPacket())","       }","    }"," }"],"syntax":"swift"},{"type":"codeListing","code":[" \/\/ Map values with keys",""," func makeCalendarDisplayNames(for missions: [Mission: LaunchWindow]) -> [Mission: String] {","    missions.mapKeyedValues { mission, launchWindow in","       makeDisplayName(for: mission, in: launchWindow)","    }"," }"],"syntax":"swift"},{"type":"codeListing","code":[" \/\/ FilePath handling macOS-named resources",""," var path: FilePath = \"\/var\/www\/static\""," path.components.append(\"WWDC\")"," print(path.components)"," \/\/ [ \"var\", \"www\", \"static\", \"WWDC\" ]",""," var path: FilePath = \"\/var\/www\/static\/..namedresource\/rsrc\""," print(path.components)"," \/\/ [ \"var\", \"www\", \"static\" ]"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swift Testing:"}],"type":"strong"},{"text":" Enhanced control over test behavior, including non-fatal issues, dynamic test cancellation, and new ","type":"text"},{"type":"codeVoice","code":"swift test"},{"text":" options ","type":"text"},{"type":"codeVoice","code":"--maximum-repetitions"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"--repeat-unit"},{"text":".","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Issue severity","","@Test(arguments: allRockets)","func testBurn(rocket: Rocket) throws {","   rocket.burn(for: .seconds(150))","   let remaining = rocket.propellantKg \/ rocket.totalPropellantKg","","   if remaining < 0.10 {","      Issue.record(","            \"\\(rocket.name) remaining fuel is below 10% reserve target\",","            severity: .warning","      )","   }","","   #expect(remaining > 0.02, \"\\(rocket.name) propellant critically low - abort\")","}"]},{"syntax":"swift","type":"codeListing","code":["\/\/ Test Cancellation","","@Test(arguments: allRockets)","func testBurn(rocket: Rocket) throws {","   \/\/ solid-fuel rocket engines can't be stopped","   if rocket.engineType == .solid {","      try Test.cancel(\"\\(rocket.name) has solid fuel\")","   }","","   rocket.burn(for: .seconds(150))","   let remaining = rocket.propellantKg \/ rocket.totalPropellantKg","","   if remaining < 0.10 {","      Issue.record(","            \"\\(rocket.name) remaining fuel is below 10% reserve target\",","            severity: .warning","      )","   }","","   #expect(remaining > 0.02, \"\\(rocket.name) propellant critically low - abort\")","}"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Subprocess Package:"}]},{"type":"text","text":" Refined APIs with improved error handling and cross-platform support."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Subprocess output streaming","","let result = try await Subprocess.run(.name(\"ls\"),","                                      input: .none,","                                      output: .sequence,","                                      error: .string(limit:4096)) { execution in","      execution.standardOtput.strings().filter { $0.hasSuffix(\".obj\") }","}","","for try await objectFiles in result.closureOutput {","   print(\"Object file: \\(objectFile)\")","}"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Foundation Enhancements:","type":"text"}]},{"type":"text","text":" Progress manager for async\/await, faster data operations, and unification of URL types."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[" \/\/ Progress reporting",""," let manager = ProgressManager(totalCount: 100)"," try await rocket.launch(mission.subprogress(assigningCount: 100))",""," extension Rocket {","    func launch(_ progress: consuming Subprogress? = nil) async throws {","       let stage = progress?.start(totalCount: 3)","       try await ignite(); stage?.complete(count: 1)","       try await liftoff(); stage?.complete(count: 1)","       try await stageSeparation(); stage?.complete(count: 1)","    }"," }"]}]}]},{"anchor":"Performance-Tuning","type":"heading","level":2,"text":"Performance Tuning"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Optimizer Control:"}]},{"text":" New ","type":"text"},{"type":"codeVoice","code":"inline(always)"},{"text":" attribute and ","type":"text"},{"type":"codeVoice","code":"@specialized"},{"text":" for fine-tuning optimization.","type":"text"}]},{"syntax":"swift","code":["@inline(never) \/\/ or @inline(always)","func makeInts(randomized: Bool) -> [256 of Int] {","   if randomized {","      InlineArray { _ in Int.random(in: (.min)...(.max)) }","   } else {","      InlineArray(repeating: 0)","   }","}"],"type":"codeListing"},{"syntax":"swift","code":["@specialized(where Values == [UInt8])","func histogram<Values>(of values: Values) -> [256 of Int] where Values: Sequence<UInt8> {","   var result = makeInts(randomized: false)","","   for value in values {","      result[Int(value)] += 1","   }","","   return result","}"],"type":"codeListing"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Ownership System:"}],"type":"strong"},{"text":" Enhancements allow non-copyable types and improved handling of ","type":"text"},{"code":"Equatable","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Comparable","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Iterables:","type":"text"}]},{"type":"text","text":" New "},{"code":"Iterable","type":"codeVoice"},{"type":"text","text":" protocol for more efficient loops."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Accessors:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"code":"borrow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"mutate","type":"codeVoice"},{"type":"text","text":" accessors replace "},{"code":"get","type":"codeVoice"},{"type":"text","text":" and "},{"code":"set","type":"codeVoice"},{"type":"text","text":" for performance gains."}],"type":"paragraph"},{"syntax":"swift","code":[" @safe public struct UniqueBox<Value: ~Copyable>: ~Copyable {","    private let valuePointer: UnsafeMutablePointer<Value>","","    public init(_ value: consuming Value) {","       valuePointer = UnsafeMutablePointer.allocate(capacity: 1)","       valuePointer.initialize(to: value)","    }","","    public var value: Value {","       borrow { valuePointer.pointee }","       mutate { &valuePointer.pointee }","    }","","    deinit {","       valuePointer.deinitialize(count: 1)","       valuePointer.deallocate()","    }"," }"],"type":"codeListing"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"New Safe APIs:"}],"type":"strong"},{"type":"text","text":" "},{"type":"codeVoice","code":"UniqueBox"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UniqueArray"},{"type":"text","text":" for managing pointers and non-copyable elements; "},{"type":"codeVoice","code":"Ref"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"MutableRef"},{"type":"text","text":" — like a "},{"type":"codeVoice","code":"Span"},{"type":"text","text":" but for one value; storable, passable, returnable, usable in generics."}]}]}]},{"anchor":"Cross-Platform-and-Interoperability","type":"heading","level":2,"text":"Cross-Platform and Interoperability"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Exposing Swift to C:"}]},{"text":" New ","type":"text"},{"code":"@c","type":"codeVoice"},{"text":" attribute for exposing Swift functions to C.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Java Interop:"}]},{"type":"text","text":" Async and throwing Swift functions are now callable from Java."}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Android SDK:","type":"text"}],"type":"strong"},{"type":"text","text":" Official Swift SDK for Android released."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Swift Extension for VS Code:"}],"type":"strong"},{"type":"text","text":" Tools for easy toolchain management and WebAssembly support."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"JavaScript Interop:","type":"text"}]},{"type":"text","text":" Safer and faster bridging with JavaScript kit improvements."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Embedded Swift:","type":"text"}]},{"type":"text","text":" Now supports existential types and untyped throws."}]}]}]},{"anchor":"The-Future-of-Swift","type":"heading","level":2,"text":"The Future of Swift"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Swift Build is now the default build-system backend for Swift Package Manager, for consistency between SwiftPM and Xcode builds.","type":"text"}],"type":"paragrap