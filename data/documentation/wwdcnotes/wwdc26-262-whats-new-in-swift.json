{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"title":"What’s new in Swift","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC26","role":"sampleCode"},"abstract":[{"type":"text","text":"Join us for an update on Swift. Discover the latest language advancements, including updates for everyday ergonomics, improved concurrency, and safer high-performance code. Explore workflow and language interoperability improvements and updates in embedded Swift."}],"primaryContentSections":[{"content":[{"type":"heading","text":"Summary","anchor":"Summary","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift 6.3 and 6.4 bring significant language and library improvements, enhancing developer efficiency and code safety."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"New tools for task cancellation, file path manipulation, and API deprecation handling improve code management.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Performance tuning features in Swift simplify optimizing code without sacrificing safety.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enhanced interoperability and new SDKs expand Swift’s usability across platforms like Android and web apps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Swift’s ownership system and new APIs make high-performance programming safer and more accessible.","type":"text"}]}]}]},{"type":"heading","text":"Language Improvements","anchor":"Language-Improvements","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Optional Handling:","type":"text"}]},{"type":"text","text":" Swift 6.4 removes the need for parentheses with "},{"type":"codeVoice","code":"some"},{"type":"text","text":" or "},{"type":"codeVoice","code":"any"},{"type":"text","text":" and optional types."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Error Handling:"}]},{"type":"text","text":" Warnings for unhandled errors in concurrency tasks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Async Functions:"}]},{"type":"text","text":" Now callable from a "},{"type":"codeVoice","code":"defer"},{"type":"text","text":" block."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Sendable Checking:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"weak let"},{"type":"text","text":" supports immutability, and "},{"type":"codeVoice","code":"~Sendable"},{"type":"text","text":" syntax for non-sendable types."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Initializer Enhancements:","type":"text"}]},{"type":"text","text":" Structs with mixed visibility properties get a second member-wise initializer."}]},{"syntax":"swift","type":"codeListing","code":[" struct Briefing {","    internal var topic: String","    internal var scheduledAt: Date","    private  var attendees: [Person] = []"," }",""," \/\/ Generated memberwise initializers:"," \/\/ extension Briefing {"," \/\/     private init(topic: String, scheduledAt: Date, attendees: [Person] = []) { "," \/\/          self.topic = topic"," \/\/          self.scheduledAt = scheduledAt"," \/\/          self.attendees = attendees"," \/\/     }"," \/\/ "," \/\/     internal init(topic: String, scheduledAt: Date) {"," \/\/          self.topic = topic"," \/\/          self.scheduledAt = scheduledAt"," \/\/          self.attendees = []"," \/\/     }"," \/\/ }"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cross-Platform Availability:"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"anyAppleOS"},{"type":"text","text":" condenses platform names for OS availability attributes."}],"type":"paragraph"},{"code":["extension Mission {","   @available(anyAppleOS 27, *)","   func showStatus() { ... }","","   @available(anyAppleOS 27, *)","   @available(tvOS, unavailable)","   func launch() { ... }","","   #if os(anyAppleOS)","   func makeLiveActivityWidget() -> some Widget { ... }","   #endif","}"],"type":"codeListing","syntax":"swift"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Deprecated APIs:"}]},{"text":" ","type":"text"},{"code":"@diagnose","type":"codeVoice"},{"text":" attribute can manage warnings for deprecated APIs.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":[" @diagnose(DeprecatedDeclaration, as: ignored, reason: \"Flying with surplus hardware\")"," func makeApolloSoyuzMission() -> Mission {","    CrewedMission(","       rocket: makeSaturnIRocket(),","       payload: makeApolloCSM(),","       crew: [.daniellePoole, .nathanMorrison]","    )"," }",""," @diagnose(StrictMemorySafety, as: warning)"," func uplinkCommand(from receiver: inout Receiver, to computer: inout Computer) {","    let commandSize = receiver.receiveInt()","    receiver.withReceivedData(byteCount: commandSize) {","       computer.receiveUplinkedCommand($0)","    }"," }",""," @diagnose(ErrorInFutureSwiftVersion, as: error)"," func fetchPosition() -> (x: Double, y: Double, z: Double) {","    return self.rotation"," }"],"type":"codeListing"}]}]},{"type":"heading","text":"Library Updates","anchor":"Library-Updates","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Standard Library:","type":"text"}],"type":"strong"},{"text":" New tools for task cancellation, dictionary transformations, and file paths.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[" \/\/ Radio for help",""," extension Radio {","    func send(_ data: [UInt8]) {","       if Task.isCancelled { return }","       \/\/ ...","    }"," }",""," extension EmergencyTransponder {","    func sendSOS() {","       withTaskCancellationShield {","          radio.send(makeSOSPacket())","       }","    }"," }"]},{"type":"codeListing","syntax":"swift","code":[" \/\/ FilePath handling macOS-named resources",""," var path: FilePath = \"\/var\/www\/static\""," path.components.append(\"WWDC\")"," print(path.components)"," \/\/ [ \"var\", \"www\", \"static\", \"WWDC\" ]",""," var path: FilePath = \"\/var\/www\/static\/..namedresource\/rsrc\""," print(path.components)"," \/\/ [ \"var\", \"www\", \"static\" ]"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Swift Testing:"}]},{"type":"text","text":" Enhanced control over test behavior, including non-fatal issues and dynamic test cancellation."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ Issue severity","","@Test(arguments: allRockets)","func testBurn(rocket: Rocket) throws {","   rocket.burn(for: .seconds(150))","   let remaining = rocket.propellantKg \/ rocket.totalPropellantKg","","   if remaining < 0.10 {","      Issue.record(","            \"\\(rocket.name) remaining fuel is below 10% reserve target\",","            severity: .warning","      )","   }","","   #expect(remaining > 0.02, \"\\(rocket.name) propellant critically low - abort\")","}"]},{"type":"codeListing","syntax":"swift","code":["\/\/ Test Cancellation","","@Test(arguments: allRockets)","func testBurn(rocket: Rocket) throws {","   \/\/ solid-fuel rocket engines can't be stopped","   if rocket.engineType == .solid {","      try Test.cancel(\"\\(rocket.name) has solid fuel\")","   }","","   rocket.burn(for: .seconds(150))","   let remaining = rocket.propellantKg \/ rocket.totalPropellantKg","","   if remaining < 0.10 {","      Issue.record(","            \"\\(rocket.name) remaining fuel is below 10% reserve target\",","            severity: .warning","      )","   }","","   #expect(remaining > 0.02, \"\\(rocket.name) propellant critically low - abort\")","}"]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Subprocess Package:"}]},{"type":"text","text":" Refined APIs with improved error handling and cross-platform support."}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Subprocess output streaming","","let result = try await Subprocess.run(.name(\"ls\"),","                                      input: .none,","                                      output: .sequence,","                                      error: .string(limit:4096)) { execution in","      execution.standardOtput.strings().filter { $0.hasSuffix(\".obj\") }","}","","for try await objectFiles in result.closureOutput {","   print(\"Object file: \\(objectFile)\")","}"],"type":"codeListing"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Foundation Enhancements:"}]},{"text":" Progress manager for async\/await, faster data operations, and unification of URL types.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[" \/\/ Progress reporting",""," let manager = ProgressManager(totalCount: 100)"," try await rocket.launch(mission.subprogress(assigningCount: 100))",""," extension Rocket {","    func launch(_ progress: consuming Subprogress? = nil) async throws {","       let stage = progress?.start(totalCount: 3)","       try await ignite(); stage?.complete(count: 1)","       try await liftoff(); stage?.complete(count: 1)","       try await stageSeparation(); stage?.complete(count: 1)","    }"," }"]}]}]},{"type":"heading","text":"Performance Tuning","anchor":"Performance-Tuning","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Optimizer Control:"}]},{"type":"text","text":" New "},{"code":"inline(always)","type":"codeVoice"},{"type":"text","text":" attribute and "},{"code":"@specialized","type":"codeVoice"},{"type":"text","text":" for fine-tuning optimization."}]},{"type":"codeListing","code":["@inline(never) \/\/ or @inline(always)","func makeInts(randomized: Bool) -> [256 of Int] {","   if randomized {","      InlineArray { _ in Int.random(in: (.min)...(.max)) }","   } else {","      InlineArray(repeating: 0)","   }","}"],"syntax":"swift"},{"type":"codeListing","code":["@specialized(where Values == [UInt8])","func histogram<Values>(of values: Values) -> [256 of Int] where Values: Sequence<UInt8> {","   var result = makeInts(randomized: false)","","   for value in values {","      result[Int(value)] += 1","   }","","   return result","}"],"syntax":"swift"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Ownership System:"}]},{"type":"text","text":" Enhancements allow non-copyable types and improved handling of "},{"type":"codeVoice","code":"Equatable"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Comparable"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Iterables:","type":"text"}]},{"type":"text","text":" New "},{"type":"codeVoice","code":"Iterable"},{"type":"text","text":" protocol for more efficient loops."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Accessors:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"code":"borrow","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"mutate","type":"codeVoice"},{"text":" accessors replace ","type":"text"},{"code":"get","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"set","type":"codeVoice"},{"text":" for performance gains.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[" @safe public struct UniqueBox<Value: ~Copyable>: ~Copyable {","    private let valuePointer: UnsafeMutablePointer<Value>","","    public init(_ value: consuming Value) {","       valuePointer = UnsafeMutablePointer.allocate(capacity: 1)","       valuePointer.initialize(to: value)","    }","","    public var value: Value {","       borrow { valuePointer.pointee }","       mutate { &valuePointer.pointee }","    }","","    deinit {","       valuePointer.deinitialize(count: 1)","       valuePointer.deallocate()","    }"," }"]}]}]},{"type":"heading","text":"Cross-Platform and Interoperability","anchor":"Cross-Platform-and-Interoperability","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Android SDK:","type":"text"}]},{"text":" Official Swift SDK for Android released.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Swift Extension for VS Code:"}]},{"type":"text","text":" Tools for easy toolchain management and WebAssembly support."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"JavaScript Interop:","type":"text"}]},{"type":"text","text":" Safer and faster bridging with JavaScript kit improvements."}],"type":"paragraph"}]}]},{"type":"heading","text":"Future Developments","anchor":"Future-Developments","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Open Source Contributions:"}]},{"type":"text","text":" Encouragement to join Swift forums and participate in community-driven enhancements."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Swift’s Expanding Role:"}]},{"type":"text","text":" Swift used across Apple software layers, from apps to firmware, demonstrating its versatility and power."}]}]}]}],"kind":"content"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/262","type":"reference","isActive":true,"overridingTitle":"Watch Video (32