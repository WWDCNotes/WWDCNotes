{"abstract":[{"type":"text","text":"Learn new ways to customize media playback using AV Foundation in both OS X and iOS. Explore how to synchronize video media with audio synthesis, achieve realtime audio processing from audiovisual media, and integrate AV Foundation’s hardware accelerated media decode and display with your own custom media transport. Learn how to perform realtime video effects processing and how to use video media to texture 3D OpenGL environments."}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc12-517-realtime-media-effects-and-processing-during-playback"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12-517-RealTime-Media-Effects-and-Processing-during-Playback"},"metadata":{"roleHeading":"WWDC12","role":"sampleCode","title":"Real-Time Media Effects and Processing during Playback","modules":[{"name":"WWDC Notes"}]},"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2012\/517\/","isActive":true,"overridingTitle":"Read Transcript"}},"sections":[],"references":{"WWDC12-Icon.png":{"type":"image","alt":null,"identifier":"WWDC12-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC