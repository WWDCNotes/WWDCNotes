{"abstract":[{"text":"Explore the latest updates to SF Symbols, Apple’s library of iconography. Meet Draw, a new animation system that allows symbols to imitate the organic flow of a handwritten stroke, and Variable Draw, which can be used to convey strength or progress. Discover Gradients, which add dimension and visual interest to symbols, and Magic Replace enhancements, which offer greater continuity between related symbols. And learn how to preview and integrate these features into your own apps.","type":"text"}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc25-337-whats-new-in-sf-symbols-7"]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"]]},"primaryContentSections":[{"content":[{"text":"Key Takeaways","level":2,"type":"heading","anchor":"Key-Takeaways"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"✍️ New draw animation along defined path, inspired by handwriting","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"🪄 Magic replace recognizes more shapes"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"🌈 Apply gradients to any Symbol","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"🎞️ Use SF Symbol app to add draw animation for custom Symbols"}],"type":"paragraph"}]}]},{"text":"Introduction","level":2,"type":"heading","anchor":"Introduction"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Paths"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Symbols are created using outlined vector shapes, not just paths with outlines."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Shapes may be constructed from two different paths, oriented in opposite direction."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"All new symbols and animations can be previewed and customized in updated "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/sf-symbols\/"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"text":"Draw Animation","level":2,"type":"heading","anchor":"Draw-Animation"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-337-Draw","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Animation along defined path, inspired by handwriting."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Two different presets:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Draw On: shows symbol"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Draw Off: hides symbol"}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Draw off animation can be reversed."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default animation is "},{"inlineContent":[{"type":"text","text":"by layer"}],"type":"emphasis"},{"type":"text","text":"."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Also supports ","type":"text"},{"inlineContent":[{"type":"text","text":"whole symbol"}],"type":"emphasis"},{"text":" or ","type":"text"},{"inlineContent":[{"type":"text","text":"individually"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Animation direction is customizable."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Complex shapes like arrow heads traveling with path possible."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Variable draw allows symbols to animate progress, like progress bar or temperature.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At render time you need to choose between variable color or variable draw."}]}]}]}]}]},{"text":"Magic Replace Animation","level":2,"type":"heading","anchor":"Magic-Replace-Animation"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-337-Magic-Replace","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Now recognizes matching enclosures aka shapes like circles.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Can be combined with draw animation."}],"type":"paragraph"}]}]},{"text":"Gradients","level":2,"type":"heading","anchor":"Gradients"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Gradient"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Generates gradient from single source color."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Both for system and custom colors.","type":"text"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Gets applied across all rendering modes."}]}]}]},{"text":"Draw for Custom Symbols","level":2,"type":"heading","anchor":"Draw-for-Custom-Symbols"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Draw-Annotation"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Draw animation relies on set of at least 2 guide points."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Start point: hollow dot","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"End point: filled dot"}]}]}],"type":"unorderedList"}]}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"All annotation is done in the ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/sf-symbols\/","isActive":true,"overridingTitle":"SF Symbols app","overridingTitleInlineContent":[{"text":"SF Symbols app","type":"text"}]},{"text":".","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Symbols-App"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Show Draw toolbar via selecting “Draw On” or “Draw Off” in animation tab (in gallery view).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enter guide point mode via leftmost button in Draw toolbar."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Click on Symbols paths to define guide points."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Use context menu to change point type."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add additional guide points for complex shapes like turning points."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Drag guide points to edit and flip animation direction."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Two-path shapes (e.g. circle) automatically get combined start and end point."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Animate clockwise by default.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Use context menu to change direction to counterclockwise."}],"type":"paragraph"}]}]}]}]},{"text":"Multiple Paths & Bidirectionally","level":3,"type":"heading","anchor":"Multiple-Paths--Bidirectionally"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Each path has same set of rules (at least 2 guides).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select each layer and annotate it separately."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"For ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"bidirectional animation"}]},{"text":" place start point between two end points.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"System will recognize it automatically."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Only available for single path shapes.","type":"text"}],"type":"paragraph"}]}]}]},{"content":[{"inlineContent":[{"text":"Enable snapping (2nd button in Draw toolbar) to ensure start points aligning across multiple layers.","type":"text"}],"type":"paragraph"}]}]},{"text":"End Caps","level":3,"type":"heading","anchor":"End-Caps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Rounded end cap by default.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use context menu on guide points to change end cap to “adaptive”."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Only available in single draw direction."}]}]}]}]}]},{"text":"Non-Drawing Components","level":3,"type":"heading","anchor":"Non-Drawing-Components"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Non-Drawing-Components"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Drag and drop non-drawing shape (like arrow head) on guide to attach it."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Indicates where shape will appear from."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"To remove drag and drop it on canvas.","type":"text"}]}]}]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":""},{"type":"text","text":" "},{"type":"text","text":"Non-drawing components need to be separate path."}],"type":"paragraph"}]},{"text":"Sharp Corner Points","level":3,"type":"heading","anchor":"Sharp-Corner-Points"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-337-Point-Types","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"For sharp corners use “Corner Point” to assign both points on same path."}],"type":"paragraph"}]}]},{"text":"Advanced Options","level":3,"type":"heading","anchor":"Advanced-Options"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-337-Point-Customization","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Hold option key (⌥) to change location of guide point of one side of path.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Select subpath in layer list to limit guide points to that path."}],"type":"paragraph"}]}]},{"text":"Support All Weights","level":3,"type":"heading","anchor":"Support-All-Weights"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"System interpolates guide points across weights."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Annotate regular weight first!"}]}]}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-337-Point-Numbers"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When fixing specific weights make sure the guide points are in correct order."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use 3rd button in Toolbar to toggle numbers on\/off.","type":"text"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Drag broken guide points to correct placement in given weight."}]}]}]},{"text":"Variable Rendering","level":3,"type":"heading","anchor":"Variable-Rendering"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Enable variable draw via button in layer list."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Review each layer and preview the animation."}],"type":"paragraph"}]}]},{"text":"New APIs","level":2,"type":"heading","anchor":"New-APIs"},{"text":"Draw Animations","level":3,"type":"heading","anchor":"Draw-Animations"},{"tabs":[{"content":[{"code":["struct DrawExamples: View {","    @State var isHidden: Bool = false","","    var body: some View {","        HStack {","            Image(systemName: \"wind\")","                .symbolEffect(.drawOn, isActive: isHidden)","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"title":"SwiftUI"},{"content":[{"type":"codeListing","code":["imageView.addSymbolEffect(.drawOff)","","\/\/ Sometime later, draw on the symbol","imageView.addSymbolEffect(.drawOn)"],"syntax":"swift"}],"title":"UIKit & AppKit"}],"type":"tabNavigator"},{"text":"Variable Draw","level":3,"type":"heading","anchor":"Variable-Draw"},{"tabs":[{"title":"SwiftUI","content":[{"type":"codeListing","code":["struct VariableDrawExample: View {","    var body: some View {","        VStack {","            Image(systemName: \"thermometer.high\", variableValue: 0.5)","        }","        .symbolVariableValueMode(.draw)","    }","}"],"syntax":"swift"}]},{"title":"UIKit","content":[{"syntax":"swift","code":["imageView.image = UIImage(systemName: \"thermometer.high\", variableValue: 0.5)","imageView.preferredSymbolConfiguration = UIImage.SymbolConfiguration(variableValueMode: .draw)"],"type":"codeListing"}]},{"title":"AppKit","content":[{"type":"codeListing","syntax":"swift","code":["imageView.image = NSImage(systemSymbolName: \"thermometer.high\", variableValue: 0.5, ...)","imageVie