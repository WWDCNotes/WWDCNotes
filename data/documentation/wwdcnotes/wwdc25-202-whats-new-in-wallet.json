ce"},{"type":"text","text":", "},{"code":"venueLocation","type":"codeVoice"},{"type":"text","text":" semantics)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Event guide shows rich details, weather, venue map (can reuse pass venue map with "},{"type":"codeVoice","code":"reuseExisting"},{"type":"text","text":")."}]}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"type":"tabNavigator","tabs":[{"title":"Main semantic fields","content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-202-event-semantic-fields.jpeg","type":"image"}]}]},{"title":"Seats","content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC25-202-event-seats.jpeg"}]}]},{"title":"Venue details","content":[{"inlineContent":[{"type":"image","identifier":"WWDC25-202-event-venue-details.jpeg"}],"type":"paragraph"}]}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Updates & Maintenance"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"code":"isActive","type":"codeVoice"},{"text":" property to mark event relevance.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Events can be added or removed via pass updates to keep info current."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Encouraged to tailor semantics & URLs per event distinct from the main pass."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"syntax":"json","code":["\/\/ pass.json","{","  \"upcomingPassInformation\": [","    {","      \"type\": \"event\",","      \"identifier\": \"classic-jazz\",","      \"name\": \"Classic Jazz\",","      \"dateInformation\": {","        \"date\": \"2025-06-1718:30:00-08:00\",","        \"timeZone\": \"America\/Los_Angeles\"","      },","      \/\/ Properties describing the event","      \"semanti