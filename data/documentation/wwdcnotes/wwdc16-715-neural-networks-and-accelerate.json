{"sections":[],"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-715-Neural-Networks-and-Accelerate","interfaceLanguage":"swift"},"metadata":{"roleHeading":"WWDC16","modules":[{"name":"WWDC Notes"}],"title":"Neural Networks and Accelerate","role":"sampleCode"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Related Sessions","anchor":"Related-Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-701-Using-Accelerate-and-simd","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-240-Increase-Usage-of-Your-App-With-Proactive-Suggestions","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-605-Whats-New-in-Metal-Part-2","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-606-Advanced-Metal-Shader-Optimization"]}],"kind":"content"}],"abstract":[{"type":"text","text":"The Accelerate framework gives you fast, energy efficient signal and image processing and linear algebra libraries. Learn about new libraries dedicated to high performance neural networks and numerical integration."}],"sampleCodeDownload":{"action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/715\/","overridingTitle":"Open on WWDCIndex","isActive":true,"type":"reference"},"kind":"sampleDownload"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc16-715-neural-networks-and-accelerate"]}],"references":{"WWDC16.jpeg":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"identifier":"WWDC16.jpeg"},"https://nonstrict.eu/wwdcindex/wwdc2016/715/":{"checksum":null,"type":"download","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/715\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/715\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-606-Advanced-Metal-Shader-Optimization":{"url":"\/documentation\/wwdcnotes\/wwdc16-606-advanced-metal-shader-optimization","role":"sampleCode","abstract":[{"text":"The Metal shading language is an easy-to-use programming language for writing graphics and compute functions which execute on the GPU. Dive deeper into understanding the design patterns, memory access models, and detailed shader coding best practices which reduce bottlenecks and hide latency. Intended for experienced shader authors with a solid understanding of GPU architecture and hoping to extract every possible cycle.","type":"text"}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-606-Advanced-Metal-Shader-Optimization","title":"Advanced Metal Shader Optimization","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-605-Whats-New-in-Metal-Part-2":{"abstract":[{"text":"Discover enhancements to the Metal shading language and how to use function specialization to improve performance while reducing the number of shader configurations in your app. Take advantage of resource read-writes to enable amazing new rendering techniques, understand how to support wide color, and accelerate your deep learning algorithms using the Metal Performance Shaders framework.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc16-605-whats-new-in-metal-part-2","role":"sampleCode","type":"topic","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-605-Whats-New-in-Metal-Part-2","title":"What’s New in Metal, Part 2"},"WWDC16-Icon.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}],"identifier":"WWDC16-Icon.png","type":"image"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-701-Using-Accelerate-and-simd":{"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-701-using-accelerate-and-simd","abstract":[{"type":"text","text":"Learn how to use sophisticated Signal and Image Processing techniques to bring higher performance to your apps while lowering battery consumption.  See compelling use cases for the Accelerate framework with interactive demos. Explore using simd—a valuable addition that effortlessly brings vector programming to your apps."}],"title":"Using Accelerate and simd","type":"topic","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-701-Using-Accelerate-and-simd"},"WWDCNotes.png":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc16","title":"WWDC16","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-240-Increase-Usage-of-Your-App-With-Proactive-Suggestions":{"type":"topic","abstract":[{"type":"text","text":"iOS and macOS can proactively promote your app and data, thereby increasing user engagement. See how adopting a few simple APIs to inform the OS about your app’s capabilities can lead to your app being suggested in various places like the app switcher, on the lock screen, Contacts, and more."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-240-Increase-Usage-of-Your-App-With-Proactive-Suggestions","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-240-increase-usage-of-your-app-with-proactive-suggestions","title":"Increase Usage of Your App With Proactive Suggestions","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"}}}