{"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-201-ios-accessibility"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"WWDC15","role":"sampleCode","title":"iOS Accessibility","modules":[{"name":"WWDC Notes"}]},"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"level":2,"anchor":"Related-Sessions","type":"heading","text":"Related Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-238-Accessibility-in-SwiftUI"]}],"kind":"content"}],"abstract":[{"type":"text","text":"iOS has transformed the lives of many users with a range of physical and learning disabilities. Learn how to create apps that leverage the power and simplicity of Apple’s assistive technologies to make them accessible to the broadest audience possible. Hear about the latest advancements in iOS accessibility and how you can take advantage of them today."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"sampleCodeDownload":{"action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/201\/","type":"reference","overridingTitle":"Open on WWDCIndex","isActive":true},"kind":"sampleDownload"},"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-201-iOS-Accessibility","interfaceLanguage":"swift"},"references":{"https://nonstrict.eu/wwdcindex/wwdc2015/201/":{"checksum":null,"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/201\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/201\/"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","type":"topic","role":"collection","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"WWDC15-Icon.png":{"identifier":"WWDC15-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC15-Icon.png"}],"type":"image","alt":null},"WWDC15.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC15.jpeg"}],"type":"image","identifier":"WWDC15.jpeg"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"title":"WWDC15","url":"\/documentation\/wwdcnotes\/wwdc15","type":"topic","role":"collectionGroup","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}],"kind":"article","images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-238-Accessibility-in-SwiftUI":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-238-Accessibility-in-SwiftUI","url":"\/documentation\/wwdcnotes\/wwdc19-238-accessibility-in-swiftui","title":"Accessibility in SwiftUI","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"Making your app accessible is critical, but just as important is designing a fantastic accessibility experience. Learn what makes a great experience and how to make your app understandable, navigable, and interactable. SwiftUI builds accessibility into your app for you! Discover how much you get with no extra adoption, like accessible images and controls. Identify where you can add supplemental accessibility information with the new SwiftUI Accessibility API, which gives you the tools to add information to elements such as labels, values, and hints."}]},"WWDCNotes.png":{"identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"type":"image","alt":null}}}