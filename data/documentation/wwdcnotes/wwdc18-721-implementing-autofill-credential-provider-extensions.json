{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-721-Implementing-AutoFill-Credential-Provider-Extensions","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"]]},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}],"type":"paragraph"},{"level":2,"anchor":"Related-Sessions","text":"Related Sessions","type":"heading"},{"style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-234-Whats-New-in-Safari-and-WebKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-206-Introducing-Password-AutoFill-for-Apps"],"type":"links"}]}],"metadata":{"role":"sampleCode","roleHeading":"WWDC18","modules":[{"name":"WWDC Notes"}],"title":"Implementing AutoFill Credential Provider Extensions"},"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","overridingTitle":"Open on WWDCIndex","isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/"}},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc18-721-implementing-autofill-credential-provider-extensions"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","abstract":[{"text":"Password AutoFill delivers the ability to fill passwords seamlessly within iOS apps and Safari. Join us to learn how app developers who provide credential management can surface their credentials during sign-in within apps and on the web.","type":"text"}],"references":{"https://nonstrict.eu/wwdcindex/wwdc2018/721/":{"checksum":null,"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","type":"topic","role":"collection","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-206-Introducing-Password-AutoFill-for-Apps":{"url":"\/documentation\/wwdcnotes\/wwdc17-206-introducing-password-autofill-for-apps","title":"Introducing Password AutoFill for Apps","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-206-Introducing-Password-AutoFill-for-Apps","kind":"article","abstract":[{"type":"text","text":"Logging in to an app is a source of friction that can lead to user abandonment. Password AutoFill is a new feature in iOS 11 that makes logging in easy by putting users’ passwords directly on the keyboard in your login UI. Learn how to guarantee that Password AutoFill works in your app to make logging in a frictionless experience for your users."}],"role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"title":"WWDC18","url":"\/documentation\/wwdcnotes\/wwdc18","type":"topic","role":"collectionGroup","abstract":[{"type":"text","text":"Xcode 10, Swift 4.2, iOS 12, macOS 10.14 (Mojave), tvOS 12, watchOS 5."}],"kind":"article","images":[{"identifier":"WWDC18-Icon.png","type":"icon"},{"identifier":"WWDC18.jpeg","type":"card"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","title":"Learn More…"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-234-Whats-New-in-Safari-and-WebKit":{"abstract":[{"type":"text","text":"Safari and WebKit are continually evolving with new features, APIs, and cutting edge web standards. Learn about this year’s biggest feature highlights, designed to help you create richer experiences with better performance and security — whether you are developing content for a browser or developing an app with embedded web content."}],"kind":"article","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-234-whats-new-in-safari-and-webkit","type":"topic","title":"What’s New in Safari and WebKit","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-234-Whats-New-in-Safari-and-WebKit"},"WWDC18.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC18.jpeg","traits":["1x","light"]}],"type":"image","identifier":"WWDC18.jpeg","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill":{"url":"\/documentation\/wwdcnotes\/wwdc18-204-automatic-strong-passwords-and-security-code-autofill","title":"Automatic Strong Passwords and Security Code AutoFill","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill","kind":"article","abstract":[{"type":"text","text":"Passwords and security codes are a modern necessity required for security and privacy. iOS 12 eases the tedious aspects of account setup and sign-in by automatically suggesting and using strong, unique passwords — even from within apps —  and by bringing one-time codes to the QuickType bar so users can fill them with one tap. Learn how to optimize your app to ensure that password, security code, and other AutoFill features provide a seamless way for your users to be more secure."}],"role":"sampleCode"},"WWDC18-Icon.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC18-Icon.png"}],"type":"image","alt":null,"identifier":"WWDC18-Icon.png"},"WWDCNotes.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","type":"image","alt":null}}}