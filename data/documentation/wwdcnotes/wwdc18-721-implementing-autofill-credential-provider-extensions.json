{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-721-Implementing-AutoFill-Credential-Provider-Extensions","interfaceLanguage":"swift"},"kind":"article","variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc18-721-implementing-autofill-credential-provider-extensions"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"roleHeading":"WWDC18","title":"Implementing AutoFill Credential Provider Extensions","role":"sampleCode","modules":[{"name":"WWDC Notes"}]},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"type":"heading","level":2,"text":"Related Sessions","anchor":"Related-Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-234-Whats-New-in-Safari-and-WebKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-206-Introducing-Password-AutoFill-for-Apps"],"type":"links","style":"list"}]}],"abstract":[{"type":"text","text":"Password AutoFill delivers the ability to fill passwords seamlessly within iOS apps and Safari. Join us to learn how app developers who provide credential management can surface their credentials during sign-in within apps and on the web."}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/","overridingTitle":"Read Transcript","isActive":true,"type":"reference"}},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-234-Whats-New-in-Safari-and-WebKit":{"abstract":[{"type":"text","text":"Safari and WebKit are continually evolving with new features, APIs, and cutting edge web standards. Learn about this year’s biggest feature highlights, designed to help you create richer experiences with better performance and security — whether you are developing content for a browser or developing an app with embedded web content."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-234-whats-new-in-safari-and-webkit","type":"topic","kind":"article","title":"What’s New in Safari and WebKit","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-234-Whats-New-in-Safari-and-WebKit"},"WWDC18-Icon.png":{"type":"image","identifier":"WWDC18-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC18-Icon.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"kind":"article","type":"topic","images":[{"identifier":"WWDC18-Icon.png","type":"icon"},{"identifier":"WWDC18.jpeg","type":"card"}],"url":"\/documentation\/wwdcnotes\/wwdc18","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18","role":"collectionGroup","title":"WWDC18","abstract":[{"type":"text","text":"Xcode 10, Swift 4.2, iOS 12, macOS 10.14 (Mojave), tvOS 12, watchOS 5."}]},"WWDCNotes.png":{"type":"image","identifier":"WWDCNotes.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWDCNotes.png"}],"type":"topic","kind":"symbol","role":"collection","title":"WWDC Notes","url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill":{"abstract":[{"type":"text","text":"Passwords and security codes are a modern necessity required for security and privacy. iOS 12 eases the tedious aspects of account setup and sign-in by automatically suggesting and using strong, unique passwords — even from within apps —  and by bringing one-time codes to the QuickType bar so users can fill them with one tap. Learn how to optimize your app to ensure that password, security code, and other AutoFill features provide a seamless way for your users to be more secure."}],"url":"\/documentation\/wwdcnotes\/wwdc18-204-automatic-strong-passwords-and-security-code-autofill","title":"Automatic Strong Passwords and Security Code AutoFill","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-204-Automatic-Strong-Passwords-and-Security-Code-AutoFill","kind":"article"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"type":"link","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-206-Introducing-Password-AutoFill-for-Apps":{"abstract":[{"type":"text","text":"Logging in to an app is a source of friction that can lead to user abandonment. Password AutoFill is a new feature in iOS 11 that makes logging in easy by putting users’ passwords directly on the keyboard in your login UI. Learn how to guarantee that Password AutoFill works in your app to make logging in a frictionless experience for your users."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc17-206-introducing-password-autofill-for-apps","type":"topic","kind":"article","title":"Introducing Password AutoFill for Apps","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-206-Introducing-Password-AutoFill-for-Apps"},"https://nonstrict.eu/wwdcindex/wwdc2018/721/":{"checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/","type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/721\/"},"WWDC18.jpeg":{"type":"image","identifier":"WWDC18.jpeg","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC18.jpeg","traits":["1x","light"]}]}}}