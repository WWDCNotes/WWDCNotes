{"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"type":"heading","text":"Related Sessions","anchor":"Related-Sessions","level":2},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences"],"type":"links","style":"list"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc16-805-iterative-ui-design"]}],"sampleCodeDownload":{"action":{"overridingTitle":"Watch Video (41 min)","isActive":true,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","type":"reference"},"kind":"sampleDownload"},"metadata":{"roleHeading":"WWDC16","role":"sampleCode","modules":[{"name":"WWDC Notes"}],"title":"Iterative UI Design"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"abstract":[{"type":"text","text":"You’re familiar with Keynote for making presentations, but it’s also a powerful tool for exploring, iterating and refining user interface layouts and workflows. Learn techniques and best practices for using Keynote to quickly and persuasively express your product ideas by building realistic and tangible design comps and user flows."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-805-Iterative-UI-Design"},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"WWDCNotes.png":{"identifier":"WWDCNotes.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image"},"WWDC16-Icon.png":{"identifier":"WWDC16-Icon.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC16-Icon.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-803-Typography-and-Fonts":{"abstract":[{"type":"text","text":"Typography is essential to an app’s form and function. Learn principles of good typography and techniques to apply them to your work. Make the most of the advanced features in our system fonts, and learn best practices for using custom fonts."}],"kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-803-typography-and-fonts","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts","title":"Typography and Fonts","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-804-Designing-Great-Apple-Watch-Experiences":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences","kind":"article","role":"sampleCode","title":"Designing Great Apple Watch Experiences","url":"\/documentation\/wwdcnotes\/wwdc16-804-designing-great-apple-watch-experiences","abstract":[{"type":"text","text":"watchOS 3 represents a big leap forward for Apple Watch and the apps that run on it. Performance improvements, powerful graphics and animation capabilities, deeper access to device capabilities, and a refined navigation model lay the foundation for designing useful and stunning Apple Watch apps. Learn best practices and techniques for making complications, notifications and apps that are highly actionable, glanceable and responsive."}],"type":"topic"},"WWDC16.jpeg":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"type":"image","alt":null,"identifier":"WWDC16.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-801-Inclusive-App-Design":{"abstract":[{"text":"Inclusive design means making your app intuitive, appropriate, and delightful for a global audience and people who have accessibility challenges. Learn easy-to-follow techniques for making your app culturally relevant and accessible through use of type, layout, color and iconography.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc16-801-inclusive-app-design","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design","kind":"article","title":"Inclusive App Design"},"doc://WWDCNotes/documentation/WWDCNotes":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","type":"topic","role":"collection","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-802-Designing-for-tvOS":{"title":"Designing for tvOS","type":"topic","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc16-802-designing-for-tvos","role":"sampleCode","abstract":[{"type":"text","text":"Change the way the world experiences television through apps that are designed to be immersive, intuitive and easy to use. Learn best practices and techniques to take advantage of the big screen and the Siri Remote."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS"},"https://developer.apple.com/videos/play/wwdc2016/805":{"checksum":null,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","type":"download"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"title":"WWDC16","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc16","type":"topic"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"text":"Learn More…","type":"text"}],"title":"Learn More…"}}}