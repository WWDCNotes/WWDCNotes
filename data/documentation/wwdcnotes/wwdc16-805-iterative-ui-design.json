{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"type":"heading","text":"Related Sessions","anchor":"Related-Sessions","level":2},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences"]}]}],"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-805-Iterative-UI-Design","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"abstract":[{"text":"You’re familiar with Keynote for making presentations, but it’s also a powerful tool for exploring, iterating and refining user interface layouts and workflows. Learn techniques and best practices for using Keynote to quickly and persuasively express your product ideas by building realistic and tangible design comps and user flows.","type":"text"}],"metadata":{"role":"sampleCode","title":"Iterative UI Design","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC16"},"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","isActive":true,"overridingTitle":"Watch Video (41 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805"}},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-805-iterative-ui-design"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-804-Designing-Great-Apple-Watch-Experiences":{"title":"Designing Great Apple Watch Experiences","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-804-designing-great-apple-watch-experiences","abstract":[{"text":"watchOS 3 represents a big leap forward for Apple Watch and the apps that run on it. Performance improvements, powerful graphics and animation capabilities, deeper access to device capabilities, and a refined navigation model lay the foundation for designing useful and stunning Apple Watch apps. Learn best practices and techniques for making complications, notifications and apps that are highly actionable, glanceable and responsive.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences","kind":"article","type":"topic"},"WWDC16.jpeg":{"type":"image","identifier":"WWDC16.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-802-Designing-for-tvOS":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS","title":"Designing for tvOS","abstract":[{"type":"text","text":"Change the way the world experiences television through apps that are designed to be immersive, intuitive and easy to use. Learn best practices and techniques to take advantage of the big screen and the Siri Remote."}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-802-designing-for-tvos","role":"sampleCode","kind":"article"},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-801-Inclusive-App-Design":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design","abstract":[{"text":"Inclusive design means making your app intuitive, appropriate, and delightful for a global audience and people who have accessibility challenges. Learn easy-to-follow techniques for making your app culturally relevant and accessible through use of type, layout, color and iconography.","type":"text"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc16-801-inclusive-app-design","title":"Inclusive App Design","type":"topic","role":"sampleCode"},"https://developer.apple.com/videos/play/wwdc2016/805":{"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc16","title":"WWDC16","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"kind":"article","type":"topic"},"WWDC16-Icon.png":{"type":"image","identifier":"WWDC16-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC16-Icon.png","traits":["1x","light"]}],"alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-803-Typography-and-Fonts":{"title":"Typography and Fonts","url":"\/documentation\/wwdcnotes\/wwdc16-803-typography-and-fonts","role":"sampleCode","abstract":[{"text":"Typography is essential to an app’s form and function. Learn principles of good typography and techniques to apply them to your work. Make the most of the advanced features in our system fonts, and learn best practices for using custom fonts.","type":"text"}],"kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts"}}}