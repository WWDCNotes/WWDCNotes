{"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-805-iterative-ui-design"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-805-Iterative-UI-Design"},"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC16","title":"Iterative UI Design","role":"sampleCode"},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"abstract":[{"text":"You’re familiar with Keynote for making presentations, but it’s also a powerful tool for exploring, iterating and refining user interface layouts and workflows. Learn techniques and best practices for using Keynote to quickly and persuasively express your product ideas by building realistic and tangible design comps and user flows.","type":"text"}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences"]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sampleCodeDownload":{"action":{"overridingTitle":"Watch Video (41 min)","type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805"},"kind":"sampleDownload"},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","type":"topic","role":"collection","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"WWDC16-Icon.png":{"type":"image","identifier":"WWDC16-Icon.png","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-804-Designing-Great-Apple-Watch-Experiences":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-804-Designing-Great-Apple-Watch-Experiences","role":"sampleCode","kind":"article","abstract":[{"text":"watchOS 3 represents a big leap forward for Apple Watch and the apps that run on it. Performance improvements, powerful graphics and animation capabilities, deeper access to device capabilities, and a refined navigation model lay the foundation for designing useful and stunning Apple Watch apps. Learn best practices and techniques for making complications, notifications and apps that are highly actionable, glanceable and responsive.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc16-804-designing-great-apple-watch-experiences","title":"Designing Great Apple Watch Experiences","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-803-Typography-and-Fonts":{"title":"Typography and Fonts","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-803-Typography-and-Fonts","kind":"article","abstract":[{"type":"text","text":"Typography is essential to an app’s form and function. Learn principles of good typography and techniques to apply them to your work. Make the most of the advanced features in our system fonts, and learn best practices for using custom fonts."}],"role":"sampleCode","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-803-typography-and-fonts"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"https://developer.apple.com/videos/play/wwdc2016/805":{"checksum":null,"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2016\/805"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-802-Designing-for-tvOS":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS","role":"sampleCode","kind":"article","abstract":[{"type":"text","text":"Change the way the world experiences television through apps that are designed to be immersive, intuitive and easy to use. Learn best practices and techniques to take advantage of the big screen and the Siri Remote."}],"title":"Designing for tvOS","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-802-designing-for-tvos"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"type":"topic","abstract":[{"text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3.","type":"text"}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","role":"collectionGroup","url":"\/documentation\/wwdcnotes\/wwdc16","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"title":"WWDC16"},"WWDC16.jpeg":{"type":"image","identifier":"WWDC16.jpeg","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC16.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-801-Inclusive-App-Design":{"title":"Inclusive App Design","url":"\/documentation\/wwdcnotes\/wwdc16-801-inclusive-app-design","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"Inclusive design means making your app intuitive, appropriate, and delightful for a global audience and people who have accessibility challenges. Learn easy-to-follow techniques for making your app culturally relevant and accessible through use of type, layout, color and iconography."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-801-Inclusive-App-Design"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}}}