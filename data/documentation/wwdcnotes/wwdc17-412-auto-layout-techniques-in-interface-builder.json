s can ensure your content can be viewed by anyone.","type":"text"}],"kind":"article","sections":[],"references":{"https://nonstrict.eu/wwdcindex/wwdc2017/412/":{"checksum":null,"type":"download","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/412\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/412\/"},"WWDC17.jpeg":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17.jpeg"}],"identifier":"WWDC17.jpeg","alt":null},"WWDCNotes.png":{"alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image","identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17","title":"WWDC17","type":"topic","abstract":[{"text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"type":"codeVoice","code":"Core NFC"},{"text":" and more.","type":"text"}],"role":"collectionGroup"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-401-Localizing-with-Xcode-9":{"url":"\/documentation\/wwdcnotes\/wwdc17-401-localizing-with-xcode-9","role":"sampleCode","abstract":[{"type":"text","text":"Build world-ready apps using Xcode by following some simple steps to manage strings and assets, and display your user interface. Take your localized apps even further with new technologies and features in Xcode 9. Learn how Xcode 9 helps you design, localize, and test your app in multiple languages."}],"title":"Localizing with Xcode 9","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-401-Localizing-with-Xcode-9","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-203-I-Have-This-Idea-For-An-App":{"role":"sampleCode","url":"\/documen