{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-303-Whats-New-in-StoreKit"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"sections":[],"metadata":{"title":"What’s New in StoreKit","modules":[{"name":"WWDC Notes"}],"role":"sampleCode","roleHeading":"WWDC17"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Related-Sessions","text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-301-Introducing-the-New-App-Store","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-302-Whats-New-in-iTunes-Connect","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-305-Advanced-StoreKit"]}]}],"kind":"article","abstract":[{"type":"text","text":"Starting with an expert guide to implementing the In-App Purchase workflow, learn about Promoted In-App Purchases and how to use the new StoreKit APIs. Find out what’s involved for your server and apps. And finally, get the details and guidance on asking for Ratings and Reviews, and responding to Reviews."}],"sampleCodeDownload":{"action":{"isActive":true,"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/303\/"},"kind":"sampleDownload"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-303-whats-new-in-storekit"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…"},"WWDC17-Icon.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC17-Icon.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"WWDC17-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","type":"topic","role":"collection","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-302-Whats-New-in-iTunes-Connect":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-302-Whats-New-in-iTunes-Connect","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc17-302-whats-new-in-itunes-connect","kind":"article","title":"What’s New in iTunes Connect","role":"sampleCode","abstract":[{"text":"iTunes Connect has been updated to make the experience of delivering your app to the new App Store even better. Learn about new and updated meta-data requirements, capabilities to support promotion of in-app purchases and techniques for handling customer reviews. Discover how new TestFlight features and deployment options can help you test and deploy your next masterpiece.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-301-Introducing-the-New-App-Store":{"title":"Introducing the New App Store","abstract":[{"type":"text","text":"Redesigned from the ground up, the new App Store provides a fresh approach to marketing your app.  Learn how the new functionality, enhanced editorial features, and the thinking that drove the visual changes are all designed to make your apps and in-app purchase more discoverable and appealing to your customers."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-301-Introducing-the-New-App-Store","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc17-301-introducing-the-new-app-store","role":"sampleCode","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-305-Advanced-StoreKit":{"kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-305-Advanced-StoreKit","title":"Advanced StoreKit","abstract":[{"type":"text","text":"Gain an understanding of the pros and cons of server- versus app-based receipt validation, and how to implement this critical functionality for your In-App Purchases.  Get the latest news, and valuable tips for keeping subscribers and managing subscriptions. Learn about a major improvement to In-App Purchases: Server-to-Server Notifications. And finally, get detailed instructions for testing with the In-App Purchase sandbox."}],"url":"\/documentation\/wwdcnotes\/wwdc17-305-advanced-storekit","role":"sampleCode"},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17","title":"WWDC17","type":"topic","abstract":[{"text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"type":"codeVoice","code":"Core NFC"},{"text":" and more.","type":"text"}],"role":"collectionGroup"},"WWDC17.jpeg":{"identifier":"WWDC17.jpeg","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17.