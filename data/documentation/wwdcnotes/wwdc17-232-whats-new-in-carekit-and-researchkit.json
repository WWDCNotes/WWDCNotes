{"metadata":{"modules":[{"name":"WWDC Notes"}],"role":"sampleCode","roleHeading":"WWDC17","title":"What’s New in CareKit and ResearchKit"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-232-whats-new-in-carekit-and-researchkit"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","type":"reference","isActive":true}},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-232-Whats-New-in-CareKit-and-ResearchKit"},"kind":"article","abstract":[{"type":"text","text":"Whether you’re a medical researcher or a care provider, the CareKit and ResearchKit open source projects are designed to be the quickest path to delivering a customized iOS app to your candidates or patients. These frameworks are constantly gaining features and functionality from both Apple and the community. Discover the latest active-tasks, care modules, and tools designed to allow medical professionals the ability prototype their own care app."}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"type":"heading","anchor":"Related-Sessions","level":2,"text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud"]}]}],"references":{"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","type":"topic","role":"collection","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"https://nonstrict.eu/wwdcindex/wwdc2017/232/":{"type":"download","checksum":null,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"url":"\/documentation\/wwdcnotes\/wwdc17","title":"WWDC17","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"kind":"article","images":[{"identifier":"WWDC17-Icon.png","type":"icon"},{"identifier":"WWDC17.jpeg","type":"card"}],"role":"collectionGroup"},"WWDC17-Icon.png":{"identifier":"WWDC17-Icon.png","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17-Icon.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-221-Whats-New-in-Health":{"title":"What’s New in Health","url":"\/documentation\/wwdcnotes\/wwdc17-221-whats-new-in-health","type":"topic","role":"sampleCode","abstract":[{"text":"HealthKit has become the standard for apps that help you manage and track your health on iOS and watchOS. Learn about new HealthKit data types in iOS 11, how to create and access workout route data, how to avoid duplication of health data, and enhancements made in HealthKit to support people managing diabetes.","type":"text"}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-239-Connecting-CareKit-to-the-Cloud":{"url":"\/documentation\/wwdcnotes\/wwdc17-239-connecting-carekit-to-the-cloud","title":"Connecting CareKit to the Cloud","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud","abstract":[{"text":"The CareKit open source project provides customizable modules for delivering an app that puts a patient’s care plan and adherence tracking in the palm of their hands. Connecting patient care apps to the care team is critical for monitoring adherence and providing updates is crucial. Until now, every implementation required custom integration.  Learn how the new CareKit Bridge API abstracts the communication to the back end and provides a simple mechanism for plugging in your custom or third-party provided cloud connectors.","type":"text"}],"kind":"article","role":"sampleCode"},"WWDC17.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC17.jpeg","traits":["1x","light"]}],"type":"image","identifier":"WWDC17.jpeg","alt":null}}}