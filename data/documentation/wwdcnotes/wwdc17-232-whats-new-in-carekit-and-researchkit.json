{"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC17","title":"What’s New in CareKit and ResearchKit","role":"sampleCode"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-232-Whats-New-in-CareKit-and-ResearchKit"},"sampleCodeDownload":{"action":{"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","overridingTitle":"Read Transcript","isActive":true},"kind":"sampleDownload"},"kind":"article","primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}]},{"type":"heading","text":"Related Sessions","anchor":"Related-Sessions","level":2},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud"],"style":"list"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-232-whats-new-in-carekit-and-researchkit"]}],"abstract":[{"text":"Whether you’re a medical researcher or a care provider, the CareKit and ResearchKit open source projects are designed to be the quickest path to delivering a customized iOS app to your candidates or patients. These frameworks are constantly gaining features and functionality from both Apple and the community. Discover the latest active-tasks, care modules, and tools designed to allow medical professionals the ability prototype their own care app.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWDCNotes.png"}],"type":"topic","kind":"symbol","role":"collection","title":"WWDC Notes","url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"WWDC17-Icon.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17-Icon.png"}],"identifier":"WWDC17-Icon.png","alt":null},"https://nonstrict.eu/wwdcindex/wwdc2017/232/":{"type":"download","checksum":null,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-239-Connecting-CareKit-to-the-Cloud":{"abstract":[{"type":"text","text":"The CareKit open source project provides customizable modules for delivering an app that puts a patient’s care plan and adherence tracking in the palm of their hands. Connecting patient care apps to the care team is critical for monitoring adherence and providing updates is crucial. Until now, every implementation required custom integration.  Learn how the new CareKit Bridge API abstracts the communication to the back end and provides a simple mechanism for plugging in your custom or third-party provided cloud connectors."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc17-239-connecting-carekit-to-the-cloud","type":"topic","kind":"article","title":"Connecting CareKit to the Cloud","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud"},"WWDC17.jpeg":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17.jpeg"}],"identifier":"WWDC17.jpeg","alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"type":"topic","kind":"article","role":"collectionGroup","title":"WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-221-Whats-New-in-Health":{"title":"What’s New in Health","url":"\/documentation\/wwdcnotes\/wwdc17-221-whats-new-in-health","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health","kind":"article","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"HealthKit has become the standard for apps that help you manage and track your health on iOS and watchOS. Learn about new HealthKit data types in iOS 11, how to create and access workout route data, how to avoid duplication of health data, and enhancements made in HealthKit to support people managing diabetes."}]}}}