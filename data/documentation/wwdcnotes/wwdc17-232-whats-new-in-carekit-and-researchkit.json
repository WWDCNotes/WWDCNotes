{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc17-232-whats-new-in-carekit-and-researchkit"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Whether you’re a medical researcher or a care provider, the CareKit and ResearchKit open source projects are designed to be the quickest path to delivering a customized iOS app to your candidates or patients. These frameworks are constantly gaining features and functionality from both Apple and the community. Discover the latest active-tasks, care modules, and tools designed to allow medical professionals the ability prototype their own care app.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-232-Whats-New-in-CareKit-and-ResearchKit"},"sampleCodeDownload":{"action":{"type":"reference","isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC17","role":"sampleCode","title":"What’s New in CareKit and ResearchKit"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"anchor":"Related-Sessions","level":2,"type":"heading","text":"Related Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud"]}]}],"references":{"https://nonstrict.eu/wwdcindex/wwdc2017/232/":{"type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/232\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-221-Whats-New-in-Health":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-221-Whats-New-in-Health","role":"sampleCode","kind":"article","abstract":[{"type":"text","text":"HealthKit has become the standard for apps that help you manage and track your health on iOS and watchOS. Learn about new HealthKit data types in iOS 11, how to create and access workout route data, how to avoid duplication of health data, and enhancements made in HealthKit to support people managing diabetes."}],"type":"topic","title":"What’s New in Health","url":"\/documentation\/wwdcnotes\/wwdc17-221-whats-new-in-health"},"WWDCNotes.png":{"type":"image","identifier":"WWDCNotes.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"WWDC17-Icon.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17-Icon.png","traits":["1x","light"]}],"identifier":"WWDC17-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-239-Connecting-CareKit-to-the-Cloud":{"role":"sampleCode","abstract":[{"text":"The CareKit open source project provides customizable modules for delivering an app that puts a patient’s care plan and adherence tracking in the palm of their hands. Connecting patient care apps to the care team is critical for monitoring adherence and providing updates is crucial. Until now, every implementation required custom integration.  Learn how the new CareKit Bridge API abstracts the communication to the back end and provides a simple mechanism for plugging in your custom or third-party provided cloud connectors.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc17-239-connecting-carekit-to-the-cloud","kind":"article","title":"Connecting CareKit to the Cloud","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-239-Connecting-CareKit-to-the-Cloud","type":"topic"},"WWDC17.jpeg":{"alt":null,"type":"image","identifier":"WWDC17.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC17.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"type":"topic","title":"WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}}}