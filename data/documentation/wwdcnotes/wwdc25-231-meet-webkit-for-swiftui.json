{"kind":"article","sampleCodeDownload":{"action":{"type":"reference","overridingTitle":"Watch Video (21 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/231","isActive":true},"kind":"sampleDownload"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc25-231-meet-webkit-for-swiftui"]}],"metadata":{"title":"Meet WebKit for SwiftUI","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC25","role":"sampleCode"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Discover how you can use WebKit to effortlessly integrate web content into your SwiftUI apps. Learn how to load and display web content, communicate with webpages, and more."}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-231-Meet-WebKit-for-SwiftUI"},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Key-Takeaways","level":2,"text":"Key Takeaways"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"🌐 New WebView in SwiftUI","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"🔗 Handle web cotent, navigation & interact with JS with the new WebPage class","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"🗺️ Easier to control the scroll position"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"🔍 Easier to perform find-in-page"}]}]}]},{"type":"heading","anchor":"Load-and-display-web-content","level":2,"text":"Load and display web content"},{"type":"heading","anchor":"Displaying-web-content","level":3,"text":"Displaying web content"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New SwiftUI API: "},{"code":"WebView(url:)","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"text":"New observable class that represent your web content: ","type":"text"},{"code":"WebPage","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"WebPage can be used to load, control and communicate with web content. It can be used completely on its own or combine with webview to build rich experiences for web content."}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @State private var page = WebPage()","","    var body: some View {","        NavigationStack {","            WebView(page)","                .navigationTitle(page.title)","        }","    }","}"]},{"type":"heading","anchor":"Loading-web-content","level":3,"text":"Loading web content"},{"type":"codeListing","syntax":"swift","code":["\/\/ Loading a URL request","let page = WebPage()","var request = URLRequest(url: item.url)","request.attribution = .user","","page.load(request)","","\/\/ Loading an HTML string","let page = WebPage()","page.load(html: item.html, baseURL: URL(string: \"about:blank\")!)","","\/\/ Loading data","let page = WebPage()","let base = URL(string: \"about:blank\")!","let mimeType = \"application\/x-webarchive\"","","page.load(item.webArchiveData, mimeType: mimeType, characterEncoding: .utf8, baseURL: base)"]},{"type":"heading","anchor":"Loading-local-resources","level":3,"text":"Loading local resources"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New protocol: "},{"type":"codeVoice","code":"URLSchemeHandler"}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Creating a custom scheme handler","struct LakeResourceSchemeHandler: URLSchemeHandler {","    func reply(","        for request: URLRequest","    ) -> some AsyncSequence<URLSchemeTaskResult, any Error> {","        AsyncThrowingStream { continuation in","            Task {","                let response = await getResponse()","                continuation.yield(.response(response))","","                for await dataChunk in getDataStream() {","                    continuation.yield(.data(dataChunk))","                }","","                continuation.finish()","            }","        }","    }","}","","\/\/ Register the lakes:\/\/ custom scheme","init(lake: LakeArticle) {","    self.lake = lake","    ","    let scheme = URLScheme(\"lakes\")!","    let handler = LakeResourceSchemeHandler()","","    var configuration = WebPage.Configuration()","    configuration.urlSchemeHandler[scheme] = handler","","    self.page = WebPage(configuration: configuration)","}","","\/\/ Providing default articles (using the handler above to deal with the data logic)","extension LakeArticle {","    static let defaults = {","        LakeArticle(","            name: \"Lake Tahoe\", ","            url: URL(string: \"lakes:\/\/tahoe.html\")!,","        ),","        LakeArticle(","            name: \"Lake Ontario\", ","            url: URL(string: \"lakes:\/\/ontario.html\")!,","        ),","    }","}"]},{"type":"heading","anchor":"Communicate-with-the-page","level":2,"text":"Communicate with the page"},{"type":"codeListing","syntax":"swift","code":["\/\/ Getting the current navigation event","let page = WebPage()","guard let event = page.currentNavigationEvent else { return }","","let navigationID = event.navigationID","","\/\/ take actions base on what kind of event it is","switch event.kind { ... }"]},{"type":"heading","anchor":"Navigation-progress","level":3,"text":"Navigation progress"},{"type":"tabNavigator","tabs":[{"title":"Normal","content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-navigation-progress-normal","type":"image"}]}]},{"title":"Failed","content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-navigation-progress-error","type":"image"}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Continuously observing navigation events","func loadArticle() async {","    let id = page.load(URLRequest(url: lake.url))","    \/\/ Available in Swift 6.2 ","    let events = Observations { page.currentNavigationEvent }","","    for await event in events where event?.navigationID = id {","        switch event?.kind {","        case let .failed(error):","            self.currentError = error","","        case .finished:","            lake.sections = await parseSections()","","        default:","            break","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"What WebPage properties observations can do:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observing page properties"}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-page-properties","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Evaluating JavaScript"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-call-js","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Navigation policies","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-decide-policy","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Combined the code below with the NavigationDecider above, we can achieve this:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Handle specific URLs within our apps","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Other URLs will be opened with the default browser","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["private var navigationDecider = NavigationDecider()","var urlToOpen: URL? = nil","","init(lake: LakeArticle) {","    \/\/ ...","    self.page = WebPage(","        configuration: configuration, ","        navigationDecider: navigationDecider,","    )","","    self.navigationDecider.owner = self","}","","\/\/ Observe `urlToOpen` in SwiftUI view and handle the rest of the logic"]},{"type":"heading","anchor":"Customize-web-content-interaction","level":2,"text":"Customize web content interaction"},{"type":"heading","anchor":"Configuring-scrolling-behavior","level":3,"text":"Configuring scrolling behavior"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-scroll-behavior","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"Can also enabling Look to Scroll on visionOS with: ","type":"text"},{"code":".webViewScrollInputBehavior(.enabled, for: .look)","type":"codeVoice"},{"text":", for more information check ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/view\/webviewscrollinputbehavior(_:for:)\/","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Enabling-find-in-page","level":3,"text":"Enabling find-in-page"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-find-in-page","type":"image"}]},{"type":"heading","anchor":"Scrolling-to-a-position","level":3,"text":"Scrolling to a position"},{"type":"paragraph","inlineContent":[{"identifier":"WWDC25-231-scroll-to-position","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Can use the new modifier to observe scroll position changes in WebView:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swiftui\/view\/webviewonscrollgeometrychange(for:of:action:)\/","isActive":true}]},{"type":"heading","anchor":"Next-steps","level":2,"text":"Next steps"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Migrate to the new API"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Explore what’s new in Swift and SwiftUI"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Share your feedback","type"