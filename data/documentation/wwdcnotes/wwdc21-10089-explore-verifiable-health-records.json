orce resource integrity, and prevents the creation of structurally invalid resources — across multiple versions of the FHIR specification. Whether you’re working with clinical data obtained from HealthKit or direct from a clinical system, FHIRModels makes FHIR easy to handle."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10669-Handling-FHIR-without-getting-burned","url":"\/documentation\/wwdcnotes\/wwdc20-10669-handling-fhir-without-getting-burned","title":"Handling FHIR without getting burned"},"https://developer.apple.com/videos/play/wwdc2021/10089":{"type":"download","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2021\/10089","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2021\/10089"},"WWDCNotes.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"type":"image","identifier":"WWDCNotes.png","alt":null},"WWDC21-Icon.png":{"type":"image","alt":null,"identifier":"WWDC21-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC21-Icon.png"}]}}}