{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc15-704-whats-new-in-cloudkit"]}],"abstract":[{"type":"text","text":"CloudKit is the framework that powers iCloud on iOS, OS X, and now iCloud on the web. Hear how we’ve been working to make CloudKit more accessible to all your users with the web services API and Javascript library. Learn about reporting available in the updated Dashboard and the new, more flexible public database storage pricing."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-704-Whats-New-in-CloudKit"},"sections":[],"sampleCodeDownload":{"action":{"type":"reference","isActive":true,"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/704\/"},"kind":"sampleDownload"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"WWDC15","modules":[{"name":"WWDC Notes"}],"title":"What’s New in CloudKit","role":"sampleCode"},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-226-Build-Better-Apps-with-CloudKit-Dashboard"],"style":"list","type":"links"}],"kind":"content"}],"references":{"WWDCNotes.png":{"alt":null,"identifier":"WWDCNotes.png","type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-226-Build-Better-Apps-with-CloudKit-Dashboard":{"role":"sampleCode","type":"topic","title":"Build Better Apps with CloudKit Dashboard","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-226-Build-Better-Apps-with-CloudKit-Dashboard","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17-226-build-better-apps-with-cloudkit-dashboard","abstract":[{"type":"text","text":"The CloudKit Dashboard has been completely overhauled to aid you throughout your development lifecycle of building, testing, operating, and supporting your CloudKit-backed applications. See the new functionality, including fetching changes and modifying sharing relationships right from the Dashboard.  Gain insights from real-time server logs into events across all of your users—including CloudKit push notifications—to facilitate debugging and customer support."}]},"WWDC15.jpeg":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}],"identifier":"WWDC15.jpeg","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"type":"topic","title":"WWDC15","role":"collectionGroup","url":"\/documentation\/wwdcnotes\/wwdc15","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","images":[{"identifier":"WWDC15-Icon.png","type":"icon"},{"identifier":"WWDC15.jpeg","type":"card"}],"abstract":[{"text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2.","type":"text"}],"kind":"article"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"https://nonstrict.eu/wwdcindex/wwdc2015/704/":{"checksum":null,"url":"https:\/\/nonstrict.eu\/wwdci