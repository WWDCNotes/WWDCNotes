h":0,"major":0},"sections":[],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-210-mastering-uikit-on-tvos"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-212-Developing-tvOS-Apps-Using-TVMLKit-Part-1":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-212-Developing-tvOS-Apps-Using-TVMLKit-Part-1","url":"\/documentation\/wwdcnotes\/wwdc16-212-developing-tvos-apps-using-tvmlkit-part-1","abstract":[{"type":"text","text":"Join us for an introduction to TVMLKit, a template-based UI layout technology that is part of tvOS. Learn about new features coming in tvOS 10, as well as best practices in architecting your application, styling and customization of templates, and media playback."}],"title":"Developing tvOS Apps Using TVMLKit: Part 1","kind":"article","type":"topic","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-607-Controlling-Game-Input-for-Apple-TV":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-607-Controlling-Game-Input-for-Apple-TV","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-607-controlling-game-input-for-apple-tv","type":"topic","title":"Controlling Game Input for Apple TV","kind":"article","abstract":[{"type":"text","text":"Apple TV presents an incredible opportunity for developers to create new games made for the living room. See how the Game Controller framework can tap into the Siri Remote to harness touch and the built-in accelerometer and gyroscope to deliver engaging gameplay. Learn how to fully integrate MFi controllers, and understand best practices for developing titles that require a game controller."}]},"WWDC16.jpeg":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"type":"image","identifier":"WWDC16.jpeg","alt":null},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-206-Whats-New-in-tvOS":{"url":"\/documentation\/wwdcnotes\/wwdc16-206-whats-new-in-tvos","title":"What’s New in tvOS","kind":"article","type":"topic","role":"sampleCode","abstract":[{"text":"Apps are quickly changing how we experience TV today, and tvOS is the foundation upon which new apps and ideas are being built. Take your app to the next level with great new features in tvOS 10. Learn all about the new interface appearance APIs, support for badging and notifications, and more.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-206-Whats-New-in-tvOS"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"WWDC16-Icon.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}],"type":"image","identifier":"WWDC16-Icon.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","type":"topic","role":"collection","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-229-Developing-tvOS-Apps-Using-TVMLKit-Part-2":{"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-229-developing-tvos-apps-using-tvmlkit-part-2","title":"Developing tvOS Apps Using TVMLKit: Part 2","kind":"article","role":"sampleCode","abstract":[{"text":"Learn about advanced techniques in TVML based apps, such as bridging between native and javascript code, creating your own custom views for use inside of templates, creating your own custom templates, how to introduce UIKit view controllers alongside TVMLKit based templates, and additional best practices you can apply to your apps.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-229-Developing-tvOS-Apps-Using-TVMLKit-Part-2"},"https://nonstrict.eu/wwdcindex/wwdc2016/210/":{"type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/210\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/210\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"title":"WWDC16","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc16","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-802-Designing-for-tvOS":{"title":"Designing for tvOS","type":"topic","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc16-802-designing-for-tvos","role":"sampleCode","abstract":[{"type":"text","text":"Change the way the world experiences television through apps that are designed to be immersive, intuitive and easy to use. Learn best practices and techniques to take advantage of the big screen and the Siri Remote."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-802-Designing-for-tvOS"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-215-Focus-Interaction-on-tvOS":{"title":"Focus Interaction on tvOS","role":"sampleCode","kind":"article","type":"topic","abstract":[{"type":"text","text":"The focus interaction model is a critical component of an engaging and intuitive experience on tvOS. Learn more about how it works, some additions and changes to the API, as well as tips and tricks for making your tvOS app even better."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-215-Focus-Interaction-on-tvOS","url":"\/documentation\/wwdcnotes\/wwdc16-215-focus-interaction-on-tvos"}}}