{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-102-Platforms-State-of-the-Union","interfaceLanguage":"swift"},"metadata":{"roleHeading":"WWDC16","modules":[{"name":"WWDC Notes"}],"title":"Platforms State of the Union","role":"sampleCode"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}]},{"type":"heading","text":"Related Sessions","anchor":"Related-Sessions","level":2},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-102-Platforms-State-of-the-Union","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-101-Keynote","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-203-Whats-New-in-Cocoa","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-205-Whats-New-in-Cocoa-Touch","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-206-Whats-New-in-tvOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-208-Whats-New-in-watchOS-3"],"style":"list"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-102-platforms-state-of-the-union"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"abstract":[{"type":"text","text":"WWDC 2016 Platforms State of the Union"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"type":"reference","overridingTitle":"Read Transcript","isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/102\/"}},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWDCNotes.png"}],"type":"topic","kind":"symbol","role":"collection","title":"WWDC Notes","url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-208-Whats-New-in-watchOS-3":{"abstract":[{"text":"watchOS 3 brings together notifications, complications, and the new Dock to keep your apps glanceable and responsive. Find out about the new additions to watchOS to create stunning visuals and learn about new snapshotting APIs to ensure your app is up to date when people glance at their wrist. Take a tour of watchOS 3 enhancements with us and find out which sessions you won’t want to miss throughout the week.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc16-208-whats-new-in-watchos-3","title":"What’s New in watchOS 3","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-208-Whats-New-in-watchOS-3","kind":"article"},"WWDCNotes.png":{"alt":null,"type":"image","identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-205-Whats-New-in-Cocoa-Touch":{"abstract":[{"text":"The UIKit framework provides the crucial infrastructure needed to construct and manage iOS apps, and UIKit continues to advance the state of the art for app design with many new features. Dive straight into new features across the iOS frameworks that allow your apps to take advantage of many new system services, as well as to offer services to other apps. This is your first stop to discover the many sessions to see about harnessing the power of iOS 10.","type":"text"}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-205-whats-new-in-cocoa-touch","type":"topic","kind":"article","title":"What’s New in Cocoa Touch","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-205-Whats-New-in-Cocoa-Touch"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"WWDC16-Icon.png":{"alt":null,"type":"image","identifier":"WWDC16-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}]},"WWDC16.jpeg":{"identifier":"WWDC16.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"type":"image","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-102-Platforms-State-of-the-Union":{"url":"\/documentation\/wwdcnotes\/wwdc18-102-platforms-state-of-the-union","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-102-Platforms-State-of-the-Union","role":"sampleCode","kind":"article","abstract":[{"type":"text","text":"2018 Platforms State of the Union"}],"type":"topic","title":"Platforms State of the Union"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-203-Whats-New-in-Cocoa":{"abstract":[{"type":"text","text":"macOS brings many new enhancements such as automatic window tabbing, enhanced color reproduction, and improved presentation of right-to-left languages. Get introduced to new APIs for these features and more, such as NSGridView and NSMeasurement. Learn about new conventions for APIs in Swift and Objective-C. This is your first stop to discover exciting new features in Cocoa sessions throughout the week."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-203-whats-new-in-cocoa","type":"topic","kind":"article","title":"What’s New in Cocoa","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-203-Whats-New-in-Cocoa"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-206-Whats-New-in-tvOS":{"url":"\/documentation\/wwdcnotes\/wwdc16-206-whats-new-in-tvos","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-206-Whats-New-in-tvOS","role":"sampleCode","kind":"article","abstract":[{"text":"Apps are quickly changing how we experience TV today, and tvOS is the foundation upon which new apps and ideas are being built. Take your app to the next level with great new features in tvOS 10. Learn all about the new interface appearance APIs, support for badging and notifications, and more.","type":"text"}],"type":"topic","title":"What’s New in tvOS"},"https://nonstrict.eu/wwdcindex/wwdc2016/102/":{"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/102\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/102\/","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"title":"WWDC16","url":"\/documentation\/wwdcnotes\/wwdc16","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"role":"collectionGroup","type":"topic","kind":"article","abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-101-Keynote":{"abstract":[{"type":"text","text":"WWDC 2016 Keynote"}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-101-keynote","type":"topic","kind":"article","title":"Keynote","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-101-Keynote"}}}