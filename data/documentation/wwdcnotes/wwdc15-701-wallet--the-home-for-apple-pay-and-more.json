{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Passbook is now Wallet.  Wallet stores your coupons, boarding passes, event tickets, and even the credit and debit cards you use with Apple Pay. In iOS 9, Wallet makes the Apple Pay experience even better and integrates more with Apple Watch.  Learn about the Wallet app, new kinds of passes, and how your app can integrate and interact with Wallet.","type":"text"}],"metadata":{"roleHeading":"WWDC15","title":"Wallet - The home for Apple Pay and more","role":"sampleCode","modules":[{"name":"WWDC Notes"}]},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/701\/","isActive":true}},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}]}]}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-701-wallet--the-home-for-apple-pay-and-more"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-701-Wallet--The-home-for-Apple-Pay-and-more","interfaceLanguage":"swift"},"kind":"article","sections":[],"references":{"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"identifier":"WWDCNotes.png"},"WWDC15-Icon.png":{"alt":null,"type":"image","variants":