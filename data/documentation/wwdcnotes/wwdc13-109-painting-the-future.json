{"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC13-109-Painting-the-Future"},"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC13","role":"sampleCode","title":"Painting the Future"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC13"]]},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]}],"kind":"content"}],"abstract":[{"text":"Be among the first to see the unveiling of MARI on OS X, the supercharged 3D painting package coming to the Mac later this year, running on the next generation Mac Pro.  Jack Greasley, The Foundry’s MARI Product Manager, will chart MARI’s rapid rise from in-house studio tool to the film industry’s painting tool of choice.  He will detail MARI’s evolution, from its original conception during Weta Digital’s visual effects work on Avatar to becoming a critical element in making countless blockbusters a reality.  Then watch as Pixar character shading artist, Jonathan Hoffman, makes full use of the power of the next generation Mac Pro to demonstrate how MARI was used to help bring Monsters University to life.","type":"text"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2013\/109\/"}},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc13-109-painting-the-future"]}],"references":{"https://nonstrict.eu/wwdcindex/wwdc2013/109/":{"checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2013\/109\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2013\/109\/","type":"download"},"WWDC13-Icon.png":{"identifier":"WWDC13-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC13-Icon.png","traits":["1x","light"]}],"type":"image"},"WWDC13.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC13.jpeg"}],"identifier":"WWDC13.jpeg","type":"image"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","type":"link","titleInlineContent":[{"text":"Learn More…","type":"text"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC13":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC13-Icon.png"},{"type":"card","identifier":"WWDC13.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc13","title":"WWDC13","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC13","type":"topic","kind":"article","abstract":[{"type":"text","text":"Xcode 5, iOS 7, macOS 10.9 (Mavericks)."}]},"WWDCNotes.png":{"identifier":"WWDCNotes.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image"}}}