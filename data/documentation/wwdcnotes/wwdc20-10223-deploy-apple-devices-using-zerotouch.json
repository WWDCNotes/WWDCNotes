{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20"]]},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Discover how Apple’s system administrators remotely deploy Apple devices to their teams, ensuring a zero-touch deployment. Learn how to configure the setup experience, control and manage devices effectively, and discover practices around security and management."}],"sections":[],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"Watch Video (17 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2020\/10223","type":"reference"}},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10223-Deploy-Apple-devices-using-zerotouch","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}]},{"level":2,"type":"heading","text":"Related Sessions","anchor":"Related-Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10139-Leverage-enterprise-identity-and-authentication","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10639-Whats-new-in-managing-Apple-devices","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10667-Custom-app-distribution-with-Apple-Business-Manager"]}]}],"metadata":{"role":"sampleCode","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC20","title":"Deploy Apple devices using zero-touch"},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc20-10223-deploy-apple-devices-using-zerotouch"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10639-Whats-new-in-managing-Apple-devices":{"abstract":[{"type":"text","text":"We’ve made significant strides in bringing crucial device management features to macOS. Discover how these features can help you manage your all your devices using the same tools and technologies. Get details on changes coming this year and how they will impact your deployment workflows, as well as some new management capabilities you can use to secure iOS and iPadOS devices in your organization."}],"url":"\/documentation\/wwdcnotes\/wwdc20-10639-whats-new-in-managing-apple-devices","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10639-Whats-new-in-managing-Apple-devices","type":"topic","kind":"article","role":"sampleCode","title":"What’s new in managing Apple devices"},"https://developer.apple.com/videos/play/wwdc2020/10223":{"checksum":null,"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2020\/10223","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2020\/10223","type":"download"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10139-Leverage-enterprise-identity-and-authentication":{"abstract":[{"text":"Empower your organization with the right tools while protecting privacy and security. Discover Apple’s identity management tools for enterprise, and how they can help you create a smoother experience for users when signing in to devices, apps and websites. We’ll show you how to take advantage of Federated Authentication and Single Sign-on extensions, including changes to Apple’s built-in Kerberos extension. And explore our other platform tools for enterprise users, including macOS account types and Shared iPad for Business.","type":"text"}],"title":"Leverage enterprise identity and authentication","role":"sampleCode","kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc20-10139-leverage-enterprise-identity-and-authentication","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10139-Leverage-enterprise-identity-and-authentication"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","url":"\/documentation\/wwdcnotes","title":"WWDC Notes","role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}]},"WWDC20-Icon.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC20-Icon.png"}],"alt":null,"identifier":"WWDC20-Icon.png","type":"image"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20":{"role":"collectionGroup","kind":"article","abstract":[{"text":"Xcode 12, Swift 5.3, iOS 14, macOS 11 (Big Sur), tvOS 14, watchOS 7.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"WidgetKit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"StoreKit Testing","type":"codeVoice"},{"text":", and more.","type":"text"}],"images":[{"identifier":"WWDC20-Icon.png","type":"icon"},{"identifier":"WWDC20.jpeg","type":"card"}],"type":"topic","title":"WWDC20","url":"\/documentation\/wwdcnotes\/wwdc20","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10667-Custom-app-distribution-with-Apple-Business-Manager":{"abstract":[{"type":"text","text":"Apple Business Manager is the best way to manage and deploy business apps to your employees and customers. Whether you’re a developer, business owner, or IT administrator, we’ll showcase the benefits of Custom apps for each role and provide guidance on each step in the process — from app creation to distribution."}],"title":"Custom app distribution with Apple Business Manager","role":"sampleCode","kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc20-10667-custom-app-distribution-with-apple-business-manager","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10667-Custom-app-distribution-with-Apple-Business-Manager"},"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png","alt":null,"type":"image"},"WWDC20.jpeg":{"type":"image","identifier":"WWDC20.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC20.jpeg"}],"alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}}}