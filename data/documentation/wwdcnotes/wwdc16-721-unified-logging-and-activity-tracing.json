{"sections":[],"kind":"article","variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-721-unified-logging-and-activity-tracing"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-721-Unified-Logging-and-Activity-Tracing","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"metadata":{"role":"sampleCode","roleHeading":"WWDC16","title":"Unified Logging and Activity Tracing","modules":[{"name":"WWDC Notes"}]},"abstract":[{"text":"The new Unified Logging and Tracing System for iOS and macOS uses Activity Tracing for performance, consolidates kernel and user-space logging, and has many other improvements. Learn how Logging and Tracing can help you debug and troubleshoot issues with your apps.","type":"text"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Introduction","text":"Introduction","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"One common, efficient logging mechanism for both user and kernel mode.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Maximize information collected while minimizing ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"observer"}]},{"text":" effect (e.g. because of breakpoints\/print you change the timing and the bug doesn’t happen anymore).","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"os_log"},{"type":"text","text":" compresses data, and defers lots of work (key point to avoid observer effect)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Designed with privacy in mind ️❤️"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Whats-New","text":"What’s New","type":"heading"},{"items":[{"content":[{"inlineContent":[{"text":"New tools to categorize and filter log messages","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Logging system collects caller info for you (","type":"text"},{"code":"__FILE__","type":"codeVoice"},{"text":", ","type":"text"},{"code":"_FUNCTION__","type":"codeVoice"},{"text":" etc are automatically collected)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New type formatters (more on this later)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New console and command-line tool"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Adoption","text":"Adoption","type":"heading"},{"inlineContent":[{"type":"text","text":"Legacy APIs ("},{"type":"codeVoice","code":"NSLog"},{"type":"text","text":") are automatically redirected into the new system."}],"type":"paragraph"},{"level":2,"anchor":"New-File-Format","text":"New File Format","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":".tracev3"},{"type":"text","text":" stored at "},{"type":"codeVoice","code":"\/var\/db\/diagnostics"},{"type":"text","text":" with additional support files at "},{"type":"codeVoice","code":"\/var\/db\/uuidtext"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":".logarchive"},{"text":" is basically a merge of the files found in the folders above, it’s used to transfer the logging to other people, bug reports","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"Subsystem-and-Categories","text":"Subsystem and Categories","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Subsystem should be the app\/framework domain (your.app.identifier)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Category are the different domains (“store”, “chat”, “account”, …)"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Logging-Behavior","text":"Logging Behavior","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Three basic levels","type":"text"}]},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Default","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Info","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Debug","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Two special levels"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Fault","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Error","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Each "},{"type":"strong","inlineContent":[{"text":"basic level","type":"text"}]},{"type":"text","text":" has two characteristics that can be set for system, subsystem, or category (in the Console app we can mute every single one of them, even the process, even filter by type like error -> you can even save one filter that you create ):"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enabled (does it actually produce a log?)"}]}]},{"content":[{"inlineContent":[{"code":"isItStoredToDisk","type":"codeVoice"},{"text":" or Memory (memory: memory buffer, saved to disk only on fault or error)","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Levels are hierarchical, therefore by setting Debug to go to disk, implies that Info (and Default) will also go to disk","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Default behavior:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"WWDC16-721-behavior"}],"type":"paragraph"},{"level":2,"anchor":"Privacy","text":"Privacy","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Prevent accidental logging of Personally Identifiable Information (PII)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dynamic strings, collections, arrays, etc. are assumed to be private"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC16-721-privacy"}],"type":"paragraph"},{"level":2,"anchor":"Architecture","text":"Architecture","type":"heading"},{"inlineContent":[{"identifier":"WWDC16-721-architecture","type":"image"}],"type":"paragraph"},{"level":2,"anchor":"Faults-and-Errors","text":"Faults and Errors","type":"heading"},{"inlineContent":[{"text":"Faults and Error log information are captured into a separate set of log files","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Errors represent issues discovered within a given application\/library","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Faults represent more global problems in the system","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"anchor":"APIs","text":"APIs","type":"heading"},{"inlineContent":[{"identifier":"WWDC16-721-api","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"os_log_create"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"takes two parameters: the name of the subsystem and the name of the category."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"creates a thread-safe singleton object that controls behavior of log messages, here’s how to use it:"}]}]}],"type":"unorderedList"},{"syntax":"swift","code":["os_log(log, \"This happened\")"],"type":"codeListing"},{"level":2,"anchor":"Type-Formatters","text":"Type Formatters","type":"heading"},{"inlineContent":[{"type":"text","text":"We should use these as 