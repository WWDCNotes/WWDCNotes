{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-301-Introducing-Expanded-Subscriptions-in-iTunes-Connect","interfaceLanguage":"swift"},"abstract":[{"text":"See what’s new in subscriptions. Learn how our improvements give you more flexibility and control over pricing, and provide powerful incentives to engage and retain your customers.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc16-301-introducing-expanded-subscriptions-in-itunes-connect"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/developer.apple.com\/wwdc16\/301","type":"reference","isActive":true,"overridingTitle":"Watch Video (34 min)"}},"primaryContentSections":[{"kind":"content","content":[{"anchor":"What-is-an-In-App-Purchase","level":2,"type":"heading","text":"What is an In-App Purchase"},{"inlineContent":[{"type":"text","text":"Digital content or service bought within app:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Consumable"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Non-consumable"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Non-renewable subscriptions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auto-renewable subscriptions"}]}]}],"type":"unorderedList"},{"anchor":"Auto-Renewable-Subscriptions","level":2,"type":"heading","text":"Auto-Renewable Subscriptions"},{"anchor":"Increased-proceeds","level":3,"type":"heading","text":"Increased proceeds"},{"inlineContent":[{"text":"Proceeds goes from 70% to 85% for subscriptions over a year.","type":"text"}],"type":"paragraph"},{"anchor":"Subscription-Groups","level":3,"type":"heading","text":"Subscription Groups"},{"inlineContent":[{"type":"text","text":"Only one subscription in a single group can be selected, if the app needs to support multiple active subscriptions at the same time, then multiple subscription groups should be created."}],"type":"paragraph"},{"inlineContent":[{"text":"In the same group, the level of subscription could be offered for the different subscriptions, thus, user could upgrade\/downgrade subscription level.","type":"text"}],"type":"paragraph"},{"anchor":"Territory-Pricing","level":2,"type":"heading","text":"Territory Pricing"},{"inlineContent":[{"type":"text","text":"Price can be customized for each territory."}],"type":"paragraph"},{"anchor":"Customer-Retention","level":3,"type":"heading","text":"Customer Retention"},{"inlineContent":[{"type":"text","text":"Using "},{"type":"emphasis","inlineContent":[{"text":"Push Notification","type":"text"}]},{"type":"text","text":" and highly customized "},{"type":"emphasis","inlineContent":[{"text":"Email","type":"text"}]},{"type":"text","text":" would be a good idea to keep attracting existing customers."}],"type":"paragraph"},{"anchor":"Preserve-Price","level":4,"type":"heading","text":"Preserve Price"},{"inlineContent":[{"text":"Multiple ways to manipulate the prices:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Initial price could be offered for the soft launch (Early adopters)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A different price could be offered after trial period."}]}]},{"content":[{"inlineContent":[{"text":"Increase the price without changing existing customers, after a certain date.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Increase the price without changing early adopters price, after a certain date."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Early adopters price could also be changed. (That will be effective immediately.)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Written-By","lev