/documentation\/wwdcnotes\/wwdc25-306-optimize-swiftui-performance-with-instruments"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"sampleCode","title":"Optimize SwiftUI performance with Instruments","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC25"},"references":{"WWDCNotes.png":{"type":"image","alt":null,"identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10160-Demystify-SwiftUI-performance":{"role":"sampleCode","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc23-10160-demystify-swiftui-performance","title":"Demystify SwiftUI performance","type":"topic","abstract":[{"text":"Learn how you can build a mental model for performance in SwiftUI and write faster, more efficient code. We’ll share some of the common causes behind performance issues and help you triage hangs and hitches in SwiftUI to create more responsive views in your app.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10160-Demystify-SwiftUI-performance"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"WWDC25.jpg":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25.jpg"}],"type":"image","identifier":"WWDC25.jpg","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-308-Optimize-CPU-performance-with-Instruments":{"role":"sampleCode","title":"Optimize CPU performance with Instruments","url":"\/documentation\/wwdcnotes\/wwdc25-308-optimize-cpu-performance-with-instruments","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-308-Optimize-CPU-performance-with-Instruments","abstract":[{"type":"text","text":"Learn how to optimize your app for Apple silicon with two new hardware-assisted tools in Instruments. We’ll start by covering how to profile your app, then dive deeper by showing every single function called with Processor Trace. We’ll also discuss how to use CPU Counters’ modes to analyze your code for CPU bottlenecks."}],"kind":"article","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10022-Demystify-SwiftUI":{"url":"\/documentation\/wwdcnotes\/wwdc21-10022-demystify-swiftui","title":"Demystify SwiftUI","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10022-Demystify-SwiftUI","abstract":[{"text":"Peek behind the curtain into the core tenets of SwiftUI philosophy: Identity, Lifetime, and Dependencies. Find out about common patterns, learn the principles that drive the framework, and discover how you can use them to guarantee correctness and performance for your app.","type":"text"}],"type":"topic","kind":"article"},"WWDC25-Icon.png":{"type":"image","alt":null,"identifier":"WWDC25-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-Icon.png"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10056-Compose-custom-layouts-with-SwiftUI":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10056-Compose-custom-layouts-with-SwiftUI","url":"\/documentation\/wwdcnotes\/wwdc22-10056-compose-custom-layouts-with-swiftui","type":"topic","abstract":[{"text":"SwiftUI now offers powerful tools to level up your layouts and arrange views for your app’s interface. We’ll introduce you to the Grid container, which helps you create highly customizable, two-dimensional layouts, and show you how you can use the Layout protocol to build your own containers with completely custom behavior. We’ll also explore how you can create seamless animated transitions between your layout types, and share tips and best practices for creating great interfaces.","type":"text"}],"kind":"article","title":"Compose custom layouts with SwiftUI","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10156-Explore-SwiftUI-animation":{"role":"sampleCode","type":"topic","abstract":[{"text":"Explore SwiftUI’s powerful animation capabilities and find out how these features work together to produce impressive visual effects. Learn how SwiftUI refreshes the rendering of a view, determines what to animate, interpolates values over time, and propagates context for the current transaction.","type":"text"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc23-10156-explore-swiftui-animation","title":"Explore SwiftUI animation","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10156-Explore-SwiftUI-animation"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10248-Analyze-hangs-with-Instruments":{"type":"topic","role":"sampleCode","title":"Analyze hangs with Instruments","abstract":[{"text":"User interface elements often mimic real-world interactions, including real-time responses. Apps with a noticeable delay in user interaction — a hang — can break that illusion and create frustration. We’ll show you how to use Instruments to analyze, understand, and fix hangs in your apps on all Apple platforms. Discover how you can efficiently navigate an Instruments trace document, interpret trace data, and record additional profiling data to better understand your specific hang.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10248-Analyze-hangs-with-Instruments","url":"\/documentation\/wwdcnotes\/wwdc23-10248-analyze-hangs-with-instruments","kind":"article"},"https://developer.apple.com/videos/play/wwdc2025/306":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/306","type":"download","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/306"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25":{"title":"WWDC25","abstract":[{"type":"text","text":"Xcode 26, Swift 6.2, iOS\/macOS\/tvOS\/visionOS 26."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"code":"Foundation Models","type":"codeVoice"},{"type":"text","text":", "},{"code":"AlarmKit","type":"codeVoice"},{"type":"text","text":", "},{"code":"PermissionKit","type":"codeVoice"},{"type":"text","text":", and more."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25","images":[{"type":"icon","identifier":"WWDC25-Icon.png"},{"type":"card","identifier":"WWDC25.jpg"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc25","role":"collectionGroup"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"}}}