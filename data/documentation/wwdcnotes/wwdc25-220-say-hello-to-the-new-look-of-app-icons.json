pe":"codeVoice"},{"type":"text","text":", and more."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25","images":[{"type":"icon","identifier":"WWDC25-Icon.png"},{"type":"card","identifier":"WWDC25.jpg"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc25","role":"collectionGroup"},"WWDC25-220-preview-icon.jpeg":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC25-220-preview-icon.jpeg","traits":["1x","light"]}],"identifier":"WWDC25-220-preview-icon.jpeg","alt":"Preview app icon example with frontal illustration style avoiding complex 3D perspectives"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-356-Get-to-know-the-new-design-system":{"role":"sampleCode","type":"topic","abstract":[{"text":"Dive deeper into the new design system to explore key changes to visual design, information architecture, and core system components. Learn how the system reshapes the relationship between interface and content, enabling you to create designs that are dynamic, harmonious, and consistent across devices, screen sizes, and input modes.","type":"text"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc25-356-get-to-know-the-new-design-system","title":"Get to know the new design system","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-356-Get-to-know-the-new-design-system"},"WWDC25-220-tinted-light-icons.jpeg":{"identifier":"WWDC25-220-tinted-light-icons.jpeg","type":"image","alt":"App icons with tinted glass effect on light background","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-220-tinted-light-icons.jpeg"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-361-Create-icons-with-Icon-Composer":{"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-361-Create-icons-with-Icon-Composer","url":"\/documentation\/wwdcnotes\/wwdc25-361-create-icons-with-icon-composer","type":"topic","abstract":[{"type":"text","text":"Learn how to use Icon Composer to make updated app icons for iOS, iPadOS, macOS, and watchOS. Find out how to export assets from your design tool of choice, add them to Icon Composer, apply real-time glass properties and other effects, and preview and adjust for different platforms and appearance modes."}],"title":"Create icons with Icon Composer","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-219-Meet-Liquid-Glass":{"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-219-Meet-Liquid-Glass","type":"topic","title":"Meet Liquid Glass","url":"\/documentation\/wwdcnotes\/wwdc25-219-meet-liquid-glass","kind":"article","abstract":[{"type":"text","text":"Liquid Glass unifies Apple platform design language while providing a more dynamic and expressive user experience. Get to know the design principles of Liquid Glass, explore its core optical and physical properties, and learn where to use it and why."}]},"VictorPuga.jpeg":{"identifier":"VictorPuga.jpeg","alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/VictorPuga.jpeg"}]},"WWDC25-220-freeform-weather-shortcuts-icons.jpeg":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC25-220-freeform-weather-shortcuts-icons.jpeg","traits":["1x","light"]}],"identifier":"WWDC25-220-freeform-weather-shortcuts-icons.jpeg","alt":"Freeform, Weather, and Shortcuts app icons demonstrating translucency and blur effects"},"WWDC25-220-contacts-icon.jpeg":{"identifier":"WWDC25-220-contacts-icon.jpeg","type":"image","alt":"Contacts app icon demonstrating layering and simplified design with liquid glass effect","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-220-contacts-icon.jpeg"}]},"WWDC25-220-intro.jpeg":{"identifier":"WWDC25-220-intro.jpeg","alt":"Realistic glass app icons elements in a table","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-220-intro.jpeg"}]},"WWDC25-220-mail-icon.jpeg":{"type":"image","variants":[{"u