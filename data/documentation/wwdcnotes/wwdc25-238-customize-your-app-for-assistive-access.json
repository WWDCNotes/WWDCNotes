{"kind":"article","variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc25-238-customize-your-app-for-assistive-access"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"]]},"sections":[],"abstract":[{"type":"text","text":"Assistive Access is a distinctive, focused iOS experience that makes it easier for people with cognitive disabilities to use iPhone and iPad independently. In iOS and iPadOS 26, you can customize your app when it’s running in Assistive Access to give people greater ease and independence. Learn how to tailor your app using the AssistiveAccess SwiftUI scene type, and explore the key design principles that can help you create a high-quality Assistive Access experience for everyone."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]},{"type":"heading","text":"Related Sessions","anchor":"Related-Sessions","level":2},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10032-Meet-Assistive-Access","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-256-Whats-new-in-SwiftUI"],"type":"links","style":"list"}],"kind":"content"}],"metadata":{"role":"sampleCode","title":"Customize your app for Assistive Access","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC25"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-238-Customize-your-app-for-Assistive-Access"},"sampleCodeDownload":{"action":{"type":"reference","overridingTitle":"Watch Video (15 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/238","isActive":true},"kind":"sampleDownload"},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10032-Meet-Assistive-Access":{"type":"topic","title":"Meet Assistive Access","abstract":[{"type":"text","text":"Learn how Assistive Access can help people with cognitive disabilities more easily use iPhone and iPad. Discover the design principles that guide Assistive Access and find out how the system experience adapts to lighten cognitive load. We’ll show you how Assistive Access works and what you can do to support this experience in your app."}],"kind":"article","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc23-10032-meet-assistive-access","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10032-Meet-Assistive-Access"},"WWDC25.jpg":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25.jpg"}],"identifier":"WWDC25.jpg"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25":{"url":"\/documentation\/wwdcnotes\/wwdc25","title":"WWDC25","role":"collectionGroup","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25","images":[{"type":"icon","identifier":"WWDC25-Icon.png"},{"type":"card","identifier":"WWDC25.jpg"}],"abstract":[{"type":"text","text":"Xcode 26, Swift 6.2, iOS\/macOS\/tvOS\/visionOS 26."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Foundation Models"},{"type":"text","text":", "},{"type":"codeVoice","code":"AlarmKit"},{"type":"text","text":", "},{"type":"codeVoice","code":"PermissionKit"},{"type":"text","text":", and more."}],"type":"topic","kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","type":"topic","role":"collection","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-256-Whats-new-in-SwiftUI":{"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc25-256-whats-new-in-swiftui","abstract":[{"type":"text","text":"Learn what’s new in SwiftUI to build great apps for any Apple platform. We’ll explore how to give your app a brand new look and feel with Liquid Glass. Discover how to boost performance with framework enhancements and new instruments, and integrate advanced capabilities like web content and rich text editing. We’ll also show you how SwiftUI is expanding to more places, including laying out views in three dimensions."}],"role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-256-Whats-new-in-SwiftUI","title":"What’s new in SwiftUI","kind":"article"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","title":"Learn More…"},"https://developer.apple.com/videos/play/wwdc2025/238":{"checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/238","type":"download","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2025\/238"},"WWDC25-Icon.png":{"identifier":"WWDC25-Icon.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC25-Icon.png","traits":["1x","light"]}]}}}