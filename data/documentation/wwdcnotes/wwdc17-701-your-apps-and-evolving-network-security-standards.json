{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-701-Your-Apps-and-Evolving-Network-Security-Standards","interfaceLanguage":"swift"},"metadata":{"title":"Your Apps and Evolving Network Security Standards","role":"sampleCode","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC17"},"sampleCodeDownload":{"action":{"isActive":true,"overridingTitle":"Read Transcript","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/701\/"},"kind":"sampleDownload"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","abstract":[{"type":"text","text":"Security standards are continuing to evolve to counter emerging threats, and so too must your apps if you want to best protect your users and their data. Learn about new developments in certificate handling, TLS, and certificate status checking on iOS, macOS, watchOS, and tvOS that impact your apps."}],"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference","isActive":true}],"type":"paragraph"},{"level":2,"anchor":"Related-Sessions","type":"heading","text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-702-Privacy-and-Your-Apps","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-707-Advances-in-Networking-Part-1","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-709-Advances-in-Networking-Part-2"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-701-your-apps-and-evolving-network-security-standards"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWDCNotes.png"}],"type":"topic","kind":"symbol","role":"collection","title":"WWDC Notes","url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"WWDC17.jpeg":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC17.jpeg","traits":["1x","light"]}],"alt":null,"identifier":"WWDC17.jpeg"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"type":"topic","kind":"article","role":"collectionGroup","title":"WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-707-Advances-in-Networking-Part-1":{"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc17-707-advances-in-networking-part-1","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-707-Advances-in-Networking-Part-1","title":"Advances in Networking, Part 1","role":"sampleCode","abstract":[{"type":"text","text":"Find out how Apple’s networking libraries and frameworks are taking advantage of new and improved protocols to deliver better connectivity and performance for your apps. In this first of two sessions, we’ll cover ECN, IPv6, Network Extensions, and Multipath protocols."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-709-Advances-in-Networking-Part-2":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-709-Advances-in-Networking-Part-2","abstract":[{"type":"text","text":"Learn about important improvements to URLSession. Find out how to use new URLSession APIs to better handle connectivity fluctuations, to schedule background session tasks, and to receive progress reports for session tasks. Plus, gain insights into valuable best practices, tips, and news about ongoing work with emerging network technologies."}],"kind":"article","type":"topic","title":"Advances in Networking, Part 2","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc17-709-advances-in-networking-part-2"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-702-Privacy-and-Your-Apps":{"title":"Privacy and Your Apps","url":"\/documentation\/wwdcnotes\/wwdc17-702-privacy-and-your-apps","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-702-Privacy-and-Your-Apps","role":"sampleCode","abstract":[{"text":"Protecting user privacy is a core principal in the Apple ecosystem. Learn what that means for the way you design and implement your apps, and learn about privacy-related changes, including new APIs, in the next versions of iOS, macOS, watchOS and tvOS.","type":"text"}],"kind":"article","type":"topic"},"WWDCNotes.png":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"identifier":"WWDCNotes.png"},"WWDC17-Icon.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17-Icon.png"}],"type":"image","identifier":"WWDC17-Icon.png"},"https://nonstrict.eu/wwdcindex/wwdc2017/701/":{"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/701\/","url":"https:\/\/n