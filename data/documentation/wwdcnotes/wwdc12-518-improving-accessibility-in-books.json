{"abstract":[{"type":"text","text":"Books are for everyone. Get an overview of the accessibility concerns facing readers on iOS and learn which components of your book can automatically leverage built-in accessibility features such as VoiceOver. Learn how to enhance rich media such as images or video for readers with visual impairments and explore how to improve the accessibility of custom HTML widgets with WAI-ARIA roles and attributes."}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc12-518-improving-accessibility-in-books"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12-518-Improving-Accessibility-in-Books","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"Improving Accessibility in Books","roleHeading":"WWDC12"},"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Read Transcript","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2012\/518\/","isActive":true,"type":"reference"}},"sections":[],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC12":{"abstract":[{"text":"iOS 6, macOS 10.8 (Mountain Lion).","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc12","images":[{"identifier":"WWDC12-Icon.png","type"