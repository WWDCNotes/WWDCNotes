lbars, discover optimization that speed up back-forward navigation, and more.","type":"text"}],"references":{"WWDC11.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC11.jpeg","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"WWDC11.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC11":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11","type":"topic","role":"collectionGroup","url":"\/documentation\/wwdcnotes\/wwdc11","abstract":[{"type":"text","text":"iOS 5, macOS 10.7 (Lion)."}],"kind":"article","images":[{"identifier":"WWDC11-Icon.png","type":"icon"},{"identifier":"WWDC11.jpeg","type":"card"}],"title":"WWDC11"},"WWDC11-Icon.png":{"identifier":"WWDC11-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC11-Icon.png","traits":["1x","light"]}],"alt":null,"type":"image"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"role":"collection","images":[{"identifier":"WWDCNotes.png","type":"icon"}],"abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"type":"topic","title":"WWDC Notes","kind":"symbol","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"WWDCNotes.png"},"https://nonstrict.eu/wwdcindex/wwdc2011/516/":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/516\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/516\/","checksum":null,"type":"download"}}}