{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11-516-Understanding-Layout-and-Gestures-in-Safari-on-iOS-and-Lion","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11"]]},"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/516\/","type":"reference","overridingTitle":"Open on WWDCIndex","isActive":true}},"abstract":[{"type":"text","text":"Safari on iOS was the first browser to deliver web content that responded to gestures such as panning, double-tapping, and pinching. Now, many of the basic principles behind gesture-friendly layout and gesture recognition have been carried over to Safari on Mac OS X Lion. See how to make web content that already looks great even better by learning the concepts behind gesture-enabled web layout.  Understand how scrollable content and fixed positioning works in zoom-able interfaces, learn best practices for handling overlay scrollbars, discover optimization that speed up back-forward navigation, and more."}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc11-516-understanding-layout-and-gestures-in-safari-on-ios-and-lion"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"Understanding Layout and Gestures in Safari on iOS and Lion","roleHeading":"WWDC11","modules":[{"name":"WWDC Notes"}],"role":"sampleCode"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}]}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","references":{"WWDCNotes.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"WWDC11-Icon.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC11-Icon.png","traits":["1x","light"]}],"identifier":"WWDC11-Icon.png","type":"image","alt":null},"https://nonstrict.eu/wwdcindex/wwdc2011/516/":{"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/516\/","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/516\/"},"WWDC11.jpeg":{"type":"image","identifier":"WWDC11.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC11.jpeg","traits":["1x","light"]}],"alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC11":{"abstract":[{"type":"text","text":"iOS 5, macOS 10.7 (Lion)."}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11","url":"\/documentation\/wwdcnotes\/wwdc11","kind":"article","images":[{"type":"icon","identifier":"WWDC11-Icon.png"},{"type":"card","identifier":"WWDC11.jpeg"}],"role":"collectionGroup","title":"WWDC11"}}}