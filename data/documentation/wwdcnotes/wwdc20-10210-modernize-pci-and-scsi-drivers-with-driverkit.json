 HAL interacts with AudioDriverKit and discover best practices for audio device drivers."}]},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"https://developer.apple.com/videos/play/wwdc2020/10210":{"type":"download","url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2020\/10210","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2020\/10210","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20":{"title":"WWDC20","url":"\/documentation\/wwdcnotes\/wwdc20","images":[{"identifier":"WWDC20-Icon.png","type":"icon"},{"identifier":"WWDC20.jpeg","type":"card"}],"role":"collectionGroup","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20","abstract":[{"type":"text","text":"Xcode 12, Swift 5.3, iOS 14, macOS 11 (Big Sur), tvOS 14, watchOS 7."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"code":"WidgetKit","type":"codeVoice"},{"type":"text","text":", "},{"code":"StoreKit Testing","type":"codeVoice"},{"type":"text","text":", and more."}],"type":"topic","kind":"article"},"WWDC20.jpeg":{"alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC20.jpeg","traits":["1x","light"]}],"identifier":"WWDC20.jpeg","type":"image"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-702-System-Extensions-and-DriverKit":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-702-System-Extensions-and-DriverKit","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc19-702-system-extensions-and-driverkit","type":"topic","title":"System Extensions and DriverKit","abstract":[{"type":"text","text":"One of the next steps in modernizing and improving the security and reliability of macOS is to provide a better architecture for kernel extensions and drivers.  Learn how to make this transition with System Extensions and DriverKit."}]},"WWDCNotes.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png","alt":null},"WWDC20-Icon.png":{"identifier":"WWDC20-Icon.png","alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC20-Icon.png","traits":["1x","light"]}]}}}