{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-209-creating-complications-with-clockkit"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"metadata":{"role":"sampleCode","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC15","title":"Creating Complications with ClockKit"},"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"anchor":"Related-Sessions","type":"heading","level":2,"text":"Related Sessions"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-253-Exploring-Tinted-Graphic-Complications"]}],"kind":"content"}],"sampleCodeDownload":{"action":{"isActive":true,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/209\/","overridingTitle":"Open on WWDCIndex","type":"reference"},"kind":"sampleDownload"},"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-209-Creating-Complications-with-ClockKit"},"abstract":[{"type":"text","text":"Making your app’s information available to users on Apple Watch is even easier in watchOS 2. Learn how to create custom complications for Watch faces using the new ClockKit framework and see how to provide data through numerous templates using text and images."}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-253-Exploring-Tinted-Graphic-Complicatio