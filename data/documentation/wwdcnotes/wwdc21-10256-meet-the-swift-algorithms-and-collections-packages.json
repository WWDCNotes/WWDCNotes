nced-models-with-Create-ML-Components":{"title":"Compose advanced models with Create ML Components","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10020-Compose-advanced-models-with-Create-ML-Components","url":"\/documentation\/wwdcnotes\/wwdc22-10020-compose-advanced-models-with-create-ml-components","kind":"article","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"Take your custom machine learning models to the next level with Create ML Components. We’ll show you how to work with temporal data like video or audio and compose models that can count repetitive human actions or provide advanced sound classification. We’ll also share best practices on using incremental fitting to speed up model training with new data."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-110355-Meet-Swift-Async-Algorithms":{"title":"Meet Swift Async Algorithms","abstract":[{"type":"text","text":"Discover the latest open source Swift package from Apple: Swift Async Algorithms. We’ll explore algorithms from this package that you can use with AsyncSequence, including zip, merge, and throttle. Follow along with us as we use these algorithms to build a great messaging app. We’ll also share best practices for combining multiple AsyncSequences and using the Swift Clock type to work with values over time."}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc22-110355-meet-swift-async-algorithms","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-110355-Meet-Swift-Async-Algorithms"},"WWDC21.jpeg":{"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC21.jpeg","traits":["1x","light"]}],"identifier":"WWDC21.jpeg","alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"type":"text","text":"Contributions are welcome!"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Contributions are welcome!"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"https://github.com/apple/swift-algorithms/blob/195e0316d7ba71e134d0f6c677f64b4db6160c46/Guides/Chunked.md":{"identifier":"https:\/\/github.com\/apple\/swift-algorithms\/blob\/195e0316d7ba71e134d0f6c677f64b4db6160c46\/Guides\/Chunked.md","titleInlineContent":[{"type":"codeVoice","code":"chunked(by:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"chunked(on:)"},{"type":"text","text":", "},{"type":"codeVoice","code":"chunks(ofCount:)"}],"type":"link","title":"chunked(by:), chunked(on:), chunks(ofCount:)","url":"https:\/\/github.com\/apple\/swift-algorithms\/blob\/195e0316d7ba71e134d0f6c677f64b4db6160c46\/Guides\/Chunked.md"},"zntfdr":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/zntfdr.jpeg"}],"identifier":"zntfdr","alt":"Profile image of zntfdr"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10217-Explore-numerical-computing-in-Swift":{"title":"Explore numerical computing in Swift","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10217-Explore-numerical-computing-in-Swift","url":"\/documentation\/wwdcnotes\/wwdc20-10217-explore-numerical-computing-in-swift","kind":"article","type":"topic","role":"sampleCode","abstract":[{"text":"Meet Swift Numerics: a new Swift package for computational mathematics. Take a tour of the protocols and types available in the package and find out how you can use them to write generic code. We’ll also show you how and when to use the new Float16 type to improve performance and reduce memory usage.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21":{"url":"\/documentation\/wwdcnotes\/wwdc21","type":"topic","images":[{"type":"icon","identifier":"WWDC21-Icon.png"},{"type":"card","identifier":"WWDC21.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21","title":"WWDC21","kind":"article","role":"collectionGroup","abstract":[{"text":"Xcode 13, Swift 5.5, iOS 15, macOS 12 (Monterey), tvOS 15, watchOS 8.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"MusicKit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"DocC","type":"codeVoice"},{"type":"text","text":", "},{"code":"StoreKit 2","type":"codeVoice"},{"type":"text","text":", and more."}]},"zntfdr.jpeg":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/zntfdr.jpeg"}],"identifier":"zntfdr.jpeg","alt":null},"https://github.com/apple/swift-collections/blob/108ac4fa4ef7f2622b97a1f5dd92a3e0c6857c60/Documentation/Deque.md":{"titleInlineContent":[{"text":"Double-ended queue ","type":"text"},{"code":"Deque<Element>","type":"codeVoice"}],"type":"link","url":"https:\/\/github.com\/apple\/swift-collections\/blob\/108ac4fa4ef7f2622b97a1f5dd92a3e0c6857c60\/Documentation\/Deque.md","identifier":"https:\/\/github.com\/apple\/swift-collections\/blob\/108ac4fa4ef7f2622b97a1f5dd92a3e0c6857c60\/Documentation\/Deque.md","title":"Double-ended queue Deque<Element>"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10192-Whats-new-in-Swift":{"title":"What‘s new in Swift","abstract":[{"text":"Join us for an update on Swift. Discover the latest language advancements that make your code easier to read and write. Explore the growing number of APIs available as Swift packages. And we’ll introduce you to Swift’s async\/await syntax, structured concurrency, and actors.","type":"text"}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc21-10192-whats-new-in-swift","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10192-Whats-new-in-Swift"},"https://developer.apple.com/wwdc21/10256":{"url":"https:\/\/developer.apple.com\/wwdc21\/10256","type":"download","identifier":"https:\/\/developer.apple.com\/wwdc21\/10256","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-223-Embracing-Algorithms":{"title":"Embracing Algorithms","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-223-Embracing-Algorithms","url":"\/documentation\/wwdcnotes\/wwdc18-223-embracing-algorithms","kind":"article","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"When you imagine building a new app, what do you think about? Models, views, and controllers deserve their prominent place in the design process, but we don’t often give the same attention to the underlying work our apps need to do. Understand how to identify and optimize the algorithms in your app, and discover how implementing algorithms as generic protocol extensions results in efficient, effective, and maintainable code."}]}}}