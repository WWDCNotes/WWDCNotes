{"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc17-201-whats-new-in-cocoa-touch"]}],"abstract":[{"text":"iOS 11 enhances the Cocoa Touch frameworks for making next generation apps on iOS. Learn about drag and drop, file management, document browser, updates to the navigation and tab bars, app safe areas, swipe actions and API refinements. Find out which sessions you won’t want to miss throughout the week.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-201-Whats-New-in-Cocoa-Touch"},"sampleCodeDownload":{"action":{"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/201\/","isActive":true,"overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"What’s New in Cocoa Touch","roleHeading":"WWDC17"},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"text":"Related Sessions","anchor":"Related-Sessions","level":2,"type":"heading"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-209-Whats-New-in-tvOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-211-Touch-Bar-Fundamentals"]}],"kind":"content"}],"references":{"WWDC17.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17.jpeg"}],"type":"image","identifier":"WWDC17.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-209-Whats-New-in-tvOS":{"type":"topic","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17-209-whats-new-in-tvos","title":"What’s New in tvOS","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-209-Whats-New-in-tvOS","abstract":[{"text":"tvOS allows you to deliver incredible apps and games for the big screen with the tvOS SDK. Gain insights into new tvOS 11 capabilities and enhancements such as Right-to-Left support, image overlays, background app updates, and user interface style improvements. And with the new AVKit capabilities you can take your media playback experience even further.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-211-Touch-Bar-Fundamentals":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-211-Touch-Bar-Fundamentals","type":"topic","kind":"article","role":"sampleCode","abstract":[{"type":"text","text":"Touch Bar replaces the function keys that have long occupied the top of your keyboard with a versatile MultiTouch input device that features a Retina display. AppKit provides powerful APIs to let you easily leverage the power of Touch Bar in your applications. Learn how to use Touch Bar in your application to add context sensitive commands and flexible content to your user experience. This session will cover the basic concepts, design considerations, standard controls, IB support, and API that you will need to get started using Touch Bar."}],"title":"Touch Bar Fundamentals","url":"\/documentation\/wwdcnotes\/wwdc17-211-touch-bar-fundamentals"},"WWDCNotes.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"text":"Learn More…","type":"text"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}],"role":"collectionGroup","kind":"article","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"type":"topic","title":"WWDC17","url":"\/documentation\/wwdcnotes\/wwdc17"},"WWDC17-Icon.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17-Icon.png"}],"type":"image","identifier":"WWDC17-Icon.png"},"https://nonstrict.eu/wwdcindex/wwdc2017/201/":{"type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/201\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/201\/","checksum":null},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"}}}