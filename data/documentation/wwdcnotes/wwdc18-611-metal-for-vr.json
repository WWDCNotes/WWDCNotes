WWDC18-Icon.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC18-Icon.png","traits":["1x","light"]}],"type":"image","identifier":"WWDC18-Icon.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"https://nonstrict.eu/wwdcindex/wwdc2018/611/":{"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/611\/","type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/611\/","checksum":null},"WWDC18.jpeg":{"identifier":"WWDC18.jpeg","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC18.jpeg","traits":["1x","light"]}],"type":"image"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"title":"Learn More…"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-603-VR-with-Metal-2":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-603-VR-with-Metal-2","type":"topic","title":"VR with Metal 2","role":"sampleCode","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17-603-vr-with-metal-2","abstract":[{"text":"Metal 2 provides powerful and specialized support for Virtual Reality (VR) rendering and external GPUs. Get details about adopting these emerging technologies within your Metal 2-based apps and games on macOS High Sierra. Walk through integrating Metal 2 with the SteamVR SDK and learn about efficiently rendering to a VR headset. Understand how external GPUs take macOS graphics to a whole new level and see how to prepare your apps to take advantage of their full potential.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-612-Metal-Game-Performance-Optimization":{"url":"\/documentation\/wwdcnotes\/wwdc18-612-metal-game-performance-optimization","type":"topic","abstract":[{"type":"text","text":"Realize the full potential of your Metal-based games by tackling common issues that cause frame rate slowdowns, stutters, and stalls. Discover how to clear up jitter and maintain a silky-smooth frame rate with simple changes in frame pacing. Get introduced to new tools for analyzing rendering passes and pinpoint expensive or unexpected work. Learn how to avoid thread stalls and get specific advice about handling thermal notifications."}],"title":"Metal Game Performance Optimization","role":"sampleCode","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-612-Metal-Game-Performance-Optimization"},"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image","identifier":"WWDCNotes.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"type":"topic","abstract":[{"text":"Xcode 10, Swift 4.2, iOS 12, macOS 10.14 (Mojave), tvOS 12, watchOS 5.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc18","kind":"article","images":[{"type":"icon","identifier":"WWDC18-Icon.png"},{"type":"card","identifier":"WWDC18.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18","role":"collectionGroup","title":"WWDC18"}}}