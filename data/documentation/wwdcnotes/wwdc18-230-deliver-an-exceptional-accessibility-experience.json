{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc18-230-deliver-an-exceptional-accessibility-experience"]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18"]]},"metadata":{"modules":[{"name":"WWDC Notes"}],"title":"Deliver an Exceptional Accessibility Experience","role":"sampleCode","roleHeading":"WWDC18"},"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"anchor":"Related-Sessions","type":"heading","level":2,"text":"Related Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10035-Perform-accessibility-audits-for-your-app","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-238-Accessibility-in-SwiftUI","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-226-VoiceOver-App-Testing-Beyond-The-Visuals","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-806-Design-For-Everyone"],"type":"links","style":"list"}],"kind":"content"}],"sampleCodeDownload":{"action":{"overridingTitle":"Watch Video (40 min)","isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/230"},"kind":"sampleDownload"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"abstract":[{"type":"text","text":"Go beyond the basics and create apps with an exceptional accessibility experience. Learn how to design elements that appear in your app for maximum clarity and accessibility. Discover how to enhance the way users interact with your app even when presenting custom views, or drawing complex UI."}],"kind":"article","identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-230-Deliver-an-Exceptional-Accessibility-Experience","interfaceLanguage":"swift"},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-226-VoiceOver-App-Testing-Beyond-The-Visuals":{"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-226-VoiceOver-App-Testing-Beyond-The-Visuals","kind":"article","role":"sampleCode","title":"VoiceOver: App Testing Beyond The Visuals","url":"\/documentation\/wwdcnotes\/wwdc18-226-voiceover-app-testing-beyond-the-visuals","abstract":[{"type":"text","text":"VoiceOver provides spoken descriptions and braille output of onscreen elements. Learn how to go beyond the visuals to identify VoiceOver and functional issues to help improve the experience for all users."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-806-Design-For-Everyone":{"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-806-Design-For-Everyone","kind":"article","role":"sampleCode","title":"Design For Everyone","url":"\/documentation\/wwdcnotes\/wwdc17-806-design-for-everyone","abstract":[{"type":"text","text":"By understanding the range of abilities and capabilities of the people who use our apps, you can design robust apps that work for everyone. Learn how designing for accessibility and inclusiveness can do social good, widen participation, and enable everyone to benefit."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"role":"collectionGroup","images":[{"type":"icon","identifier":"WWDC18-Icon.png"},{"type":"card","identifier":"WWDC18.jpeg"}],"type":"topic","title":"WWDC18","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18","abstract":[{"type":"text","text":"Xcode 10, Swift 4.2, iOS 12, macOS 10.14 (Mojave), tvOS 12, watchOS 5."}],"url":"\/documentation\/wwdcnotes\/wwdc18","kind":"article"},"WWDC18.jpeg":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC18.jpeg"}],"identifier":"WWDC18.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC23-10035-Perform-accessibility-audits-for-your-app":{"role":"sampleCode","abstract":[{"text":"Discover how you can test your app for accessibility with every build. Learn how to perform automated audits for accessibility using XCTest and find out how to interpret the results. We’ll also share enhancements to the accessibility API that can help you improve UI test coverage.","type":"text"}],"title":"Perform accessibility audits for your app","url":"\/documentation\/wwdcnotes\/wwdc23-10035-perform-accessibility-audits-for-your-app","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC23-10035-Perform-accessibility-audits-for-your-app","kind":"article","type":"topic"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"role":"collection","images":[{"identifier":"WWDCNotes.png","type":"icon"}],"abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"type":"topic","title":"WWDC Notes","kind":"symbol","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-238-Accessibility-in-SwiftUI":{"kind":"article","title":"Accessibility in SwiftUI","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc19-238-accessibility-in-swiftui","abstract":[{"text":"Making your app accessible is critical, but just as important is designing a fantastic accessibility experience. Learn what makes a great experience and how to make your app understandable, navigable, and interactable. SwiftUI builds accessibility into your app for you! Discover how much you get with no extra adoption, like accessible images and controls. Identify where you can add supplemental accessibility information with the new SwiftUI Accessibility API, which gives you the tools to add information to elements such as labels, values, and hints.","type":"text"}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-238-Accessibility-in-SwiftUI"},"WWDCNotes.png":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png"},"WWDC18-Icon.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC18-Icon.png"}],"identifier":"WWDC18-Icon.png"},"https://developer.apple.com/videos/play/wwdc2018/230":{"type":"download","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/230","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2018\/230"}}}