-process-of-inclusive-design"]}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC25":{"images":[{"identifier":"WWDC25-Icon.png","type":"icon"},{"identifier":"WWDC25.jpg","type":"card"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc25","abstract":[{"text":"Xcode 26, Swift 6.2, iOS\/macOS\/tvOS\/visionOS 26.","type":"text"},{"text":" ","type":"text"},{"text":"New APIs: ","type":"text"},{"code":"Foundation Models","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AlarmKit","type":"codeVoice"},{"text":", ","type":"text"},{"code":"PermissionKit","type":"codeVoice"},{"text":", and more.","type":"text"}],"title":"WWDC25","role":"collectionGroup","type":"topic"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","role":"collection","images":[{"identifier":"WWDCNotes.png","type":"icon"}],"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","kind":"symbol","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25-224-Evaluate-your-app-for-Accessibility-Nutrition-Labels":{"title":"Evaluate your app for Accessibility Nutrition Labels","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc25-224-evaluate-your-app-for-accessibility-nutrition-labels","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25-224-Evaluate-your-app-for-Accessibility-Nutrition-Labels","kind":"article","abstract":[{"text":"Use Accessibility Nutrition Labels on your App Store product page to highlight the accessibility features supported by your app. You’ll learn how to evaluate your app’s accessibility features — such as VoiceOver, Larger Text, Captions, and more — and choose accurate and informative Accessibility Nutrition Labels. You’ll also find out how to approach accessibility throughout the design phase.","type":"text"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10275-The-practice-of-inclusive-design":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10275-The-practice-of-inclusive-design","url":"\/documentation\/wwdcnotes\/wwdc21-10275-the-practice-of-inclusive-design","abstract":[{"text":"An inclusive app or game is not only usable by different people, but also welcomes people from diverse backgrounds and perspectives. Discover how you can design inclusive content for your interface, language, imagery, and marketing materials and support the broadest possible range of people with your app or game.","type":"text"}],"type":"topic","role":"sampleCode","title":"The practice of inclusive design","kind":"article"},"WWDC25.jpg":{"identifier":"WWDC25.jpg","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC25.jpg","traits":["1x","light"]}]},"WWDC25-Icon.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC25-Icon.png"}],"type":"image","identifier":"WWDC25-Icon.png","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10304-The-process-of-inclusive-design":{"role":"sampleCode","type":"topic","kind":"article","abstract":[{"type":"text","text":"Discover how you can deliver inclusive apps that can foster amazing experiences for everyone who uses your software. We’ll take you through best practices for creating and empowering diverse teams and explore how inclusivity influences every stage of the design and development process."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10304-The-process-of-inclusive-design","url":"\/documentation\/wwdcnotes\/wwdc21-10304-the-process-of-inclusive-design","title":"The process of inclusive design"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/