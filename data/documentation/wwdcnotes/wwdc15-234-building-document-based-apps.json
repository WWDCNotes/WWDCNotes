{"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC15","title":"Building Document Based Apps","role":"sampleCode"},"sampleCodeDownload":{"action":{"isActive":true,"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/234\/","overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"abstract":[{"text":"UIDocument is a robust way to model user-generated content in your app. See how to easily integrate your app’s documents with iCloud, file extensions, and document browsers. Learn how to build a document-based app from the ground up.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-234-Building-Document-Based-Apps","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","primaryContentSections":[{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"level":2,"anchor":"Related-Sessions","text":"Related Sessions","type":"heading"},{"style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-231-Whats-New-in-Core-Spotlight-for-iOS-and-macOS","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-243-File-Provider-Enhancements"],"type":"links"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-234-building-document-based-apps"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"https://nonstrict.eu/wwdcindex/wwdc2015/234/":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/234\/","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/234\/","type":"download"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"WWDC15.jpeg":{"identifier":"WWDC15.jpeg","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-243-File-Provider-Enhancements":{"kind":"article","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-243-File-Provider-Enhancements","url":"\/documentation\/wwdcnotes\/wwdc17-243-file-provider-enhancements","abstract":[{"type":"text","text":"File providers are front and center in the new Files app and system-provided document browser, empowering users to work on their documents in the cloud without the confusion of multiple copies or different versions. Hear details about how your cloud services can integrate with this new functionality. See how to provide an efficient and seamless user experience. If you are an app developer, learn the details about how file providers work and hear about exciting opportunities to take advantage of service-specific APIs from cloud storage providers."}],"role":"sampleCode","title":"File Provider Enhancements"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-231-Whats-New-in-Core-Spotlight-for-iOS-and-macOS":{"url":"\/documentation\/wwdcnotes\/wwdc17-231-whats-new-in-core-spotlight-for-ios-and-macos","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-231-Whats-New-in-Core-Spotlight-for-iOS-and-macOS","title":"What’s New in Core Spotlight for iOS and macOS","kind":"article","role":"sampleCode","abstract":[{"type":"text","text":"Fundamental to the iOS Search Experience, Core Spotlight is now available on macOS. Using the same APIs that are available for iOS, Core Spotlight lets you index your app’s contents without requiring on-disk files. Learn how to provide rich custom Quick Look previews on both macOS and iOS so your users can see the content right in their search results. Get details about how your Core Spotlight items on iOS can participate in the new Drag and Drop feature."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc15","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}],"title":"WWDC15"},"WWDC15-Icon.png":{"type":"image","identifier":"WWDC15-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC15-Icon.png","traits":["1x","light"]}]},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]}}}