{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-305-Whats-New-in-iTunes-Connect"},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"text":"Related Sessions","level":2,"type":"heading","anchor":"Related-Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-204-iMessage-Apps-and-Stickers-Part-1","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-224-iMessage-Apps-and-Stickers-Part-2","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-301-Introducing-Expanded-Subscriptions-in-iTunes-Connect","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-702-Using-Store-Kit-for-InApp-Purchases-with-Swift-3"],"type":"links","style":"list"}]}],"sections":[],"metadata":{"title":"What’s New in iTunes Connect","roleHeading":"WWDC16","role":"sampleCode","modules":[{"name":"WWDC Notes"}]},"sampleCodeDownload":{"action":{"overridingTitle":"Open on WWDCIndex","type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/305\/","isActive":true},"kind":"sampleDownload"},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc16-305-whats-new-in-itunes-connect"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"iTunes Connect has been updated to make your experience with delivering apps to the App Store even better. Learn about time-saving improvements to managing screenshots, new ways to stay up to date with the iTunes Connect for iOS app, and upcoming features to help you gain insights into your data in App Analytics.","type":"text"}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16","kind":"article","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","role":"collectionGroup","title":"WWDC16"},"https://nonstrict.eu/wwdcindex/wwdc2016/305/":{"type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/305\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/305\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-224-iMessage-Apps-and-Stickers-Part-2":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-224-iMessage-Apps-and-Stickers-Part-2","abstract":[{"type":"text","text":"Messages apps allow people to collaborate by using your app. Learn how people can work together to accomplish a task within the conversation. Customize the appearance of the messages your app can send. Learn about how to manage your app state in one-to-one and group conversations to provide an engaging and collaborative experience."}],"url":"\/documentation\/wwdcnotes\/wwdc16-224-imessage-apps-and-stickers-part-2","role":"sampleCode","title":"iMessage Apps and Stickers, Part 2","type":"topic","kind":"article"},"WWDC16-Icon.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}],"identifier":"WWDC16-Icon.png","type":"image"},"WWDCNotes.png":{"alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-702-Using-Store-Kit-for-InApp-Purchases-with-Swift-3":{"abstract":[{"text":"The StoreKit API allows apps to request payment for additional functionality or content. Hear about the latest changes to StoreKit including Swift 3.0 APIs, updates to Subscriptions and using StoreKit with iMessage apps. Learn best practices for receipt management and Sandbox testing.","type":"text"}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-702-Using-Store-Kit-for-InApp-Purchases-with-Swift-3","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-702-using-store-kit-for-inapp-purchases-with-swift-3","type":"topic","title":"Using Store Kit for In-App Purchases with Swift 3"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"link","titleInlineContent":[{"text":"Learn More…","type":"text"}],"title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-301-Introducing-Expanded-Subscriptions-in-iTunes-Connect":{"title":"Introducing Expanded Subscriptions in iTunes Connect","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-301-introducing-expanded-subscriptions-in-itunes-connect","kind":"article","role":"sampleCode","abstract":[{"text":"See what’s new in subscriptions. Learn how our improvements give you more flexibility and control over pricing, and provide powerful incentives to engage and retain your customers.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-301-Introducing-Expanded-Subscriptions-in-iTunes-Connect"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-204-iMessage-Apps-and-Stickers-Part-1":{"type":"topic","role":"sampleCode","abstract":[{"text":"Messages allows your apps to create an expressive experience within a conversation. Get an overview of the iMessage App architecture. See how Xcode can easily create a simple sticker pack with your art. Learn how to make an iMessage app that has a custom sticker grid and can make any image you create into a sticker. Go beyond the basic sticker and create animated stickers. Learn how to perfect your iMessage app presentation and layout.","type":"text"}],"title":"iMessage Apps and Stickers, Part 1","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-204-iMessage-Apps-and-Stickers-Part-1","url":"\/documentation\/wwdcnotes\/wwdc16-204-imessage-apps-and-stickers-part-1","kind":"article"},"WWDC16.jpeg":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"identifier":"WWDC16.jpeg","type":"image"}}}