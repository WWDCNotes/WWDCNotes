act":[{"type":"text","text":"Session notes shared by the community for the community."}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-103-Apple-Design-Awards":{"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-103-Apple-Design-Awards","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-103-apple-design-awards","title":"Apple Design Awards","abstract":[{"text":"Join us for an unforgettable award ceremony celebrating developers and their outstanding work. The 2018 Apple Design Awards recognize state of the art iOS, macOS, watchOS, and tvOS apps that reflect excellence in design and innovation.","type":"text"}],"role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC19-104-Apple-Design-Awards":{"abstract":[{"text":"Join us for an unforgettable award ceremony celebrating developers and their outstanding work. The 2019 Apple Design Awards recognize state of the art iOS, macOS, watchOS, and tvOS apps that reflect excellence in design and innovation.","type":"text"}],"type":"topic","role":"sampleCode","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC19-104-Apple-Design-Awards","url":"\/documentation\/wwdcnotes\/wwdc19-104-apple-design-awards","title":"Apple Design Awards"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-801-The-Qualities-of-Great-Design":{"type":"topic","role":"sampleCode","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-801-the-qualities-of-great-design","abstract":[{"text":"Great Design isn’t magic, it is crafted with care by real people. Explore the characteristics of great design through the voices of designers from Apple and our developer community. Learn how they take inspiration from everyday life, conceive and refine ideas, and push themselves to design apps and games that can stand the test of time.","type":"text"}],"title":"The Qualities of Great Design","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-801-The-Qualities-of-Great-Design"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-20022-The-winners-of-the-2020-Apple-Design-Awards":{"type":"topic","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc20-20022-the-winners-of-the-2020-apple-design-awards","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-20022-The-winners-of-the-2020-Apple-Design-Awards","role":"sampleCode","abstract":[{"text":"Join us as we surprise the 2020 winners of the Apple Design Awards. The Apple Design Awards recognize excellence in design and innovation for apps and games across all of Apple’s platforms.","type":"text"}],"title":"The winners of the 2020 Apple Design Awards"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-802-Essential-Design-Principles":{"type":"topic","kind":"article","abstract":[{"type":"text","text":"Design principles are the key to understanding how design serves human needs for safety, meaning, achievement and beauty. Learn what these principles are and how they can help you design more welcoming, understandable, empowering and gratifying user experiences."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-802-Essential-Design-Principles","role":"sampleCode","title":"Essential Design Principles","url":"\/documentation\/wwdcnotes\/wwdc17-802-essential-design-principles"}}}