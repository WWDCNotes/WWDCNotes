{"sections":[],"kind":"article","sampleCodeDownload":{"action":{"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/234\/","isActive":true,"overridingTitle":"Open on WWDCIndex"},"kind":"sampleDownload"},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true,"type":"reference"}],"type":"paragraph"},{"text":"Related Sessions","anchor":"Related-Sessions","level":2,"type":"heading"},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-209-Getting-the-Most-Out-of-HealthKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-237-Getting-Started-with-CareKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-714-Networking-for-the-Modern-Internet"]}]}],"metadata":{"roleHeading":"WWDC16","modules":[{"name":"WWDC Notes"}],"title":"What’s New in ResearchKit","role":"sampleCode"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc16-234-whats-new-in-researchkit"]}],"abstract":[{"text":"ResearchKit is an open source framework you can use to build compelling apps that gather and present meaningful data used in medical research. Learn about new capabilities, how to create and extend surveys, how to create active tasks that use touch or other built-in and third-party accessory features, and how to effectively participate in the community.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16"]]},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-234-Whats-New-in-ResearchKit","interfaceLanguage":"swift"},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-237-Getting-Started-with-CareKit":{"type":"topic","title":"Getting Started with CareKit","abstract":[{"text":"CareKit is a new open source framework designed to help you create personal care apps that can monitor, present and share personal health information. Learn how to create and extend Care Cards and an Insight Dashboard, and to package information for sharing with families or professional caregivers.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-237-Getting-Started-with-CareKit","url":"\/documentation\/wwdcnotes\/wwdc16-237-getting-started-with-carekit","kind":"article","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-714-Networking-for-the-Modern-Internet":{"title":"Networking for the Modern Internet","abstract":[{"type":"text","text":"The next wave of the Internet’s evolution is happening now. You’ll learn best practices for supporting IPv6, restricting cellular usage, and using Quality of Service to create a fast lane for your iOS apps. Discover how to support a multilingual Internet by using UTF-8, and how new internationalized domain names and email addresses affect you."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-714-Networking-for-the-Modern-Internet","kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16-714-networking-for-the-modern-internet","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"abstract":[{"type":"text","text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3."}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc16","kind":"article","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","role":"collectionGroup","title":"WWDC16"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"WWDC16-Icon.png":{"identifier":"WWDC16-Icon.png","alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC16-Icon.png","traits":["1x","light"]}]},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"WWDCNotes.png":{"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"WWDCNotes.png"},"https://nonstrict.eu/wwdcindex/wwdc2016/234/":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/234\/","type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/234\/"},"WWDC16.jpeg":{"alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC16.jpeg","traits":["1x","light"]}],"type":"image","identifier":"WWDC16.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-209-Getting-the-Most-Out-of-HealthKit":{"abstract":[{"text":"HealthKit offers more than ever to developers joining in Apple’s vibrant health and fitness ecosystem. Discover new ways to integrate the popular activity-tracking features of Apple Watch with your own app. Learn how to contribute to an even more complete picture of users’ health data by reading and writing Health Documents from your organization. Review core concepts for working with HealthKit and explore best practices for managing data to ensure your users enjoy a seamless experience.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-209-Getting-the-Most-Out-of-HealthKit","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc16-209-getting-the-most-out-of-healthkit","type":"topic","kind":"article","title":"Getting the Most Out of HealthKit"}}}