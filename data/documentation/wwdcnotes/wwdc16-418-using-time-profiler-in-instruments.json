{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Intro-to-profiling","level":2,"type":"heading","text":"Intro to profiling"},{"inlineContent":[{"type":"text","text":"How much and what kind of work is my app doing?"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The Call Tree displays counter of each calls, it doesn’t measure the duration of each calls, even ignore\/lose some quick\/short calls. So, it shows long running calls and the most repetitive calls."}],"type":"paragraph"},{"anchor":"Going-faster","level":2,"type":"heading","text":"Going faster"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Focused on an area of high CPU usage","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Zoom and Select area will help focus on the “Problems”, which filters out all other unrelevant calls.","type":"text"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Examined the call tree, looking for where the work was happening"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Walked back to our code"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Inspected our code","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Made it faster","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Verified the changes"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Saved the user’s time","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Doing-less","level":2,"type":"heading","text":"Doing less"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Focused on low, but "},{"type":"strong","inlineContent":[{"type":"text","text":"unexpected"}]},{"type":"text","text":" CPU usage"}]}]},{"content":[{"inlineContent":[{"text":"Examined the call tree","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Determined the frameworks involved"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Stopped doing unnecessary work","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Verified the changes","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Improved battery life"}],"type":"paragraph"}]}]},{"anchor":"Improving-responsiveness","level":2,"type":"heading","text":"Improving responsiveness"},{"anchor":"Problem-The-main-thread-does-all-the-UI-work","level":3,"type":"heading","text":"Problem: The main thread does all the UI work"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Runloop waiting for events"}]}]},{"content":[{"inlineContent":[{"text":"Sends events to your UIApplication instance","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Passes through the responder chain","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your code gets invoked","type":"text"}]}]}]},{"anchor":"Phenomenon-When-busy-the-main-thread-cant-process-events","level":3,"type":"heading","text":"Phenomenon: When busy, the main thread can’t process events"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The queue backs up","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Stuttering and hiccups"}]}]},{"content":[{"inlineContent":[{"text":"App becomes unresponsive","type":"text"}],"type":"paragraph"}]}]},{"anchor":"What-to-Do-Keep-your-main-thread-Free","level":3,"type":"heading","text":"What to Do: Keep your main thread Free"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Examined the CPU spikes"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Focused on the main thread","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Identified non-UI work happening on the main thread"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Distributed the work across multiple threads"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verified the changes"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Achieved a better user experience"}]}]}]},{"anchor":"Tips","level":2,"type":"heading","text":"Tips"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Always profile release builds","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Always profile on the device"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Run with old devices","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Use large data sets where it makes sense","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Look for ","type":"text"},{"inlineContent":[{"text":"poorly scaling code","type":"text"}],"type":"strong"},{"text":" (O(n^2), etc.)","type":"text"}],"type":"paragraph"}]}]},{"anchor":"Summary","level":2,"type":"heading","text":"Summary"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Optimize High CPU usage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Remove Unexpected CPU usage","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Move heavy work away from main thread","type":"text"}]}]}]},{"anchor":"Written-By","level":2,"type":"heading","text":"Written By"},{"numberOfColumns":5,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"antonio081014"}]}]},{"size":4,"content":[{"level":3,"text":"Yi D.","type":"heading","anchor":"Yi-D"},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"Contributed Notes","type":"text"}],"type":"reference","overridingTitle":"Contributed Notes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/antonio081014","isActive":true},{"type":"text","text":" "},{"type":"text","text":"|"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/github.com\/antonio081014","isActive":true},{"type":"text","text":" "},{"type":"text","text":"|"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/x.com\/antonio081014","isActive":true},{"type":"text","text":" "},{"type":"text","text":"|"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/medium.com\/@antonio081014","isActive":true}]}]}],"type":"row"},{"type":"thematicBreak"},{"inlineContent":[{"type":"text","text":"Missing anything? Corrections? "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"},{"anchor":"Related-Sessions","level":2,"type":"heading","text":"Related Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-233-Adding-Delight-to-your-iOS-App","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-407-Practical-Approaches-to-Great-App-Performance","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-406-Optimizing-App-Startup-Time","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-410-Visual-Debugging-with-Xcode","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-411-System-Trace-in-Depth","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-412-Thread-Sanitizer-and-Static-Analysis","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-413-Introduction-to-Xcode","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-719-Optimizing-IO-for-Performance-and-Battery-Life","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-720-Concurrent-Programming-With-GCD-in-Swift-3","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-721-Unified-Logging-and-Activity-Tracing"]},{"in