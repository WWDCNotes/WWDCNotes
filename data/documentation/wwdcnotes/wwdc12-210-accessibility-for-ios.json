{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12-210-Accessibility-for-iOS"},"abstract":[{"text":"iOS devices are incredibly popular for users with special needs. Learn how to take advantage of the accessibility APIs so that everyone is able to use your apps. Gain insight into the best practices for making your apps work with VoiceOver and how to integrate accessibility features into your apps. Come learn how to make even an interactive game (The NSZombie Apocalypse!) work well with VoiceOver.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc12-210-accessibility-for-ios"]}],"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"sampleCodeDownload":{"action":{"isActive":true,"type":"reference","overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2012\/210\/"},"kind":"sampleDownload"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC12"]]},"metadata":{"role":"sampleCode","roleHeading":"WWDC12","modules":[{"name":"WWDC Notes"}],"title":"Accessibility for iOS"},"references":{"WWDC12.jpeg":{"variants":[{"url":"\/images\/WWDCNotes\/WWDC12.jpeg","traits":["1x","light"]}],"type":"image","alt":null,"identifier":"WWDC12.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","u