ind":"sampleDownload"},"references":{"WWDCNotes.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png"},"https://nonstrict.eu/wwdcindex/wwdc2015/219/":{"type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/219\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/219\/"},"WWDC15-Icon.png":{"type":"image","identifier":"WWDC15-Icon.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC15-Icon.png"}],"alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","title":"Learn More…","titleInlineContent":[{"text":"Learn More…","type":"text"}],"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc15","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}],"title":"WWDC15"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-220-High-Performance-Auto-Layout":{"title":"High Performance Auto Layout","abstract":[{"type":"text","text":"Get a glimpse inside to find out what happens when you add a constraint! Dive into the internals of Auto Layout to develop intuition for how your code affects what happens under the hood. Learn how to measure and refine your approach to Auto Layout and see how its improved performance in iOS 12 will speed up your app."}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-220-high-performance-auto-layout","role":"sampleCode","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-220-High-Performance-Auto-Layout"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-203-I-Have-This-Idea-For-An-App":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-203-i-have-this-idea-for-an-app","abstract":[{"text":"Do you have an idea for an app that you think would be useful to others, but you don’t know how to make it a reality? You’re not alone! Lots of people are interested in app development, but they aren’t sure how to turn their idea to code and then into a finished app. From first steps to Xcode, we’ll explain the building blocks you need to turn your iOS app idea into reality.","type":"text"}],"title":"I Have This Idea For An App…","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-203-I-Have-This-Idea-For-An-App","type":"topic","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-236-Whats-New-in-Auto-Layout":{"role":"sampleCode","abstract":[{"type":"text","text":"Get details about new features of Auto Layout in Xcode, Cocoa and Cocoa Touch. Explore the new NSGridView, allowing your Cocoa app to easily build grid interfaces. Dive deeper into new tools that enable you to quickly diagnose layout issues in your interface. Learn about the new features in Xcode to quickly build adaptive interfaces."}],"type":"topic","title":"What’s New in Auto Layout","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-236-Whats-New-in-Auto-Layout","url":"\/documentation\/wwdcnotes\/wwdc16-236-whats-new-in-auto-layout","kind":"article"},"WWDC15.jpeg":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}],"identifier":"WWDC15.jpeg"