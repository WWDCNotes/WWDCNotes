/wwdcnotes\/contributing"},"WWDCNotes.png":{"type":"image","alt":null,"identifier":"WWDCNotes.png","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}]},"WWDC15.jpeg":{"type":"image","alt":null,"identifier":"WWDC15.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-203-I-Have-This-Idea-For-An-App":{"kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc18-203-i-have-this-idea-for-an-app","role":"sampleCode","abstract":[{"text":"Do you have an idea for an app that you think would be useful to others, but you don’t know how to make it a reality? You’re not alone! Lots of people are interested in app development, but they aren’t sure how to turn their idea to code and then into a finished app. From first steps to Xcode, we’ll explain the building blocks you need to turn your iOS app idea into reality.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-203-I-Have-This-Idea-For-An-App","title":"I Have This Idea For An App…"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-220-High-Performance-Auto-Layout":{"abstract":[{"type":"text","text":"Get a glimpse inside to find out what happens when you add a constraint! Dive into the internals of Auto Layout to develop intuition for how your code affects what happens under the hood. Learn how to measure and refine your approach to Auto Layout and see how its improved performance in iOS 12 will speed up your app."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-220-high-performance-auto-layout","type":"topic","kind":"article","title":"High Performance Auto Layout","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-220-High-Performance-Auto-Layout"},"WWDC15-Icon.png":{"identifier":"WWDC15-Icon.png","type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC15-Icon.png","traits":["1x","light"]}],"alt":null}}}