{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-203-Whats-New-in-HealthKit","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"abstract":[{"text":"HealthKit is Apple’s framework to centralize the data storage of personal health information. Hear about the latest enhancements to the framework, supporting new types of data, efficiently deleting objects, and integrating HealthKit into your Apple Watch app.","type":"text"}],"metadata":{"roleHeading":"WWDC15","title":"What’s New in HealthKit","role":"sampleCode","modules":[{"name":"WWDC Notes"}]},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference","isActive":true}]},{"text":"Related Sessions","type":"heading","anchor":"Related-Sessions","level":2},{"style":"list","type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-209-Getting-the-Most-Out-of-HealthKit","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-235-Building-Great-Workout-Apps"]}],"kind":"content"}],"sampleCodeDownload":{"action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/203\/","type":"reference","overridingTitle":"Open on WWDCIndex","isActive":true},"kind":"sampleDownload"},"kind":"article","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc15-203-whats-new-in-healthkit"]}],"references":{"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","titleInlineContent":[{"text":"Learn More…","type":"text"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-235-Building-Great-Workout-Apps":{"abstract":[{"type":"text","text":"HealthKit provides robust tools for building great workout apps for Apple Watch. Learn how your workout app can collect data from Watch sensors, run and analyze data in real-time in the background, and contribute to Activity rings. Gain insights into creating a great standalone Watch experience and see how to display your workouts within the Health app and the Activity app on iOS."}],"url":"\/documentation\/wwdcnotes\/wwdc16-235-building-great-workout-apps","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-235-Building-Great-Workout-Apps","type":"topic","kind":"article","role":"sampleCode","title":"Building Great Workout Apps"},"WWDC15-Icon.png":{"type":"image","identifier":"WWDC15-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC15-Icon.png","traits":["1x","light"]}]},"https://nonstrict.eu/wwdcindex/wwdc2015/203/":{"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/203\/","type":"download","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/203\/","checksum":null},"WWDC15.jpeg":{"alt":null,"type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}],"identifier":"WWDC15.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-209-Getting-the-Most-Out-of-HealthKit":{"url":"\/documentation\/wwdcnotes\/wwdc16-209-getting-the-most-out-of-healthkit","kind":"article","type":"topic","role":"sampleCode","title":"Getting the Most Out of HealthKit","abstract":[{"text":"HealthKit offers more than ever to developers joining in Apple’s vibrant health and fitness ecosystem. Discover new ways to integrate the popular activity-tracking features of Apple Watch with your own app. Learn how to contribute to an even more complete picture of users’ health data by reading and writing Health Documents from your organization. Review core concepts for working with HealthKit and explore best practices for managing data to ensure your users enjoy a seamless experience.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-209-Getting-the-Most-Out-of-HealthKit"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc15","role":"collectionGroup","type":"topic","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}],"title":"WWDC15"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"WWDCNotes.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"type":"image","identifier":"WWDCNotes.png"}}}