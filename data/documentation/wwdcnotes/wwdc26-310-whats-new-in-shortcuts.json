{"kind":"article","sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC26","role":"sampleCode","title":"What’s new in Shortcuts"},"abstract":[{"text":"Explore techniques to build powerful shortcuts using your app’s content. New automations unlock additional ways to integrate your app with the system. Refine how your App Entity is presented to LLMs using the new “Use Model” transcript feature. Store rich information from your app inside shortcuts that is synced across devices. Learn how to combine these features to create intelligent, powerful automations that integrate seamlessly with content and features from your app.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"Key-Takeaways","text":"Key Takeaways","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"🔁 New automation types — screenshot, keyboard connection, and notifications","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"🔬 Inspector shows the model’s transcript for your actions"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"💾 Persistent storage for variables can be accessed across devices"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"🆔 App Entities need stable, device-consistent IDs for cross-device recognition","type":"text"}]}]}]},{"anchor":"Automations","text":"Automations","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Three new automation trigger types:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Screenshot","type":"text"}],"type":"strong"},{"text":" — run a shortcut when a screenshot is taken","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Keyboard connection"}],"type":"strong"},{"text":" — react when a keyboard is connected or disconnected","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Notification"}],"type":"strong"},{"type":"text","text":" — trigger on incoming notifications"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Can filter based on notification content","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Design notifications with automation in mind: clear titles and bodies help users build reliable keyword-based triggers"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"}]}]},{"anchor":"Use-Model","text":"Use Model","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"Use Model"},{"text":" action runs the latest Apple Intelligence models and can retrieve information from the web","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When a shortcut passes your app’s App Intent entities to the model, the "},{"type":"strong","inlineContent":[{"text":"model transcript inspector","type":"text"}]},{"type":"text","text":" shows exactly what data is sent"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use the inspector to verify entity properties, tune ","type":"text"},{"type":"codeVoice","code":"@Property"},{"text":" titles, and refine what the model sees","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Rich "},{"type":"codeVoice","code":"@Property"},{"type":"text","text":" annotations on entities improve how content is represented in the transcript"}]}]}]},{"code":["import AppIntents","","struct SoupEntity: AppEntity, Identifiable {","    static var typeDisplayRepresentation = TypeDisplayRepresentation(","        name: \"Soup\",","        numericFormat: \"\\(placeholder: .int) soups\"","    )","    static var defaultQuery = SoupEntityQuery()","","    var id: Soup.ID","","    @Property var name: String","","    @Property(title: \"Available Today\")","    var isAvailableToday: Bool","","    @Property(title: \"Ingredients\")","    var ingredients: String","","    var displayRepresentation: DisplayRepresentation {","        DisplayRepresentation(title: \"\\(name)\", subtitle: SoupStore.description(for: id))","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Storage","text":"Storage","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Storage","type":"text"}],"type":"strong"},{"text":" lets shortcuts persist data between runs with Get, Set, and global storage values","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Global storage syncs across all of a person’s devices via iCloud","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Combine storage with Use Model to give a shortcut “memory” — e.g. save prior model output or user preferences for the next run","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For App Intent entities referenced in storage or passed to Use Model, use a "},{"type":"strong","inlineContent":[{"type":"text","text":"stable, device-consistent identifier"}]},{"type":"text","text":" so entities are recognized correctly on every device"}]}]}]}],"kind":"content"}],"sampleCodeDownload":{"action":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/310","type":"reference","isActive":true,"overridingTitle":"Watch Video (11 min)"},"kind":"sampleDownload"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-310-Whats-new-in-Shortcuts"},"variants":[{"traits":[{