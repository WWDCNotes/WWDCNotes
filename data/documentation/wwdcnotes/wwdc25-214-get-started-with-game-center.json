tes.com/documentation/wwdcnotes/contributing":{"title":"Learn More…","type":"link","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC25":{"title":"WWDC25","kind":"article","role":"collectionGroup","images":[{"identifier":"WWDC25-Icon.png","type":"icon"},{"identifier":"WWDC25.jpg","type":"card"}],"url":"\/documentation\/wwdcnotes\/wwdc25","abstract":[{"type":"text","text":"Xcode 26, Swift 6.2, iOS\/macOS\/tvOS\/visionOS 26."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Foundation Models"},{"type":"text","text":", "},{"type":"codeVoice","code":"AlarmKit"},{"text":", ","type":"text"},{"code":"PermissionKit","type":"codeVoice"},{"text":", and more.","type":"text"}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC25"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10065-Plugin-and-play-Add-Apple-frameworks-to-your-Unity-game-projects":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10065-Plugin-and-play-Add-Apple-frameworks-to-your-Unity-game-projects","type":"topic","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc22-10065-plugin-and-play-add-apple-frameworks-to-your-unity-game-projects","abstract":[{"type":"text","text":"Help make your Unity app or game an even better experience on Apple platforms. Learn how you can add Apple technologies directly to your projects with six plug-ins: Apple.Core, Game Center, Game Controller, Accessibility, Core Haptics, and PHASE. We’ll show you how you can add new gameplay mechanics, make your games more accessible, and tap into the latest Apple features and services."}],"kind":"article","title":"Plug-in and play: Add Apple frameworks to your Unity game projects"},"WWDCNotes.png":{"alt":null,"variants":[{"traits":["1x","light"]