{"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-711-networking-with-nsurlsession"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-711-Networking-with-NSURLSession"},"abstract":[{"type":"text","text":"Learn about App Transport Security, HTTP\/2 protocol support, new NSURLSession API, and best practices for networking in apps, extensions, and WatchKit apps."}],"kind":"article","sections":[],"metadata":{"role":"sampleCode","roleHeading":"WWDC15","modules":[{"name":"WWDC Notes"}],"title":"Networking with NSURLSession"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference","isActive":true}]},{"type":"heading","text":"Related Sessions","level":2,"anchor":"Related-Sessions"},{"type":"links","style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10120-Streamline-your-App-Clip","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-203-I-Have-This-Idea-For-An-App","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-707-Advances-in-Networking-Part-1","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-709-Advances-in-Networking-Part-2"]}],"kind":"content"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/711\/","isActive":true,"type":"reference"}},"references":{"https://nonstrict.eu/wwdcindex/wwdc2015/711/":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/711\/","type":"download","checksum":null,"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/711\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-203-I-Have-This-Idea-For-An-App":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-203-i-have-this-idea-for-an-app","abstract":[{"text":"Do you have an idea for an app that you think would be useful to others, but you don’t know how to make it a reality? You’re not alone! Lots of people are interested in app development, but they aren’t sure how to turn their idea to code and then into a finished app. From first steps to Xcode, we’ll explain the building blocks you need to turn your iOS app idea into reality.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-203-I-Have-This-Idea-For-An-App","role":"sampleCode","type":"topic","title":"I Have This Idea For An App…"},"WWDC15.jpeg":{"alt":null,"identifier":"WWDC15.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}],"type":"image"},"doc://WWDCNotes/documentation/WWDCNotes":{"kind":"symbol","role":"collection","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"role":"collectionGroup","images":[{"identifier":"WWDC15-Icon.png","type":"icon"},{"identifier":"WWDC15.jpeg","type":"card"}],"url":"\/documentation\/wwdcnotes\/wwdc15","title":"WWDC15","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","type":"topic","kind":"article","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-709-Advances-in-Networking-Part-2":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-709-Advances-in-Networking-Part-2","abstract":[{"type":"text","text":"Learn about important improvements to URLSession. Find out how to use new URLSession APIs to better handle connectivity fluctuations, to schedule background session tasks, and to receive progress reports for session tasks. Plus, gain insights into valuable best practices, tips, and news about ongoing work with emerging network technologies."}],"url":"\/documentation\/wwdcnotes\/wwdc17-709-advances-in-networking-part-2","role":"sampleCode","type":"topic","title":"Advances in Networking, Part 2"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10120-Streamline-your-App-Clip":{"type":"topic","title":"Streamline your App Clip","url":"\/documentation\/wwdcnotes\/wwdc20-10120-streamline-your-app-clip","kind":"article","role":"sampleCode","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10120-Streamline-your-App-Clip","abstract":[{"type":"text","text":"App Clips are best when they provide an “in the moment” experience for people using them, like ordering your favorite refreshing beverage or paying for parking. We’ll share guidelines and best practices for building focused and consistent App Clips, show you how to streamline transaction experiences by taking advantage of technologies like App Clip notifications and location confirmation, and explore how you can help people move from your App Clip over to your full app."}]},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-707-Advances-in-Networking-Part-1":{"type":"topic","abstract":[{"type":"text","text":"Find out how Apple’s networking libraries and frameworks are taking advantage of new and improved protocols to deliver better connectivity and performance for your apps. In this first of two sessions, we’ll cover ECN, IPv6, Network Extensions, and Multipath protocols."}],"url":"\/documentation\/wwdcnotes\/wwdc17-707-advances-in-networking-part-1","title":"Advances in Networking, Part 1","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-707-Advances-in-Networking-Part-1","kind":"article","role":"sampleCode"},"WWDC15-Icon.png":{"identifier":"WWDC15-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC15-Icon.png","traits":["1x","light"]}],"alt":null,"type":"image"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link"}}}