WDC15-Icon.png":{"identifier":"WWDC15-Icon.png","variants":[{"url":"\/images\/WWDCNotes\/WWDC15-Icon.png","traits":["1x","light"]}],"type":"image","alt":null},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-707-Advances-in-Networking-Part-1":{"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc17-707-advances-in-networking-part-1","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-707-Advances-in-Networking-Part-1","title":"Advances in Networking, Part 1","role":"sampleCode","abstract":[{"type":"text","text":"Find out how Apple’s networking libraries and frameworks are taking advantage of new and improved protocols to deliver better connectivity and performance for your apps. In this first of two sessions, we’ll cover ECN, IPv6, Network Extensions, and Multipath protocols."}]},"https://nonstrict.eu/wwdcindex/wwdc2015/711/":{"checksum":null,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/711\/","type":"download","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/711\/"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","title":"Learn More…","titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-203-I-Have-This-Idea-For-An-App":{"kind":"article","type":"topic","url":"\/documentation\/wwdcnotes\/wwdc18-203-i-have-this-idea-for-an-app","role":"sampleCode","abstract":[{"text":"Do you have an idea for an app that you think would be useful to others, but you don’t know how to make it a reality? You’re not alone! Lots of people are interested in app development, but they aren’t sure how to turn their idea to code and then into a finished app. From first steps to Xcode, we’ll explain the building blocks you need to turn your iOS app idea into reality.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-203-I-Have-This-Idea-For-An-App","title":"I Have This Idea For An App…"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"kind":"article","type":"topic","images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"url":"\/documentation\/wwdcnotes\/wwdc15","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","role":"collectionGroup","title":"WWDC15","abstract":[{"type":"text","text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2."}]},"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWDCNotes.png"}],"type":"topic","kind":"symbol","role":"collection","title":"WWDC Notes","url":"\/documentation\/wwdcnotes","abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10120-Streamline-your-App-Clip":{"abstract":[{"type":"text","text":"App Clips are best when they provide an “in the moment” experience for people using them, like ordering your favorite refreshing beverage or paying for parking. We’ll share guidelines and best practices for building focused and consistent App Clips, show you how to streamline transaction experiences by taking advantage of technologies like App Clip notifications and location confirmation, and explore how you can help people move from your App Clip over to your full app."}],"role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc20-10120-streamline-your-app-clip","type":"topic","kind":"article","title":"Streamline your App Clip","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10120-Streamline-your-App-Clip"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-709-Advances-in-Networking-Part-2":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-709-Advances-in-Networking-Part-2","abstract":[{"type":"text","text":"Learn about important improvements to URLSession. Find out how to use new URLSession APIs to better handle connectivity fluctuations, to schedule background session tasks, and to receive progress reports for session tasks. Plus, gain insights into valuable best practices, tips, and news about ongoing work with emerging network technologies."}],"kind":"article","type":"topic","title":"Advances in Networking, Part 2","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc17-709-advances-in-networking-part-2"},"WWDC15.jpeg":{"identifier":"WWDC15.jpeg","variants":[{"url":"\/images\/WWDCNotes\/WWDC15.jpeg","traits":["1x","light"]}],"type":"image","alt":null}}}