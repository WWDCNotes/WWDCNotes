bstract":[{"text":"Designing for AR can be intimidating and discovering design flaws late in the process can be costly. See how low-tech traditional prototyping techniques can help you validate and refine your AR app and game design ideas.","type":"text"}],"role":"sampleCode","kind":"article","url":"\/documentation\/wwdcnotes\/wwdc18-808-prototyping-for-ar"},"https://nonstrict.eu/wwdcindex/wwdc2018/809/":{"type":"download","checksum":null,"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/809\/","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2018\/809\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18":{"url":"\/documentation\/wwdcnotes\/wwdc18","abstract":[{"type":"text","text":"Xcode 10, Swift 4.2, iOS 12, macOS 10.14 (Mojave), tvOS 12, watchOS 5."}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18","type":"topic","kind":"article","images":[{"identifier":"WWDC18-Icon.png","type":"icon"},{"identifier":"WWDC18.jpeg","type":"card"}],"role":"collectionGroup","title":"WWDC18"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-811-Presenting-Design-Work":{"url":"\/documentation\/wwdcnotes\/wwdc18-811-presenting-design-work","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-811-Presenting-Design-Work","title":"Presenting Design Work","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"Ideas can live or die by their presentation. Learn indispensable and proven techniques for presenting your design work to better communicate your objectives and receive helpful, valuable and constructive feedback."}],"kind":"article"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC20-10106-Meet-Scribble-for-iPad":{"url":"\/documentation\/wwdcnotes\/wwdc20-10106-meet-scribble-for-ipad","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC20-10106-Meet-Scribble-for-iPad","abstract":[{"text":"Scribble offers a lightweight, ergonomic, and enjoyable way of entering text on iPad with Apple Pencil. Discover how people 