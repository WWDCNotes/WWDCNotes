n\/WWDCNotes\/WWDC18-810-Tips-for-Great-Maps","kind":"article","abstract":[{"type":"text","text":"Maps are powerful tools for conveying information. Learn key cartographic principles that will help you create beautiful, useful maps so that your users can get the most out of your apps."}],"type":"topic","title":"Tips for Great Maps","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc18-810-tips-for-great-maps"}}}