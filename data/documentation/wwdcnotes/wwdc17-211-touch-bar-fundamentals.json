{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17"]]},"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-211-Touch-Bar-Fundamentals","interfaceLanguage":"swift"},"sections":[],"metadata":{"modules":[{"name":"WWDC Notes"}],"role":"sampleCode","roleHeading":"WWDC17","title":"Touch Bar Fundamentals"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}]},{"type":"heading","anchor":"Related-Sessions","level":2,"text":"Related Sessions"},{"type":"links","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-201-Whats-New-in-Cocoa-Touch","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-222-Advanced-Touch-Bar"],"style":"list"}]}],"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc17-211-touch-bar-fundamentals"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","sampleCodeDownload":{"action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/211\/","isActive":true,"overridingTitle":"Open on WWDCIndex","type":"reference"},"kind":"sampleDownload"},"abstract":[{"type":"text","text":"Touch Bar replaces the function keys that have long occupied the top of your keyboard with a versatile MultiTouch input device that features a Retina display. AppKit provides powerful APIs to let you easily leverage the power of Touch Bar in your applications. Learn how to use Touch Bar in your application to add context sensitive commands and flexible content to your user experience. This session will cover the basic concepts, design considerations, standard controls, IB support, and API that you will need to get started using Touch Bar."}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-201-Whats-New-in-Cocoa-Touch":{"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-201-Whats-New-in-Cocoa-Touch","title":"What’s New in Cocoa Touch","role":"sampleCode","abstract":[{"type":"text","text":"iOS 11 enhances the Cocoa Touch frameworks for making next generation apps on iOS. Learn about drag and drop, file management, document browser, updates to the navigation and tab bars, app safe areas, swipe actions and API refinements. Find out which sessions you won’t want to miss throughout the week."}],"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc17-201-whats-new-in-cocoa-touch"},"WWDC17-Icon.png":{"type":"image","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC17-Icon.png","traits":["1x","light"]}],"identifier":"WWDC17-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-222-Advanced-Touch-Bar":{"url":"\/documentation\/wwdcnotes\/wwdc17-222-advanced-touch-bar","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-222-Advanced-Touch-Bar","role":"sampleCode","kind":"article","title":"Advanced Touch Bar","abstract":[{"type":"text","text":"Look behind the scenes into how system applications enhance their Touch Bar content with more than the basic controls. Learn about NSScrubber, customizing the text bar, candidate list item, event handling, layout, animations, and more. Leverage the full power of the Touch Bar to take your Mac app to the next level."}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17":{"title":"WWDC17","type":"topic","role":"collectionGroup","abstract":[{"type":"text","text":"Xcode 9, Swift 4.0, iOS 11, macOS 10.13 (High Sierra), tvOS 11, watchOS 4."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"Core NFC"},{"type":"text","text":" and more."}],"url":"\/documentation\/wwdcnotes\/wwdc17","kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17","images":[{"type":"icon","identifier":"WWDC17-Icon.png"},{"type":"card","identifier":"WWDC17.jpeg"}]},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"type":"link","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"type":"text","text":"Learn More…"}],"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"https://nonstrict.eu/wwdcindex/wwdc2017/211/":{"url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/211\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2017\/211\/","type":"download","checksum":null},"WWDCNotes.png":{"type":"image","alt":null,"identifier":"WWDCNotes.png","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}]},"WWDC17.jpeg":{"identifier":"WWDC17.jpeg","type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC17.jpeg"}]},"doc://WWDCNotes/documentation/WWDCNotes":{"role":"collection","images":[{"identifier":"WWDCNotes.png","type":"icon"}],"abstract":[{"type":"text","text":"Session notes shared by the community for the community."}],"type":"topic","title":"WWDC Notes","kind":"symbol","url":"\/documentation\/wwdcnotes","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes"}}}