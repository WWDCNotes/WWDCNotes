Language":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-401-Whats-New-in-Xcode-App-Signing"},"references":{"WWDCNotes.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDCNotes.png"}],"identifier":"WWDCNotes.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16":{"abstract":[{"text":"Xcode 8, Swift 3.0, iOS 10, macOS 10.12 (Sierra), tvOS 10, watchOS 3.","type":"text"}],"type":"topic","images":[{"type":"icon","identifier":"WWDC16-Icon.png"},{"type":"card","identifier":"WWDC16.jpeg"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16","title":"WWDC16","kind":"article","role":"collectionGroup","url":"\/documentation\/wwdcnotes\/wwdc16"},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"titleInlineContent":[{"type":"text","text":"Learn More…"}],"type":"link","title":"Learn More…","url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"WWDC16-Icon.png":{"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16-Icon.png"}],"alt":null,"identifier":"WWDC16-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes":{"abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"url":"\/documentation\/wwdcnotes","type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","kind":"symbol","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","title":"WWDC Notes"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-706-Whats-New-in-Security":{"title":"What’s New in Security","abstract":[{"type":"text","text":"Designing security into your app requires that you follow secure coding practices and use the security features that are built into the operating system. Learn about new developments in Security on iOS, macOS, watchOS and tvOS that impact your apps. Hear about best practices for developing and distributing secure apps and protecting people’s data."}],"type":"topic","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-706-Whats-New-in-Security","url":"\/documentation\/wwdcnotes\/wwdc16-706-whats-new-in-security","kind":"article","role":"sampleCode"},"WWDC16.jpeg":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC16.jpeg"}],"identifier":"WWDC16.jpeg"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-705-How-iOS-Security-Really-Works":{"url":"\/documentation\/wwdcnotes\/wwdc16-705-how-ios-security-really-works","kind":"article","type":"topic","role":"sampleCode","title":"How iOS Security Really Works","abstract":[{"text":"Have you saved our 63-page iOS security white paper to your Reading List but find yourself too busy making great apps to get through it? You can keep your good intentions to devour every last detail, but meanwhile come join us for an illuminating talk on why we care so deeply about security as a design philosophy central to all our iOS products.","type":"text"}],"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-705-How-iOS-Security-Really-Works"},"https://nonstrict.eu/wwdcindex/wwdc2016/401/":{"checksum":null,"type":"download","url":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/401\/","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2016\/401\/"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC16-413-Introduction-to-Xcode":{"title":"Introduction to Xcode","abstract":[{"type":"text","text":"Xcode enables you to create great apps for Apple platforms. This session will introduce you to the basics of creating a project with Xcode, and more. You’ll learn how to comfortably navigate your project and gain insights into working with workspaces, targets, and schemes. We’ll introduce you to version control workflows, and walk through using Xcode’s source editors and design tools. Join us if you’re new to Apple platforms or want to learn more about using Xcode."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC16-413-Introduction-to-Xcode","url":"\/documentation\/wwdcnotes\/wwdc16-413-introduction-to-xcode","type":"topic","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-403-Whats-New-in-Signing-for-Xcode-and-Xcode-Server":{"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-403-Whats-New-in-Signing-for-Xcode-and-Xcode-Server","role":"sampleCode","type":"topic","abstract":[{"text":"Learn about new advances in Xcode’s support for code signing, including more powerful distribution signing, better integration with Xcode Server, and more control for working with manual signing assets.","type":"text"}],"url":"\/documentation\/wwdcnotes\/wwdc17-403-whats-new-in-signing-for-xcode-and-xcode-server","title":"What’s New in Signing for Xcode and Xcode Server"}}}