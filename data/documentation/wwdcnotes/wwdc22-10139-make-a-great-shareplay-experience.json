{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10139-Make-a-great-SharePlay-experience"},"sections":[],"abstract":[{"type":"text","text":"Discover how you can design and build a great SharePlay experience. We’ll show you how to identify activities in your app that can help bring everyone together — even while they’re apart. Learn best practices to help you design for group activities, create intuitive interactions, and build support for different types of experiences."}],"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"WWDC22","modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"Make a great SharePlay experience"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"😱 “No Overview Available!”"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by watching the video and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","type":"reference"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Related-Sessions","text":"Related Sessions"},{"items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10140-Whats-new-in-SharePlay","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-110380-Display-ads-and-interstitials-in-SharePlay","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10225-Coordinate-media-experiences-with-Group-Activities"],"style":"list","type":"links"}]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"Watch Video (18 min)","type":"reference","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2022\/10139"}},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc22-10139-make-a-great-shareplay-experience"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC22":{"title":"WWDC22","abstract":[{"type":"text","text":"Xcode 14, Swift 5.7, iOS 16, macOS 13 (Ventura), tvOS 16, watchOS 9."},{"type":"text","text":" "},{"type":"text","text":"New APIs: "},{"type":"codeVoice","code":"WeatherKit"},{"type":"text","text":", "},{"type":"codeVoice","code":"ScreenCaptureKit"},{"type":"text","text":", "},{"type":"codeVoice","code":"Swift Regex"},{"type":"text","text":", and more."}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22","images":[{"type":"icon","identifier":"WWDC22-Icon.png"},{"type":"card","identifier":"WWDC22.jpeg"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc22","role":"collectionGroup"},"WWDC22.jpeg":{"type":"image","alt":null,"identifier":"WWDC22.jpeg","variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC22.jpeg"}]},"doc://WWDCNotes/documentation/WWDCNotes/WWDC21-10225-Coordinate-media-experiences-with-Group-Activities":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC21-10225-Coordinate-media-experiences-with-Group-Activities","title":"Coordinate media experiences with Group Activities","role":"sampleCode","url":"\/documentation\/wwdcnotes\/wwdc21-10225-coordinate-media-experiences-with-group-activities","type":"topic","kind":"article","abstract":[{"text":"Discover how you can help people watch or listen to content all in sync with SharePlay and the Group Activities framework. We’ll show you how to adapt a media app into a synchronized, SharePlay-enabled experience for multiple people. Learn how to add Group Activities to your app, explore the Picture in Picture layout, and find out how the playback coordinator object can help you fine-tune playback across multiple devices.","type":"text"}]},"WWDC22-Icon.png":{"identifier":"WWDC22-Icon.png","alt":null,"variants":[{"url":"\/images\/WWDCNotes\/WWDC22-Icon.png","traits":["1x","light"]}],"type":"image"},"WWDCNotes.png":{"identifier":"WWDCNotes.png","type":"image","variants":[{"url":"\/images\/WWDCNotes\/WWDCNotes.png","traits":["1x","light"]}],"alt":null},"https://wwdcnotes.com/documentation/wwdcnotes/contributing":{"url":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","titleInlineContent":[{"text":"Learn More…","type":"text"}],"type":"link","title":"Learn More…","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"https://developer.apple.com/videos/play/wwdc2022/10139":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2022\/10139","checksum":null,"url":"https:\/\/developer.apple.com\/videos\/play\/wwdc2022\/10139","type":"download"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-10140-Whats-new-in-SharePlay":{"identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-10140-Whats-new-in-SharePlay","url":"\/documentation\/wwdcnotes\/wwdc22-10140-whats-new-in-shareplay","type":"topic","abstract":[{"text":"Join us as we share the latest updates to SharePlay. We’ll show you how you can start SharePlay sessions right from your app, take you through improvements to APIs to create richer experiences, and check out enhancements to GroupSessionMessenger. We’ll also explore best practices for adding SharePlay to your app.","type":"text"}],"kind":"article","title":"What’s new in SharePlay","role":"sampleCode"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC22-110380-Display-ads-and-interstitials-in-SharePlay":{"kind":"article","url":"\/documentation\/wwdcnotes\/wwdc22-110380-display-ads-and-interstitials-in-shareplay","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC22-110380-Display-ads-and-interstitials-in-SharePlay","title":"Display ads and interstitials in SharePlay","type":"topic","role":"sampleCode","abstract":[{"type":"text","text":"Find out how you can deliver a coordinated playback experience in SharePlay when your app delivers different ad schedules to each participant. We’ll explore how to build playback experiences with stitched-in ads and scheduled HLS interstitials, and share tips and best practices."}]}}}