{"abstract":[{"text":"Discover the latest enhancements to SwiftData. We’ll show you how to persist custom and third-party types using Codable, and group fetched data into sections in your SwiftUI app. We’ll also explore how to observe data store changes anywhere else using ModelResultsObserver and HistoryObserver, giving you the flexibility to drive powerful state objects, integrate with delegate-based architectures, and react precisely to model updates.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc26-274-whats-new-in-swiftdata"]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/274","overridingTitle":"Watch Video (12 min)","type":"reference","isActive":true}},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-274-Whats-new-in-SwiftData"},"metadata":{"role":"sampleCode","modules":[{"name":"WWDC Notes"}],"title":"What’s new in SwiftData","roleHeading":"WWDC26"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Key Takeaways","type":"heading","anchor":"Key-Takeaways"},{"items":[{"content":[{"inlineContent":[{"text":"🗄️ Sectioned fetch requests supported by @Query","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"🌈 Persist custom attribute types via Codable"}]}]},{"content":[{"inlineContent":[{"text":"🕵️ Observe changes outside of SwiftUI views","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Sectioning your fetches","type":"heading","anchor":"Sectioning-your-fetches"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"@Query","type":"codeVoice"},{"text":" now supports sectioned fetches","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Access query from property wrapper via underscore-prefix name","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each section has ID property"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"ID is value model from the KeyPath passed on in "},{"type":"codeVoice","code":"sectionBy"}]}]}]}]}],"type":"unorderedList"},{"type":"codeListing","code":["struct TripListView: View {   ","    @Query(sort: \\Trip.startDate,","           sectionBy: \\.destination)","    var trips: [Trip]","","    var body: some View: {","        List {","            ForEach(_trips.sections) { section in","                Section(section.id) {","                    ForEach(section) { trip in","                        TripListItem(trip: trip)","                    }","               }","            }","        }","    }","}"],"syntax":"swift"},{"level":2,"text":"Using custom types","type":"heading","anchor":"Using-custom-types"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"SwiftData generates mapping between Model classes and entities + properties","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Works automatically for most types"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Classes not annotated with ","type":"text"},{"code":"@Model","type":"codeVoice"},{"text":" macro can’t automatically be inspected and generated","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Classes conforming to "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":" can now be serialized to type by SwiftData"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"SwiftData stores the serialized representation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":".codable","type":"codeVoice"},{"type":"text","text":" attribute to mark for automatic serialization"}]}]}]}]}],"type":"unorderedList"},{"type":"codeListing","code":["import SwiftData","","@Model class Trip {","","    struct Location: Codable {","        var latitude: Double","        var longitude: Double","    }","","    var name: String","    var destination: String","","    var startDate: Date","    var endDate: Date","","    var location: Location?","    @Attribute(.codable) var mapItemIdentifier: MKMapItem.Identifier?","}"],"syntax":"swift"},{"level":3,"text":"Limitations of `@Attribute(.codable)`","type":"heading","anchor":"Limitations-of-Attributecodable"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Persists encoded representation instead of inferring schema for type"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"No support for filtering in Predicates or sorting in Sort Descriptors"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Codable attributes are opaque to SwiftData"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Migration is defined by type","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Adding or removing properties from codable type won’t trigger migration"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Type must encode and decode in forward- and backward-compatible way"}]}]}]}]}],"type":"unorderedList"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"Avoid codable for Types you define: “Using Codable attributes can be thought of as an ‘escape hatch’ to persist types that SwiftData does not support natively.”","type":