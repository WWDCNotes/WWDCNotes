{"identifier":{"url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-101-Keynote","interfaceLanguage":"swift"},"abstract":[{"text":"Don’t miss the exciting reveal of the latest Apple software and technologies.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc26-101-keynote"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"overridingTitle":"Watch Video (76 min)","identifier":"https:\/\/developer.apple.com\/videos\/play\/wwdc2026\/101","type":"reference"}},"primaryContentSections":[{"content":[{"level":2,"text":"Key Takeaways","anchor":"Key-Takeaways","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Apple introduces Siri AI with powerful new capabilities for a more conversational experience."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"New design improvements and performance enhancements across macOS, iOS, and more.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enhanced child safety features with customizable parental controls."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Integration of Apple Intelligence models for smarter app functionalities."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Advanced photo editing tools with features like Spatial Reframing and Image Playground.","type":"text"}]}]}],"type":"unorderedList"},{"level":2,"text":"WWDC Highlights","anchor":"WWDC-Highlights","type":"heading"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-ios-27.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Event Introduction by Tim Cook","type":"text"}]},{"type":"text","text":": Focused on the importance of platform advancements and developer community engagement. Celebrated the continuous growth and innovation within the Apple ecosystem."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Developer Community Growth"}],"type":"strong"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Over 1,000 app submissions per hour to the App Store."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Developer Academies have educated tens of thousands worldwide, fostering the next generation of developers."}]}]}]}]}],"type":"unorderedList"},{"level":2,"text":"Design and Performance Enhancements","anchor":"Design-and-Performance-Enhancements","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cross-Platform Design Updates","type":"text"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Liquid Glass","type":"text"}],"type":"strong"},{"text":": Enhanced for improved readability and depth. Now includes a slider for users to adjust clarity from ultra-clear to fully tinted, allowing for personalized app experiences.","type":"text"}],"type":"paragraph"}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-liquid-glass-slider.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"UI Consistency"}]},{"type":"text","text":": New uniform toolbars and expanded sidebars across apps provide better structure and focus, reducing distractions and enhancing usability."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Performance Optimizations","type":"text"}]},{"type":"text","text":":"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Faster App Launches"}]},{"type":"text","text":": iPhone and iPad apps launch up to 30% faster by preloading key data, increasing efficiency and user satisfaction."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Photo and Content Loading"}]},{"type":"text","text":": Photo loading is improved by up to 70%, making photo libraries more responsive. AirDrop transfers are 80% faster, streamlining file sharing."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Network Transitions","type":"text"}]},{"type":"text","text":": More seamless transitions between cellular and Wi-Fi networks, reducing connectivity disruptions and enhancing user experience."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"System Animations","type":"text"}],"type":"strong"},{"text":": Smoother animations across devices, such as swiping between Home Screen pages on iPhone and transitioning between spaces on Mac.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"level":2,"text":"Child Safety Features","anchor":"Child-Safety-Features","type":"heading"},{"numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-contact-permission.jpeg"}]}]},{"size":1,"content":[{"inlineContent":[{"type":"image","identifier":"WWDC26-101-time-limits.jpeg"}],"type":"paragraph"}]}],"type":"row"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Parental Controls","type":"text"}]},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New tools for managing app access, content, and communications."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Features like Ask to Browse ensure children request permission for new website access."}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Expert Collaboration","type":"text"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Developed with input from the American Academy of Pediatrics."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Focus on healthy digital habits and age-appropriate content access."}]}]}]}]}],"type":"unorderedList"},{"level":2,"text":"Apple Intelligence and Siri AI","anchor":"Apple-Intelligence-and-Siri-AI","type":"heading"},{"inlineContent":[{"identifier":"WWDC26-101-siri-ai-architecture.jpeg","type":"image"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Advanced AI Integration"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Collaboration with Google on Apple Foundation models enhances Siri’s capabilities.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Models run on-device and on Private Cloud Compute to ensure privacy.","type":"text"}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-apple-intelligence-summary-1.jpeg"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-apple-intelligence-summary-2.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"New Siri AI","type":"text"}]},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Provides a conversational experience with advanced speech understanding and generation.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integrated across platforms for personalized assistance."}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-siri-ai-features.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Visual Intelligence","type":"text"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Siri can analyze images and provide contextual information, enriching user interactions."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"level":2,"text":"App Enhancements","anchor":"App-Enhancements","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Safari","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"AI organizes tabs into topics and monitors page updates with the Notify Me feature.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom extensions can be created easily with natural language descriptions."}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Photos"}],"type":"strong"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Features like Clean Up, Extend, and Spatial Reframing for advanced photo editing.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Image Playground provides creative possibilities through generative models.","type":"text"}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-photos-features.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Shortcuts"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineC