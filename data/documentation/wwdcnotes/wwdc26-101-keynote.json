{"kind":"article","variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc26-101-keynote"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"sections":[],"abstract":[{"type":"text","text":"Don’t miss the exciting reveal of the latest Apple software and technologies."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Key-Takeaways","text":"Key Takeaways"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Apple introduces Siri AI with powerful new capabilities for a more conversational experience.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"New design improvements and performance enhancements across macOS, iOS, and more."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Enhanced child safety features with customizable parental controls.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Integration of Apple Intelligence models for smarter app functionalities.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Advanced photo editing tools with features like Spatial Reframing and Image Playground."}],"type":"paragraph"}]}]},{"level":2,"type":"heading","anchor":"WWDC-Highlights","text":"WWDC Highlights"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-ios-27.jpeg"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Event Introduction by Tim Cook","type":"text"}]},{"type":"text","text":": Focused on the importance of platform advancements and developer community engagement. Celebrated the continuous growth and innovation within the Apple ecosystem."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Developer Community Growth","type":"text"}],"type":"strong"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Over 1,000 app submissions per hour to the App Store.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Apple Developer Academies have educated tens of thousands worldwide, fostering the next generation of developers."}],"type":"paragraph"}]}]}]}]},{"level":2,"type":"heading","anchor":"Design-and-Performance-Enhancements","text":"Design and Performance Enhancements"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Cross-Platform Design Updates","type":"text"}],"type":"strong"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Liquid Glass","type":"text"}]},{"text":": Enhanced for improved readability and depth. Now includes a slider for users to adjust clarity from ultra-clear to fully tinted, allowing for personalized app experiences.","type":"text"}],"type":"paragraph"}]}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-101-liquid-glass-slider.jpeg","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"UI Consistency"}],"type":"strong"},{"text":": New uniform toolbars and expanded sidebars across apps provide better structure and focus, reducing distractions and enhancing usability.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Performance Optimizations"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Faster App Launches","type":"text"}]},{"type":"text","text":": iPhone and iPad apps launch up to 30% faster by preloading key data, increasing efficiency and user satisfaction."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Photo and Content Loading","type":"text"}]},{"text":": Photo loading is improved by up to 70%, making photo libraries more responsive. AirDrop transfers are 80% faster, streamlining file sharing.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Network Transitions","type":"text"}],"type":"strong"},{"text":": More seamless transitions between cellular and Wi-Fi networks, reducing connectivity disruptions and enhancing user experience.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"System Animations"}]},{"type":"text","text":": Smoother animations across devices, such as swiping between Home Screen pages on iPhone and transitioning between spaces on Mac."}]}]}],"type":"unorderedList"}]}]},{"level":2,"type":"heading","anchor":"Child-Safety-Features","text":"Child Safety Features"},{"type":"row","numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-101-contact-permission.jpeg","type":"image"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-101-time-limits.jpeg","type":"image"}]}]}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Parental Controls"}]},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New tools for managing app access, content, and communications."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Features like Ask to Browse ensure children request permission for new website access."}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Expert Collaboration"}]},{"type":"text","text":":"}]},{"items":[{"content":[{"inlineContent":[{"text":"Developed with input from the American Academy of Pediatrics.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Focus on healthy digital habits and age-appropriate content access.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}]},{"level":2,"type":"heading","anchor":"Apple-Intelligence-and-Siri-AI","text":"Apple Intelligence and Siri AI"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-siri-ai-architecture.jpeg"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Advanced AI Integration"}],"type":"strong"},{"text":":","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"Collaboration with Google on Apple Foundation models enhances Siri’s capabilities.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Models run on-device and on Private Cloud Compute to ensure privacy."}]}]}],"type":"unorderedList"}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-apple-intelligence-summary-1.jpeg"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-apple-intelligence-summary-2.jpeg"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"New Siri AI"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Provides a conversational experience with advanced speech understanding and generation."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Integrated across platforms for personalized assistance.","type":"text"}]}]}]}]}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"WWDC26-101-siri-ai-features.jpeg"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Visual Intelligence"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Siri can analyze images and provide contextual information, enriching user interactions.","type":"text"}],"type":"paragraph"}]}]}]}]},{"level":2,"type":"heading","anchor":"App-Enhancements","text":"App Enhancements"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Safari"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"AI organizes tabs into topics and monitors page updates with the Notify Me feature."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom extensions can be created easily with natural language descriptions."}]}]}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Photos","type":"text"}]},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Features like Clean Up, Extend, and Spatial Reframing for advanced photo editing.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Image Playground provides creative possibilities through generative models."}]}]}]}]}]},{"type":"paragraph","inlineContent":[{"identifier":"WWDC26-101-photos-features.jpeg","type":"image"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Shortcuts","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Simplified creation using natural language descriptions, making automation more accessible."}]}]}],"type":"unorderedList"}]}]},{"le