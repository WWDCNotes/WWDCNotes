{"sections":[],"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC26-101-Keynote"},"metadata":{"modules":[{"name":"WWDC Notes"}],"role":"sampleCode","title":"Keynote","roleHeading":"WWDC26"},"kind":"article","primaryContentSections":[{"content":[{"level":2,"anchor":"Key-Takeaways","type":"heading","text":"Key Takeaways"},{"items":[{"content":[{"inlineContent":[{"text":"Apple introduces Siri AI with powerful new capabilities for a more conversational experience.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"New design improvements and performance enhancements across macOS, iOS, and more."}]}]},{"content":[{"inlineContent":[{"text":"Enhanced child safety features with customizable parental controls.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Integration of Apple Intelligence models for smarter app functionalities."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Advanced photo editing tools with features like Spatial Reframing and Image Playground."}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"anchor":"WWDC-Highlights","type":"heading","text":"WWDC Highlights"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-ios-27.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Event Introduction by Tim Cook","type":"text"}]},{"type":"text","text":": Focused on the importance of platform advancements and developer community engagement. Celebrated the continuous growth and innovation within the Apple ecosystem."}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Developer Community Growth"}]},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Over 1,000 app submissions per hour to the App Store."}]}]},{"content":[{"inlineContent":[{"text":"Apple Developer Academies have educated tens of thousands worldwide, fostering the next generation of developers.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"level":2,"anchor":"Design-and-Performance-Enhancements","type":"heading","text":"Design and Performance Enhancements"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Cross-Platform Design Updates","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Liquid Glass"}],"type":"strong"},{"text":": Enhanced for improved readability and depth. Now includes a slider for users to adjust clarity from ultra-clear to fully tinted, allowing for personalized app experiences.","type":"text"}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-liquid-glass-slider.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"UI Consistency"}]},{"type":"text","text":": New uniform toolbars and expanded sidebars across apps provide better structure and focus, reducing distractions and enhancing usability."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Performance Optimizations","type":"text"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Faster App Launches"}]},{"type":"text","text":": iPhone and iPad apps launch up to 30% faster by preloading key data, increasing efficiency and user satisfaction."}],"type":"paragraph"}]},{"content":[{"type":"paragrap