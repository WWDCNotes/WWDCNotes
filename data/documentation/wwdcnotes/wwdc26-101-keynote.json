Content":[{"type":"text","text":"Developed with input from the American Academy of Pediatrics."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Focus on healthy digital habits and age-appropriate content access."}],"type":"paragraph"}]}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Apple-Intelligence-and-Siri-AI","type":"heading","text":"Apple Intelligence and Siri AI"},{"inlineContent":[{"identifier":"WWDC26-101-siri-ai-architecture.jpeg","type":"image"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Advanced AI Integration"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Collaboration with Google on Apple Foundation models enhances Siri’s capabilities.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Models run on-device and on Private Cloud Compute to ensure privacy."}],"type":"paragraph"}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"WWDC26-101-apple-intelligence-summary-1.jpeg","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"WWDC26-101-apple-intelligence-summary-2.jpeg"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"New Siri AI","type":"text"}],"type":"strong"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Provides a conversational experience with advanced speech understanding and generation."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Integrated across platforms for personalized assistance."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"WWDC26-101-siri-ai-features.jpeg","type":"image"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Visual Intelligence"}],"type":"strong"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Siri can analyze images and provide contextual information, enriching user interactions."}]}]}]}]}],"type":"unorderedList"},{"level":2,"anchor":"App-Enhancements","type":"heading","text":"App Enhancements"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Safari","type":"text"}]},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"AI organizes tabs into topics and monitors page updates with the Notify Me feature."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom extensions can be created easily with natural language descriptions."}]}]}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Photos","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Features like Clean Up, Extend, and Spatial Reframing for advanced photo editing."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Image Playground provides creative possibilities through generative models."}]}]}]}]}],"type":"unorderedList"},{"inlineContent":[{"identifier":"WWDC26-101-photos-features.jpeg","type":"image"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Shortcuts"}],"type":"strong"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Simplified creation using natural language descriptions, making automation more accessible."}],"type":"paragraph"}]}]}]}],"type":"unorderedList"},{"level":2,"anchor":"Developer-Tools","type":"heading","text":"Developer Tool