{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"article","hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15"]]},"metadata":{"role":"sampleCode","title":"What’s New in NSCollectionView","roleHeading":"WWDC15","modules":[{"name":"WWDC Notes"}]},"variants":[{"paths":["\/documentation\/wwdcnotes\/wwdc15-225-whats-new-in-nscollectionview"],"traits":[{"interfaceLanguage":"swift"}]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"overridingTitle":"Open on WWDCIndex","isActive":true,"type":"reference","identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2015\/225\/"}},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Be the hero to change that by watching the video or reading the transcript on WWDCIndex and providing notes! It’s super easy:"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing","isActive":true}],"type":"paragraph"},{"level":2,"text":"Related Sessions","type":"heading","anchor":"Related-Sessions"},{"style":"list","items":["doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-225-A-Tour-of-UICollectionView","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC17-218-Choosing-the-Right-Cocoa-Container-View"],"type":"links"}],"kind":"content"}],"sections":[],"abstract":[{"text":"NSCollectionView has been displaying grids of views for many years.  OS X 10.11 brings a major update to the capabilities of NSCollectionView.  Much of the design of UICollectionView in iOS is now available for OS X apps.  Understand the details of the enhancements and how you can harness them in your apps.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15-225-Whats-New-in-NSCollectionView"},"references":{"doc://WWDCNotes/documentation/WWDCNotes/WWDC15":{"title":"WWDC15","abstract":[{"text":"Xcode 7, Swift 2.0, iOS 9, macOS 10.11 (El Capitan), watchOS 2.","type":"text"}],"kind":"article","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC15","images":[{"type":"icon","identifier":"WWDC15-Icon.png"},{"type":"card","identifier":"WWDC15.jpeg"}],"type":"topic","url":"\/documentation\/wwdcnotes\/wwdc15","role":"collectionGroup"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC18-225-A-Tour-of-UICollectionView":{"kind":"article","role":"sampleCode","title":"A Tour of UICollectionView","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC18-225-A-Tour-of-UICollectionView","url":"\/documentation\/wwdcnotes\/wwdc18-225-a-tour-of-uicollectionview","abstract":[{"type":"text","text":"UICollectionView is a flexible, powerful tool to help you achieve great user experiences in your applications. Hear how you can leverage these rich APIs to rapidly move from initial design ideas to polished shipping applications. Topics range from getting started to advanced update animations and layouts."}],"type":"topic"},"doc://WWDCNotes/documentation/WWDCNotes":{"title":"WWDC Notes","url":"\/documentation\/wwdcnotes","images":[{"type":"icon","identifier":"WWDCNotes.png"}],"role":"collection","identifier":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes","abstract":[{"text":"Session notes shared by the community for the community.","type":"text"}],"kind":"symbol","type":"topic"},"WWDC15-Icon.png":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/WWDCNotes\/WWDC15-Icon.png"}],"identifier":"WWDC15-Icon.png"},"doc://WWDCNotes/documentation/WWDCNotes/WWDC17-218-Choosing-the-Right-Cocoa-Container-View":{"kind":"article","title":"Choosing the Right Cocoa Container View","url":"\/documentation\/wwdcnotes\/wwdc17-218-choosing-the-right-cocoa-container-view","role":"sampleCode","type":"topic","abstract":[{"type":"text","text":"AppKit o