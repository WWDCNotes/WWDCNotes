{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"In-App Purchase lets you embed a store directly within your app that can be used to sell a variety of items such as premium content, virtual goods or subscriptions. Discover the Store Kit APIs needed to add In App Purchase to your iOS or Mac OS X application. Understand how to perform receipt verification, and learn to manage and test items for sale through iTunes Connect. See how new features of iTunes Connect make it easier to manage large sets of items for sale, test subscriptions that automatically renew, and more.","type":"text"}],"metadata":{"title":"In-App Purchase for iOS and Mac OS X","modules":[{"name":"WWDC Notes"}],"roleHeading":"WWDC11","role":"sampleCode"},"primaryContentSections":[{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"😱 “No Overview Available!”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Be the hero to change that by reading the transcript and providing notes! It’s super easy:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/wwdcnotes.com\/documentation\/wwdcnotes\/contributing"}],"type":"paragraph"}],"kind":"content"}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"identifier":"https:\/\/nonstrict.eu\/wwdcindex\/wwdc2011\/510\/","type":"reference","overridingTitle":"Read Transcript","isActive":true}},"kind":"article","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/wwdcnotes\/wwdc11-510-inapp-purchase-for-ios-and-mac-os-x"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11-510-InApp-Purchase-for-iOS-and-Mac-OS-X"},"hierarchy":{"paths":[["doc:\/\/WWDCNotes\/documentation\/WWDCNotes","doc:\/\/WWDCNotes\/documentation\/WWDCNotes\/WWDC11"]]},"references":{"doc://WWDCNotes/documentation/WWDCNotes":{"images":[{"type":"icon","identifier":"WWD